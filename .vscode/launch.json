{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch FL Tools Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/tools/vscode",
        "${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/tools/vscode/dist/**/*.js"],
      "preLaunchTask": "FL: build"
    },
    {
      "name": "Launch FL Tools Extension (no build)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/tools/vscode",
        "${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/tools/vscode/dist/**/*.js"]
    }
  ]
}
