{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FL Tools (one-shot build)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/tools/vscode",
        "${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/tools/vscode/dist/extension/**/*.js"],
      "preLaunchTask": "FL: build"
    },
    {
      "name": "FL Tools (attach to running FL: dev)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/tools/vscode",
        "${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/tools/vscode/dist/extension/**/*.js"]
    }
  ]
}
