{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "FL: build",
      "detail": "One-shot extension + webview build. Used by 'FL Tools (build)' launch.",
      "type": "shell",
      "command": "pnpm",
      "args": ["exec", "pnpm", "run", "build"],
      "options": { "cwd": "${workspaceFolder}/tools/vscode" },
      "group": "build",
      "problemMatcher": [],
      "presentation": { "reveal": "silent", "panel": "dedicated" }
    },
    {
      "label": "FL: dev",
      "detail": "Watch host (esbuild) + webview (vite build --watch). On webview change the extension host fs-watches dist/webview and nudges open panels to reload (PWA-style). On extension code change, Cmd+R the Extension Development Host to pick up.",
      "type": "shell",
      "command": "pnpm",
      "args": ["exec", "pnpm", "run", "dev"],
      "options": { "cwd": "${workspaceFolder}/tools/vscode" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "fl-dev",
        "pattern": [
          { "regexp": "^.*$", "file": 1, "location": 2, "message": 3 }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*\\[host\\].*$",
          "endsPattern": "^.*watching extension host.*$"
        }
      },
      "presentation": { "panel": "dedicated", "reveal": "always" }
    }
  ]
}
