{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "FL: build",
      "detail": "One-shot extension + webview build. Used by 'FL Tools (build)' launch.",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@three-flatland/vscode", "build"],
      "group": "build",
      "problemMatcher": [],
      "presentation": { "reveal": "silent", "panel": "dedicated" }
    },
    {
      "label": "FL: dev",
      "detail": "Vite dev server + tsdown watch. Runs in the background; used by 'FL Tools (dev)' launch. Webview edits HMR; extension edits need Cmd+R on the Extension Development Host.",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@three-flatland/vscode", "dev"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "fl-vite",
        "pattern": [
          { "regexp": "^.*$", "file": 1, "location": 2, "message": 3 }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "ready in"
        }
      },
      "presentation": { "panel": "dedicated", "reveal": "always" }
    }
  ]
}
