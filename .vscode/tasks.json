{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "FL: watch all",
      "dependsOn": ["FL: watch host", "FL: watch webview"],
      "problemMatcher": []
    },
    {
      "label": "FL: watch host",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@three-flatland/vscode", "dev:host"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": [{ "regexp": "^.*$", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "watching extension host",
          "endsPattern": "watching extension host"
        }
      }
    },
    {
      "label": "FL: watch webview",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@three-flatland/vscode", "dev:webview"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": [{ "regexp": "^.*$", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "watching",
          "endsPattern": "built in"
        }
      }
    }
  ]
}
