{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "FL: build",
      "detail": "One-shot host + webview build. Used by the F5 launch config.",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@three-flatland/vscode", "build"],
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "FL: watch",
      "detail": "Live-rebuild host + webview on every save. Run manually while iterating; reload the Extension Development Host window (Cmd+R) to pick up changes.",
      "dependsOn": ["FL: watch host", "FL: watch webview"],
      "problemMatcher": []
    },
    {
      "label": "FL: watch host",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@three-flatland/vscode", "dev:host"],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "group": "FL watchers",
        "panel": "dedicated"
      }
    },
    {
      "label": "FL: watch webview",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@three-flatland/vscode", "dev:webview"],
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "group": "FL watchers",
        "panel": "dedicated"
      }
    }
  ]
}
