{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "FL: build",
      "detail": "One-shot extension + webview build. Used by 'FL Tools (one-shot build)' launch.",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@three-flatland/vscode", "build"],
      "group": "build",
      "problemMatcher": [],
      "presentation": { "reveal": "silent", "panel": "dedicated" }
    },
    {
      "label": "FL: dev",
      "detail": "Vite dev server + tsdown watch. Keeps running. Start once, then F5 'FL Tools (attach to running FL: dev)'. Edit webview → HMR. Edit extension → Cmd+R extension dev host.",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "@three-flatland/vscode", "dev"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": [{ "regexp": "^.*$", "file": 1, "location": 2, "message": 3 }],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      },
      "presentation": { "panel": "dedicated", "reveal": "always" }
    }
  ]
}
