{
  "$schema": "https://turborepo.dev/microfrontends/schema.json",
  "options": {
    "localProxyPort": 5173
  },
  "applications": {
    "docs": {
      "development": {
        "local": {
          "port": 4000
        }
      }
    },
    "examples": {
      "development": {
        "local": {
          "port": 5174
        }
      },
      "routing": [
        {
          "group": "examples",
          "paths": ["/three/:path*", "/react/:path*"]
        }
      ]
    },
    "example-vanilla-slug-text": {
      "development": {
        "local": {
          "port": 4017
        }
      },
      "routing": [
        {
          "group": "vanilla-examples",
          "paths": ["/vanilla/slug-text", "/vanilla/slug-text/:path*"]
        }
      ]
    }
  }
}
