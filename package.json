{
  "name": "three-flatland",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.28.1+sha512.7d7dbbca9e99447b7c3bf7a73286afaaf6be99251eb9498baefa7d406892f67b879adb3a1d7e687fc4ccc1a388c7175fbaae567a26ab44d1067b54fcb0d6a316",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "build": "NODE_OPTIONS=--max-old-space-size=8192 nx run-many -t build",
    "dev": "echo '\\n  ➜  Dev server: http://localhost:4321\\n' && nx run-many -t dev -p docs examples",
    "typecheck": "nx run-many -t typecheck",
    "lint": "oxlint --type-aware packages minis tools examples '!**/node_modules/**' '!**/dist/**' '!**/third_party/**' '!**/vendor/**' '!**/fixtures/**' '!**/*.gen.ts' '!**/*.generated.ts'",
    "lint:fix": "oxlint --type-aware --fix packages minis tools examples '!**/node_modules/**' '!**/dist/**' '!**/third_party/**' '!**/vendor/**' '!**/fixtures/**' '!**/*.gen.ts' '!**/*.generated.ts'",
    "format": "oxfmt '**/*.ts' '**/*.tsx'",
    "format:check": "oxfmt --check '**/*.ts' '**/*.tsx'",
    "test": "nx run-many -t test",
    "test:skia": "pnpm --filter @three-flatland/skia run build:wasm && pnpm --filter @three-flatland/skia run test",
    "test:smoke": "nx run docs:build && pnpm test:e2e",
    "test:smoke:ui": "nx run docs:build && pnpm test:e2e -- --ui",
    "test:smoke:headed": "nx run docs:build && pnpm test:e2e -- --headed",
    "test:smoke:install": "playwright install chromium",
    "test:e2e": "playwright test",
    "clean": "nx run-many -t clean && rm -rf node_modules/.vite .nx/cache",
    "changeset": "changeset",
    "changeset:generate": "tsx scripts/generate-changesets.ts",
    "changeset:version": "changeset version && tsx scripts/sync-versions.ts",
    "sync:versions": "tsx scripts/sync-versions.ts",
    "sync:versions:verify": "tsx scripts/sync-versions.ts --verify",
    "release": "nx run-many -t build && changeset publish",
    "sync:pack": "tsx scripts/sync-pack.ts",
    "sync:pack:verify": "tsx scripts/sync-pack.ts --verify",
    "tracks:add": "tsx scripts/add-track.ts",
    "bake:fonts": "tsx scripts/bake-example-fonts.ts",
    "sync:react": "tsx scripts/sync-react-subpaths.ts",
    "sync:react:verify": "tsx scripts/sync-react-subpaths.ts --verify",
    "sync:examples": "tsx scripts/sync-examples.ts",
    "sync:examples:verify": "tsx scripts/sync-examples.ts --verify",
    "validate:skills": "pnpm --filter @three-flatland/skills validate",
    "size": "size-limit",
    "size:why": "tsx scripts/size-why.ts",
    "gen:types": "tsx scripts/gen-schema-types.ts",
    "gen:types:verify": "tsx scripts/gen-schema-types.ts --verify",
    "sync:docs:schemas": "tsx scripts/sync-docs-schemas.ts",
    "sync:docs:schemas:verify": "tsx scripts/sync-docs-schemas.ts --verify",
    "graph": "nx graph",
    "prepare": "lefthook install",
    "boundaries": "node scripts/check-boundaries.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "three-flatland": "workspace:*",
      "@three-flatland/bake": "workspace:*",
      "@three-flatland/image": "workspace:*",
      "@three-flatland/nodes": "workspace:*",
      "@three-flatland/presets": "workspace:*",
      "@three-flatland/schemas": "workspace:*",
      "@three-flatland/skia": "workspace:*",
      "@three-flatland/skills": "workspace:*",
      "@three-flatland/slug": "workspace:*",
      "@three-flatland/devtools": "workspace:*",
      "yaml": "^2.8.4",
      "minimatch@<3.1.4": ">=3.1.4 <4",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7 <10",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0 <5",
      "ajv@<6.14.0": ">=6.14.0 <7",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0 <9",
      "flatted@<=3.4.1": ">=3.4.2 <4",
      "smol-toml@<1.6.1": ">=1.6.1 <2",
      "brace-expansion@<1.1.13": ">=1.1.13 <2",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3 <3",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6 <6",
      "picomatch@<2.3.2": ">=2.3.2 <3",
      "fast-uri@<=3.1.1": ">=3.1.2 <4",
      "esbuild@>=0.27.3 <0.28.1": ">=0.28.1 <0.29",
      "@babel/core@<=7.29.0": ">=7.29.6 <8",
      "markdown-it@<=14.1.1": ">=14.2.0 <15",
      "linkify-it@<=5.0.0": ">=5.0.1 <6",
      "js-yaml@<3.15.0": ">=3.15.0 <4",
      "js-yaml@>=4.0.0 <=4.1.1": ">=4.2.0 <5"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@playwright/test": "^1.60.0",
    "@size-limit/esbuild-why": "12.0.0",
    "@size-limit/preset-small-lib": "^12.0.0",
    "@three-flatland/normals": "workspace:*",
    "@types/dagre": "^0.7.54",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.2.6",
    "cytoscape": "^3.33.3",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-fcose": "^2.2.0",
    "dagre": "^0.8.5",
    "json-schema-to-typescript": "^15.0.4",
    "lefthook": "^2.1.5",
    "nx": "23.1.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "size-limit": "^12.0.0",
    "three-flatland": "workspace:*",
    "tsdown": "^0.22.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  }
}
