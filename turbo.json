{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "concurrency": "20",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "three-flatland#build", "@three-flatland/nodes#build", "@three-flatland/presets#build", "@three-flatland/skia#build"],
      "outputs": ["dist/**"]
    },
    "@three-flatland/skia#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["src/**", "wit/**", "build.zig", "build.zig.zon", "tsup.config.ts", "tsconfig.json", "package.json"]
    },
    "three-flatland#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@three-flatland/nodes#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@three-flatland/presets#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "docs#build": {
      "dependsOn": [
        "^build",
        "three-flatland#build",
        "@three-flatland/nodes#build",
        "@three-flatland/presets#build",
        "@three-flatland/mini-breakout#build",
        "example-vanilla-animation#build",
        "example-vanilla-basic-sprite#build",
        "example-vanilla-batch-demo#build",
        "example-vanilla-knightmark#build",
        "example-vanilla-pass-effects#build",
        "example-vanilla-tilemap#build",
        "example-vanilla-tsl-nodes#build",
        "example-react-animation#build",
        "example-react-basic-sprite#build",
        "example-react-batch-demo#build",
        "example-react-knightmark#build",
        "example-react-pass-effects#build",
        "example-react-tilemap#build",
        "example-react-tsl-nodes#build",
        "example-vanilla-skia#build",
        "example-react-skia#build"
      ],
      "outputs": ["dist/**"],
      "inputs": [
        "src/**",
        "public/**",
        "astro.config.mjs",
        "tsconfig.json"
      ]
    },
    "docs#dev": {
      "cache": false,
      "persistent": true
    }
  }
}
