      "locked": false,
      "fontSize": 13,
      "fontFamily": 3,
      "text": "const REGISTRY_SYMBOL = Symbol.for('three-flatland.registry')\n\nfunction getOrCreateRegistry(renderer, scene) {\n  let host = renderer[REGISTRY_SYMBOL]\n  if (!host) {\n    host = { scenes: new WeakMap() }\n    renderer[REGISTRY_SYMBOL] = host          // attached directly to renderer instance\n  }\n  let registry = host.scenes.get(scene)\n  if (!registry) {\n    registry = new Registry(renderer, scene)\n    host.scenes.set(scene, registry)\n  }\n  return registry\n}",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "const REGISTRY_SYMBOL = Symbol.for('three-flatland.registry')\n\nfunction getOrCreateRegistry(renderer, scene) {\n  let host = renderer[REGISTRY_SYMBOL]\n  if (!host) {\n    host = { scenes: new WeakMap() }\n    renderer[REGISTRY_SYMBOL] = host          // attached directly to renderer instance\n  }\n  let registry = host.scenes.get(scene)\n  if (!registry) {\n    registry = new Registry(renderer, scene)\n    host.scenes.set(scene, registry)\n  }\n  return registry\n}",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 11,
      "index": "a4"
    },
