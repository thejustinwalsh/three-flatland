  "elements": [

    {"type":"text","id":"hero","x":40,"y":-50,"width":1300,"height":40,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":4001,"version":1,"versionNonce":1,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"fontSize":32,"fontFamily":5,"text":"Per-(renderer, scene) registry  —  WeakMap-of-WeakMaps, no singletons","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Per-(renderer, scene) registry  —  WeakMap-of-WeakMaps, no singletons","autoResize":true,"lineHeight":1.25,"baseline":28},
    {"type":"text","id":"hero-sub","x":40,"y":0,"width":1300,"height":20,"angle":0,"strokeColor":"#666","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":4002,"version":1,"versionNonce":2,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"fontSize":14,"fontFamily":3,"text":"Keyed via Symbol.for('three-flatland.registry') so double-bundled module copies still share. Cross-realm separation is fundamental — not solved by any pattern.","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Keyed via Symbol.for('three-flatland.registry') so double-bundled module copies still share. Cross-realm separation is fundamental — not solved by any pattern.","autoResize":true,"lineHeight":1.25,"baseline":12},


    {"type":"text","id":"sec1","x":40,"y":50,"width":900,"height":36,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":4003,"version":1,"versionNonce":3,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"fontSize":24,"fontFamily":5,"text":"1.  Storage shape  —  module-level WeakMap, attached to each renderer instance","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"1.  Storage shape  —  module-level WeakMap, attached to each renderer instance","autoResize":true,"lineHeight":1.25,"baseline":20},

    {"type":"rectangle","id":"code-box","x":40,"y":110,"width":1320,"height":200,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"#f9fafb","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":{"type":3},"seed":4004,"version":1,"versionNonce":4,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"type":"text","id":"code-b","x":56,"y":124,"width":1288,"height":172,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":4005,"version":1,"versionNonce":5,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"fontSize":13,"fontFamily":3,"text":"const REGISTRY_SYMBOL = Symbol.for('three-flatland.registry')\n\nfunction getOrCreateRegistry(renderer, scene) {\n  let host = renderer[REGISTRY_SYMBOL]\n  if (!host) {\n    host = { scenes: new WeakMap() }\n    renderer[REGISTRY_SYMBOL] = host          // attached directly to renderer instance\n  }\n  let registry = host.scenes.get(scene)\n  if (!registry) {\n    registry = new Registry(renderer, scene)\n    host.scenes.set(scene, registry)\n  }\n  return registry\n}","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"const REGISTRY_SYMBOL = Symbol.for('three-flatland.registry')\n\nfunction getOrCreateRegistry(renderer, scene) {\n  let host = renderer[REGISTRY_SYMBOL]\n  if (!host) {\n    host = { scenes: new WeakMap() }\n    renderer[REGISTRY_SYMBOL] = host          // attached directly to renderer instance\n  }\n  let registry = host.scenes.get(scene)\n  if (!registry) {\n    registry = new Registry(renderer, scene)\n    host.scenes.set(scene, registry)\n  }\n  return registry\n}","autoResize":true,"lineHeight":1.25,"baseline":11},


    {"type":"text","id":"sec2","x":40,"y":340,"width":900,"height":36,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":4006,"version":1,"versionNonce":6,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"fontSize":24,"fontFamily":5,"text":"2.  Multi-renderer / multi-scene isolation  —  every tuple gets its own world","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"2.  Multi-renderer / multi-scene isolation  —  every tuple gets its own world","autoResize":true,"lineHeight":1.25,"baseline":20},

