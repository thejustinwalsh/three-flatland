    {"type":"text","id":"reg-c1-t","x":772,"y":532,"width":136,"height":86,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":4020,"version":1,"versionNonce":20,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"fontSize":11,"fontFamily":3,"text":"Registry\n(C, scene3)\n\n• world\n• defaults\n• batches\n• sprites","textAlign":"center","verticalAlign":"middle","containerId":null,"originalText":"Registry\n(C, scene3)\n\n• world\n• defaults\n• batches\n• sprites","autoResize":true,"lineHeight":1.25,"baseline":10},

    {"type":"text","id":"iso-note","x":40,"y":650,"width":1320,"height":40,"angle":0,"strokeColor":"#666","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":4021,"version":1,"versionNonce":21,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"fontSize":13,"fontFamily":3,"text":"Each rectangle is an independent registry: its own Koota world, own default materials, own batches, own sprite set. Same scene rendered by\ntwo renderers = two registries (each managing its own GPU resources). Same renderer rendering two scenes = two registries (separate worlds).","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Each rectangle is an independent registry: its own Koota world, own default materials, own batches, own sprite set. Same scene rendered by\ntwo renderers = two registries (each managing its own GPU resources). Same renderer rendering two scenes = two registries (separate worlds).","autoResize":true,"lineHeight":1.25,"baseline":11},


    {"type":"text","id":"sec3","x":40,"y":730,"width":900,"height":36,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":4022,"version":1,"versionNonce":22,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"fontSize":24,"fontFamily":5,"text":"3.  What each registry owns","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"3.  What each registry owns","autoResize":true,"lineHeight":1.25,"baseline":20},

    {"type":"rectangle","id":"owns-box","x":40,"y":790,"width":1320,"height":260,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"#f9fafb","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":{"type":3},"seed":4023,"version":1,"versionNonce":23,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"type":"text","id":"owns-b","x":56,"y":804,"width":1288,"height":232,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":4024,"version":1,"versionNonce":24,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"fontSize":13,"fontFamily":3,"text":"class Registry {\n  readonly renderer:        Renderer            // captured at first render\n  readonly scene:           Scene               // captured at first prime\n\n  readonly world:           World               // Koota — internal only, never exposed\n  readonly defaultMaterials: WeakMap<Texture, Sprite2DMaterial>   // texture → shared default\n  readonly batches:         Map<RunKey, SpriteBatch[]>            // (material, layer) → tiered batches\n  readonly sprites:         Set<Sprite2D>                          // registered primitives, for sweep\n  readonly particleSystems: Set<ParticleSystem>                    // ...future batcher kinds\n\n  // chained Scene.onBeforeRender install marker\n  _sceneHookInstalled = false\n  _originalSceneOnBeforeRender: SceneCallback | null = null\n}","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"class Registry {\n  readonly renderer:        Renderer            // captured at first render\n  readonly scene:           Scene               // captured at first prime\n\n  readonly world:           World               // Koota — internal only, never exposed\n  readonly defaultMaterials: WeakMap<Texture, Sprite2DMaterial>   // texture → shared default\n  readonly batches:         Map<RunKey, SpriteBatch[]>            // (material, layer) → tiered batches\n  readonly sprites:         Set<Sprite2D>                          // registered primitives, for sweep\n  readonly particleSystems: Set<ParticleSystem>                    // ...future batcher kinds\n\n  // chained Scene.onBeforeRender install marker\n  _sceneHookInstalled = false\n  _originalSceneOnBeforeRender: SceneCallback | null = null\n}","autoResize":true,"lineHeight":1.25,"baseline":11},


    {"type":"text","id":"sec4","x":40,"y":1080,"width":900,"height":36,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":4025,"version":1,"versionNonce":25,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"fontSize":24,"fontFamily":5,"text":"4.  GC chain  —  drop a key, the rest disappears","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"4.  GC chain  —  drop a key, the rest disappears","autoResize":true,"lineHeight":1.25,"baseline":20},

    {"type":"rectangle","id":"gc-box","x":40,"y":1140,"width":1320,"height":180,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"#fefefe","fillStyle":"solid","strokeWidth":2,"strokeStyle":"solid","roughness":1,"opacity":100,"groupIds":[],"frameId":null,"roundness":{"type":3},"seed":4026,"version":1,"versionNonce":26,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false},
    {"type":"text","id":"gc-b","x":56,"y":1154,"width":1288,"height":152,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":4027,"version":1,"versionNonce":27,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"fontSize":13,"fontFamily":3,"text":"Trigger                                        →   What gets collected\n────────────────────────────────────────       ─────────────────────────────────────────────\nUser drops scene reference                     →   Registry GC'd (host's WeakMap entry releases)\nUser disposes renderer                         →   All registries for that renderer GC'd\nUser disposes texture                          →   defaultMaterials entry GC'd (WeakMap key)\nUser disposes material                         →   We dispose batches via dispose event; sprites resurrect or fall back\nSprite removed from scene                      →   registry.sprites delete on 'removed' event; batch slot freed next sweep\n\nNo finalization machinery, no polling, no explicit teardown the user has to remember. WeakMap chains do the work.","textAlign":"left","verticalAlign":"top","containerId":null,"originalText":"Trigger                                        →   What gets collected\n────────────────────────────────────────       ─────────────────────────────────────────────\nUser drops scene reference                     →   Registry GC'd (host's WeakMap entry releases)\nUser disposes renderer                         →   All registries for that renderer GC'd\nUser disposes texture                          →   defaultMaterials entry GC'd (WeakMap key)\nUser disposes material                         →   We dispose batches via dispose event; sprites resurrect or fall back\nSprite removed from scene                      →   registry.sprites delete on 'removed' event; batch slot freed next sweep\n\nNo finalization machinery, no polling, no explicit teardown the user has to remember. WeakMap chains do the work.","autoResize":true,"lineHeight":1.25,"baseline":11}

  ],
