    {"type":"text","id":"reg-a1-t","x":52,"y":532,"width":136,"height":86,"angle":0,"strokeColor":"#1e1e1e","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"groupIds":[],"frameId":null,"roundness":null,"seed":4014,"version":1,"versionNonce":14,"isDeleted":false,"boundElements":null,"updated":1,"link":null,"locked":false,"fontSize":11,"fontFamily":3,"text":"Registry\n(A, scene1)\n\n• world\n• defaults\n• batches\n• sprites","textAlign":"center","verticalAlign":"middle","containerId":null,"originalText":"Registry\n(A, scene1)\n\n• world\n• defaults\n• batches\n• sprites","autoResize":true,"lineHeight":1.25,"baseline":10},

