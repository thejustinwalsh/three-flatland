    {
      "type": "text",
      "id": "iso-note",
      "x": 41.608662660341906,
      "y": 724.6439489588021,
      "width": 1320,
      "height": 40,
      "angle": 0,
      "strokeColor": "#666",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
