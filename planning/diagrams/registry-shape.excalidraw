      "seed": 4021,
      "version": 92,
      "versionNonce": 1491309894,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779077030745,
      "link": null,
      "locked": false,
      "fontSize": 13,
      "fontFamily": 3,
      "text": "Each rectangle is an independent registry: its own Koota world, own default materials, own batches, own sprite set. Same scene rendered by\ntwo renderers = two registries (each managing its own GPU resources). Same renderer rendering two scenes = two registries (separate worlds).",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Each rectangle is an independent registry: its own Koota world, own default materials, own batches, own sprite set. Same scene rendered by\ntwo renderers = two registries (each managing its own GPU resources). Same renderer rendering two scenes = two registries (separate worlds).",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 11,
      "index": "aK"
    },
