      "fontSize": 13,
      "fontFamily": 3,
      "text": "class Registry {\n  readonly renderer:        Renderer            // captured at first render\n  readonly scene:           Scene               // captured at first prime\n\n  readonly world:           World               // Koota — internal only, never exposed\n  readonly defaultMaterials: WeakMap<Texture, Sprite2DMaterial>   // texture → shared default\n  readonly batches:         Map<RunKey, SpriteBatch[]>            // (material, layer) → tiered batches\n  readonly sprites:         Set<Sprite2D>                          // registered primitives, for sweep\n  readonly particleSystems: Set<ParticleSystem>                    // ...future batcher kinds\n\n  // chained Scene.onBeforeRender install marker\n  _sceneHookInstalled = false\n  _originalSceneOnBeforeRender: SceneCallback | null = null\n}",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "class Registry {\n  readonly renderer:        Renderer            // captured at first render\n  readonly scene:           Scene               // captured at first prime\n\n  readonly world:           World               // Koota — internal only, never exposed\n  readonly defaultMaterials: WeakMap<Texture, Sprite2DMaterial>   // texture → shared default\n  readonly batches:         Map<RunKey, SpriteBatch[]>            // (material, layer) → tiered batches\n  readonly sprites:         Set<Sprite2D>                          // registered primitives, for sweep\n  readonly particleSystems: Set<ParticleSystem>                    // ...future batcher kinds\n\n  // chained Scene.onBeforeRender install marker\n  _sceneHookInstalled = false\n  _originalSceneOnBeforeRender: SceneCallback | null = null\n}",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 11,
      "index": "aN"
    },
