      "fontSize": 14,
      "fontFamily": 3,
      "text": "Every trait does three jobs at once: data shape · system dispatch · runtime branch. The library uses Koota; users never see it.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Every trait does three jobs at once: data shape · system dispatch · runtime branch. The library uses Koota; users never see it.",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 12,
      "index": "a1"
    },
