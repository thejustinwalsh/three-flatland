      "seed": 3012,
      "version": 2,
      "versionNonce": 1922355829,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779076546116,
      "link": null,
      "locked": false,
      "fontSize": 13,
      "fontFamily": 3,
      "text": "Cheap per-entity check inside a wider\nloop the system has to run anyway.\nBranch predictor handles it.\n\nExample:\n  for (const batch of activeBatches) {\n    sortInPlace(batch)\n    if (batch.entity.has(CastsShadow)) {\n      enqueueShadowPass(batch)\n    }\n  }\n\nUse when the loop must run anyway AND\nthe branch is predictable (constant per\nbatch life, etc.)",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Cheap per-entity check inside a wider\nloop the system has to run anyway.\nBranch predictor handles it.\n\nExample:\n  for (const batch of activeBatches) {\n    sortInPlace(batch)\n    if (batch.entity.has(CastsShadow)) {\n      enqueueShadowPass(batch)\n    }\n  }\n\nUse when the loop must run anyway AND\nthe branch is predictable (constant per\nbatch life, etc.)",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 11,
      "index": "aB"
    },
    {
      "type": "text",
      "id": "role-rule",
      "x": 40,
      "y": 350,
      "width": 1320,
      "height": 40,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 3013,
      "version": 2,
      "versionNonce": 1269791579,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779076546116,
      "link": null,
      "locked": false,
      "fontSize": 15,
      "fontFamily": 5,
      "text": "Decision rule:  trait when the system would otherwise touch entities it doesn't care about  ·  branch when the system already had to touch them",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Decision rule:  trait when the system would otherwise touch entities it doesn't care about  ·  branch when the system already had to touch them",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 13,
      "index": "aC"
    },
