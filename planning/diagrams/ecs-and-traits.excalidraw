      "fontSize": 13,
      "fontFamily": 3,
      "text": "// library defines built-in layers + extensible registry\nexport interface LayerRegistry {\n  default: BuiltInLayer\n  ui:      BuiltInLayer\n}\n\n// user code declares additions via module augmentation\ndeclare module 'three-flatland' {\n  interface LayerRegistry {\n    outline:   OutlineLayer\n    radarBlip: RadarBlipLayer\n  }\n}\n\nspriteGroup.createLayer('outline', { renderOrder: 10 })       // typed key, autocomplete\nspriteGroup.layer('outline').onRender(({ batches }) => { ... }) // typed return\nsprite.layer = 'outline'                                        // type-checked assignment\n\n// Internally each layer registers a Koota trait; user never sees the trait handle.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "// library defines built-in layers + extensible registry\nexport interface LayerRegistry {\n  default: BuiltInLayer\n  ui:      BuiltInLayer\n}\n\n// user code declares additions via module augmentation\ndeclare module 'three-flatland' {\n  interface LayerRegistry {\n    outline:   OutlineLayer\n    radarBlip: RadarBlipLayer\n  }\n}\n\nspriteGroup.createLayer('outline', { renderOrder: 10 })       // typed key, autocomplete\nspriteGroup.layer('outline').onRender(({ batches }) => { ... }) // typed return\nsprite.layer = 'outline'                                        // type-checked assignment\n\n// Internally each layer registers a Koota trait; user never sees the trait handle.",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 11,
      "index": "aM"
    },
