{
  "name": "@three-flatland/bridge",
  "version": "0.0.0",
  "private": true,
  "description": "Typed postMessage RPC between VSCode extension host and webview",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./host": {
      "source": "./src/host.ts",
      "import": {
        "types": "./dist/host.d.ts",
        "default": "./dist/host.js"
      }
    },
    "./client": {
      "source": "./src/client.ts",
      "import": {
        "types": "./dist/client.d.ts",
        "default": "./dist/client.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "nx": {
    "targets": {
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "oxlint --type-aware .",
          "cwd": "{projectRoot}"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  }
}
