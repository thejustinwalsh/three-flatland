{
  "name": "@three-flatland/design-system",
  "version": "0.0.0",
  "private": true,
  "description": "Shared UI primitives for three-flatland editor tools — thin wrappers over @vscode-elements/react-elements",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./src/tokens/vscode-theme.stylex": {
      "source": "./src/tokens/vscode-theme.stylex.ts",
      "types": "./src/tokens/vscode-theme.stylex.ts",
      "default": "./src/tokens/vscode-theme.stylex.ts"
    },
    "./src/tokens/space.stylex": {
      "source": "./src/tokens/space.stylex.ts",
      "types": "./src/tokens/space.stylex.ts",
      "default": "./src/tokens/space.stylex.ts"
    },
    "./src/tokens/radius.stylex": {
      "source": "./src/tokens/radius.stylex.ts",
      "types": "./src/tokens/radius.stylex.ts",
      "default": "./src/tokens/radius.stylex.ts"
    },
    "./src/tokens/z.stylex": {
      "source": "./src/tokens/z.stylex.ts",
      "types": "./src/tokens/z.stylex.ts",
      "default": "./src/tokens/z.stylex.ts"
    }
  },
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["src"],
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stylexjs/stylex": "catalog:"
  },
  "peerDependencies": {
    "@vscode-elements/react-elements": "^2.4.0",
    "react": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@vscode-elements/react-elements": "^2.4.0",
    "react": "catalog:"
  }
}
