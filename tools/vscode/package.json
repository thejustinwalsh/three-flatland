{
  "name": "@three-flatland/vscode",
  "displayName": "three-flatland Tools",
  "version": "0.0.0",
  "private": true,
  "description": "Official three-flatland tools for editor hosts (VSCode, Cursor, Antigravity)",
  "publisher": "three-flatland",
  "type": "module",
  "main": "./dist/extension/index.js",
  "engines": {
    "vscode": "^1.94.0"
  },
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "threeFlatland.atlas.openEditor",
        "title": "Open in FL Sprite Atlas",
        "category": "FL"
      }
    ],
    "customEditors": [
      {
        "viewType": "threeFlatland.atlas",
        "displayName": "FL Sprite Atlas",
        "selector": [
          { "filenamePattern": "*.png" }
        ],
        "priority": "option"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "threeFlatland.atlas.openEditor",
          "when": "resourceExtname == .png",
          "group": "navigation@10"
        }
      ],
      "commandPalette": [
        {
          "command": "threeFlatland.atlas.openEditor",
          "when": "resourceExtname == .png"
        }
      ]
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@three-flatland/bridge": "workspace:*",
    "@three-flatland/design-system": "workspace:*",
    "@three-flatland/io": "workspace:*",
    "@three-flatland/preview": "workspace:*",
    "@react-three/fiber": "catalog:",
    "@vscode-elements/elements": "^2.5.1",
    "@vscode-elements/react-elements": "^2.4.0",
    "@vscode/codicons": "^0.0.44",
    "react": "catalog:",
    "react-dom": "catalog:",
    "three": "catalog:",
    "three-flatland": "workspace:*"
  },
  "devDependencies": {
    "@tomjs/vite-plugin-vscode": "^7.1.1",
    "@types/node": "^22.10.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/vscode": "^1.94.0",
    "@vitejs/plugin-react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
