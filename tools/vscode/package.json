{
  "name": "@three-flatland/vscode",
  "displayName": "three-flatland Tools",
  "version": "0.0.0",
  "private": true,
  "description": "Official three-flatland tools for editor hosts (VSCode, Cursor, Antigravity)",
  "publisher": "three-flatland",
  "type": "module",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.94.0"
  },
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact"
  ],
  "contributes": {
    "commands": [
      {
        "command": "threeFlatland.atlas.openEditor",
        "title": "Open in Sprite Atlas",
        "category": "FL"
      },
      {
        "command": "threeFlatland.merge.openMergeTool",
        "title": "Merge Atlases…",
        "category": "FL"
      },
      {
        "command": "threeFlatland.wasmTest.open",
        "title": "WASM Contract Test",
        "category": "FL"
      },
      {
        "command": "threeFlatland.encode.open",
        "title": "Open in Image Encoder",
        "category": "FL"
      },
      {
        "command": "threeFlatland.zzfx.playAtCursor",
        "title": "Play ZzFX at Cursor",
        "category": "FL"
      },
      {
        "command": "threeFlatland.zzfx.openEditor",
        "title": "Open ZzFX Editor",
        "category": "FL"
      },
      {
        "command": "threeFlatland.normalBaker.open",
        "title": "Open in Normal Baker",
        "category": "FL"
      }
    ],
    "customEditors": [
      {
        "viewType": "threeFlatland.atlas",
        "displayName": "FL Sprite Atlas",
        "selector": [
          {
            "filenamePattern": "*.png"
          }
        ],
        "priority": "option"
      },
      {
        "viewType": "threeFlatland.encode",
        "displayName": "FL KTX2 Viewer",
        "selector": [
          {
            "filenamePattern": "*.ktx2"
          }
        ],
        "priority": "default"
      }
    ],
    "configuration": {
      "title": "FL Tools",
      "properties": {
        "threeFlatland.tools.spriteAtlas.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable FL Sprite Atlas (packing + animation editor for sprite sheets)."
        },
        "threeFlatland.tools.imageEncoder.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable FL Image Encoder (PNG/WebP/AVIF/KTX2 comparison + encoding)."
        },
        "threeFlatland.tools.atlasMerge.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable FL Atlas Merge (combine multiple .atlas.json sprite sheets)."
        },
        "threeFlatland.tools.normalBaker.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable FL Normal Baker (region editor for baking normal maps from PNG source art)."
        },
        "threeFlatland.tools.zzfxStudio.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable FL ZzFX Studio (CodeLens + tuner panel for zzfx() sound-effect calls). Changing this setting requires a window reload."
        },
        "threeFlatland.zzfx.inlinePlayback.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Play ZzFX one-shots via a lightweight background process instead of opening the editor panel. Disable to always route ▶ Play through the panel."
        },
        "threeFlatland.zzfx.playbackVolume": {
          "type": "number",
          "default": 0,
          "minimum": -12,
          "maximum": 12,
          "description": "Playback volume adjustment for ZzFX preview sounds, in dB relative to the default loudness. 0 keeps the built-in baseline; positive is louder, negative quieter (±12 dB ≈ ×4 / ×0.25). Applies to both the inline ▶ Play route and the tuner panel."
        }
      }
    },
    "submenus": [
      {
        "id": "threeFlatland.flatlandMenu",
        "label": "FL Tools",
        "icon": "$(package)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "threeFlatland.flatlandMenu",
          "group": "navigation@10",
          "when": "(threeFlatland.tool.spriteAtlas.enabled && (resourceExtname == .png || resourceFilename =~ /\\.atlas\\.json$/)) || (threeFlatland.tool.imageEncoder.enabled && (resourceExtname == .png || resourceExtname == .webp || resourceExtname == .avif || resourceExtname == .ktx2)) || (threeFlatland.tool.atlasMerge.enabled && resourceFilename =~ /\\.atlas\\.json$/) || (threeFlatland.tool.normalBaker.enabled && (resourceExtname == .png || resourceFilename =~ /\\.normal\\.json$/))"
        }
      ],
      "threeFlatland.flatlandMenu": [
        {
          "command": "threeFlatland.atlas.openEditor",
          "when": "threeFlatland.tool.spriteAtlas.enabled && (resourceExtname == .png || resourceFilename =~ /\\.atlas\\.json$/)",
          "group": "1_authoring@1"
        },
        {
          "command": "threeFlatland.normalBaker.open",
          "when": "threeFlatland.tool.normalBaker.enabled && (resourceExtname == .png || resourceFilename =~ /\\.normal\\.json$/)",
          "group": "1_authoring@2"
        },
        {
          "command": "threeFlatland.encode.open",
          "when": "threeFlatland.tool.imageEncoder.enabled && (resourceExtname == .png || resourceExtname == .webp || resourceExtname == .avif || resourceExtname == .ktx2)",
          "group": "2_convert@1"
        },
        {
          "command": "threeFlatland.merge.openMergeTool",
          "when": "threeFlatland.tool.atlasMerge.enabled && resourceFilename =~ /\\.atlas\\.json$/",
          "group": "3_combine@1"
        }
      ],
      "commandPalette": [
        {
          "command": "threeFlatland.atlas.openEditor",
          "when": "threeFlatland.tool.spriteAtlas.enabled && (resourceExtname == .png || resourceFilename =~ /\\.atlas\\.json$/)"
        },
        {
          "command": "threeFlatland.merge.openMergeTool",
          "when": "threeFlatland.tool.atlasMerge.enabled && resourceFilename =~ /\\.atlas\\.json$/"
        },
        {
          "command": "threeFlatland.encode.open",
          "when": "threeFlatland.tool.imageEncoder.enabled && (resourceExtname == .png || resourceExtname == .webp || resourceExtname == .avif || resourceExtname == .ktx2)"
        },
        {
          "command": "threeFlatland.normalBaker.open",
          "when": "threeFlatland.tool.normalBaker.enabled && (resourceExtname == .png || resourceFilename =~ /\\.normal\\.json$/)"
        },
        {
          "command": "threeFlatland.zzfx.playAtCursor",
          "when": "threeFlatland.tool.zzfxStudio.enabled && (resourceLangId == typescript || resourceLangId == typescriptreact || resourceLangId == javascript || resourceLangId == javascriptreact)"
        },
        {
          "command": "threeFlatland.zzfx.openEditor",
          "when": "threeFlatland.tool.zzfxStudio.enabled && (resourceLangId == typescript || resourceLangId == typescriptreact || resourceLangId == javascript || resourceLangId == javascriptreact)"
        }
      ]
    },
    "languages": [
      {
        "id": "fl-atlas",
        "aliases": [
          "FL Atlas"
        ],
        "filenamePatterns": [
          "*.atlas.json"
        ],
        "icon": {
          "light": "./icons/atlas-light.svg",
          "dark": "./icons/atlas-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "fl-atlas",
        "scopeName": "source.fl-atlas",
        "path": "./grammars/fl-atlas.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "build": "pnpm run build:webview && pnpm run build:host",
    "build:host": "node esbuild.config.mjs",
    "build:webview": "vite build",
    "dev": "concurrently -n host,webview -c blue,magenta --prefix \"[{name}]\" \"pnpm run dev:host\" \"pnpm run dev:webview\"",
    "dev:host": "node esbuild.config.mjs --watch",
    "dev:webview": "vite build --watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p e2e/tsconfig.json",
    "clean": "rm -rf dist",
    "package": "vsce package --no-dependencies",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts"
  },
  "dependencies": {
    "@jsquash/webp": "catalog:",
    "@stylexjs/stylex": "catalog:",
    "@three-flatland/bake": "workspace:*",
    "@three-flatland/bridge": "workspace:*",
    "@three-flatland/codelens-service": "workspace:*",
    "@three-flatland/image": "workspace:*",
    "@three-flatland/design-system": "workspace:*",
    "@three-flatland/io": "workspace:*",
    "@three-flatland/normals": "workspace:*",
    "@three-flatland/preview": "workspace:*",
    "@three-flatland/schemas": "workspace:*",
    "@three-flatland/zzfx-play": "workspace:*",
    "@react-three/fiber": "catalog:",
    "@vscode-elements/elements": "^2.5.1",
    "@vscode-elements/react-elements": "^2.4.0",
    "@vscode/codicons": "^0.0.44",
    "react": "catalog:",
    "react-dom": "catalog:",
    "three": "catalog:",
    "three-flatland": "workspace:*",
    "zundo": "catalog:",
    "zustand": "catalog:",
    "zzfx": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@stylexjs/unplugin": "catalog:",
    "@types/node": "^22.10.0",
    "@types/pngjs": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/three": "catalog:",
    "@types/vscode": "^1.94.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "catalog:",
    "@vscode/test-electron": "^3.0.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.25.0",
    "pngjs": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "ws": "^8.21.0"
  }
}
