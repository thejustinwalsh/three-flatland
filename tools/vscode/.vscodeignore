# Everything here is a gitignore-style EXCLUDE pattern — files not
# matched are included in the packaged .vsix. package.json, LICENSE,
# README.md, and CHANGELOG.md are always included by vsce regardless of
# this file; don't bother listing them.
#
# Runtime-needed and therefore NEVER excluded: dist/, bin/, audio-play/,
# grammars/, icons/ (contributes.grammars / contributes.languages /
# the marketplace icon all reference these directly) — EXCEPT
# icons/readme/, see below.

# Source — compiled into dist/ by `pnpm build`
extension/**
webview/**

# Dev/build tooling — not needed once dist/ + bin/ + audio-play/ exist
scripts/**
esbuild.config.mjs
vite.config.ts
tsconfig.json
.turbo/**

# Marketing screenshots + banner — vsce rewrites README.md's relative
# image paths to raw.githubusercontent.com URLs for the marketplace
# listing (see scripts/package-vsix.mjs's --githubBranch comment), so
# nothing at runtime ever loads these from inside the package. Shipping
# them would just be dead weight in every user's download.
docs/**

# Same reasoning as docs/** above — these are README section-header
# icons, only ever referenced via relative <img> tags in README.md, never
# by package.json contributes or extension runtime code. icon.png and the
# fl-atlas grammar icons directly above this stay (those ARE referenced
# at runtime), only this subdirectory is README-only decoration.
icons/readme/**

# Tests
e2e/**

# Downloaded VS Code test binary (~264 MB) — never ship this
.vscode-test/**

# Local dev deps — everything runtime-needed is bundled into dist/ or
# copied into audio-play/node_modules/ by scripts/bundle-sidecars.mjs
node_modules/**

# Maintainer/agent-facing docs, not user-facing — README.md is the only
# doc an installed extension needs to carry.
AGENTS.md
CLAUDE.md
PUBLISHING.md
.impeccable/**
.restruct/**

# Sourcemaps — smaller package; drop this line if stack-trace fidelity
# in bug reports becomes worth the size.
**/*.map

.gitignore
*.vsix
