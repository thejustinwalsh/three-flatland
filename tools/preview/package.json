{
  "name": "@three-flatland/preview",
  "version": "0.0.0",
  "private": true,
  "description": "Shared R3F preview components for three-flatland editor tools",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@react-three/fiber": "catalog:",
    "react": "catalog:",
    "three": "catalog:",
    "three-flatland": "workspace:*"
  },
  "devDependencies": {
    "@react-three/fiber": "catalog:",
    "@types/react": "catalog:",
    "@types/three": "catalog:",
    "react": "catalog:",
    "three": "catalog:",
    "three-flatland": "workspace:*"
  }
}
