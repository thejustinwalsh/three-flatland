{
  "name": "@three-flatland/codelens-service",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript client for the codelens-service Rust sidecar — spawns the process, speaks LSP-framed JSON-RPC, exposes a typed protocol",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "catalog:"
  }
}
