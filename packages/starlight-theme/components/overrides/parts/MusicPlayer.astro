---
/**
 * MusicPlayer — header popover for the docs jukebox. Sits LEFT of
 * SoundToggle in the header audio cluster so master mute stays
 * rightmost (per design). Renders a small icon button; click opens
 * a popover with track metadata, prev/play-pause/restart/next, music
 * volume slider, and a thin progress line.
 *
 * Toast behavior: when the active track changes (auto-start, user
 * clicks next/prev, restart, or an external — game — source takes
 * over the music bus), the popover auto-opens for ~3s as a "now
 * playing" toast then auto-closes. If the user interacts with the
 * popover during the open window, it stays open until they explicitly
 * close.
 *
 * External takeover: when `state.musicDuckedExternal` is true, all
 * jukebox transport controls (prev/play-pause/restart/next) disable;
 * volume slider remains active (controls the docs music bus only,
 * which is ducked). The popover title swaps to show the external
 * (game) track. On unduck, controls re-enable.
 */
---

<flatland-music-player>
    {/* Native HTML Popover API — `popover="auto"` gives us light dismiss
        (click outside) + Escape close + top-layer rendering for free.
        The trigger uses `popovertarget` to reference the popover by id;
        the browser also wires implicit aria-expanded on the button so
        we don't have to manage that attribute manually. */}
    <button
        type="button"
        class="music-trigger"
        aria-label="Open music player"
        popovertarget="flatland-music-popover"
        title="Music — click to open player"
    >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18V5l12-2v13" />
            <circle cx="6" cy="18" r="3" />
            <circle cx="18" cy="16" r="3" />
        </svg>
    </button>

    <div
        id="flatland-music-popover"
        class="music-popover"
        role="dialog"
        aria-label="Music player"
        popover="auto"
    >
        <div class="music-meta">
            <span class="music-title" data-music-title>Loading…</span>
            <span class="music-credit" data-music-credit></span>
        </div>

        <div class="music-controls" data-music-controls>
            <button type="button" class="music-btn" data-music-prev aria-label="Previous track" title="Previous track">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="19 20 9 12 19 4 19 20" />
                    <line x1="5" y1="19" x2="5" y2="5" />
                </svg>
            </button>
            <button type="button" class="music-btn" data-music-restart aria-label="Restart track" title="Restart track">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="1 4 1 10 7 10" />
                    <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10" />
                </svg>
            </button>
            <button type="button" class="music-btn music-toggle" data-music-toggle aria-label="Play" title="Play">
                <svg class="icon-play" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                    <polygon points="5 3 19 12 5 21 5 3" />
                </svg>
                <svg class="icon-pause" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                    <rect x="6" y="4" width="4" height="16" />
                    <rect x="14" y="4" width="4" height="16" />
                </svg>
            </button>
            <button type="button" class="music-btn" data-music-next aria-label="Next track" title="Next track">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="5 4 15 12 5 20 5 4" />
                    <line x1="19" y1="5" x2="19" y2="19" />
                </svg>
            </button>
        </div>

        <label class="music-volume-label">
            <span class="sr-only">Music volume</span>
            <input
                type="range"
                class="music-volume"
                data-music-volume
                min="0"
                max="100"
                value="30"
                aria-label="Music volume"
            />
        </label>

        <div class="music-progress" aria-hidden="true">
            <span class="music-progress-fill" data-music-progress-fill></span>
        </div>
    </div>
</flatland-music-player>

<script>
    type SoundsModule = typeof import('../../../../../docs/src/scripts/sounds')

    type Track = {
        id: string
        title: string
        credit?: string
        gem?: string
        bpm: number
    }

    type AudioState = {
        masterLevel: 0 | 1 | 2 | 3
        musicVolume: number
        musicPlaying: boolean
        musicTrackIndex: number
        musicUserStopped: boolean
        musicDuckedExternal: boolean
        currentTrack: Track | null
        library: { tracks: Track[] } | null
    }

    const TOAST_MS = 3000

    class FlatlandMusicPlayer extends HTMLElement {
        private cleanup?: AbortController
        private toastTimer: number | null = null
        private soundsPromise?: Promise<SoundsModule>
        private lastTrackId: string | null = null
        private userInteractedDuringToast = false
        private progressRaf = 0

        private trigger!: HTMLButtonElement
        private popoverEl!: HTMLElement
        private titleEl!: HTMLElement
        private creditEl!: HTMLElement
        private toggleBtn!: HTMLButtonElement
        private prevBtn!: HTMLButtonElement
        private nextBtn!: HTMLButtonElement
        private restartBtn!: HTMLButtonElement
        private volumeInput!: HTMLInputElement
        private progressFill!: HTMLElement
        private controls!: HTMLElement

        constructor() {
            super()
            const ctrl = new AbortController()
            this.cleanup = ctrl
            const { signal } = ctrl

            this.trigger = this.querySelector<HTMLButtonElement>('.music-trigger')!
            this.popoverEl = this.querySelector<HTMLElement>('.music-popover')!
            this.titleEl = this.querySelector<HTMLElement>('[data-music-title]')!
            this.creditEl = this.querySelector<HTMLElement>('[data-music-credit]')!
            this.toggleBtn = this.querySelector<HTMLButtonElement>('[data-music-toggle]')!
            this.prevBtn = this.querySelector<HTMLButtonElement>('[data-music-prev]')!
            this.nextBtn = this.querySelector<HTMLButtonElement>('[data-music-next]')!
            this.restartBtn = this.querySelector<HTMLButtonElement>('[data-music-restart]')!
            this.volumeInput = this.querySelector<HTMLInputElement>('[data-music-volume]')!
            this.progressFill = this.querySelector<HTMLElement>('[data-music-progress-fill]')!
            this.controls = this.querySelector<HTMLElement>('[data-music-controls]')!

            // Transport handlers — the popover open/close itself is owned
            // by the native `popover` attribute on the panel + the
            // `popovertarget` attribute on the trigger button. The browser
            // handles light dismiss + Escape + top-layer rendering.
            this.toggleBtn.addEventListener('click', () => this.handleToggle(), { signal })
            this.prevBtn.addEventListener('click', () => this.handlePrev(), { signal })
            this.nextBtn.addEventListener('click', () => this.handleNext(), { signal })
            this.restartBtn.addEventListener('click', () => this.handleRestart(), { signal })
            this.volumeInput.addEventListener('input', (e) => this.handleVolume(e), { signal })

            // Popover position is static — CSS pins it relative to the
            // header (top: header-height + gap; right: container padding).
            // The trigger button doesn't move laterally between routes,
            // so no per-open position computation needed.

            // Toast logic + progress loop hook into the popover's state
            // changes. `toggle` fires after the state has changed.
            this.popoverEl.addEventListener(
                'toggle',
                (e: Event) => {
                    const ev = e as { newState?: string } & Event
                    if (ev.newState === 'open') {
                        this.startProgressLoop()
                    } else {
                        this.stopProgressLoop()
                        if (this.toastTimer !== null) {
                            clearTimeout(this.toastTimer)
                            this.toastTimer = null
                        }
                    }
                },
                { signal }
            )

            // Track user interaction with the popover so a toast doesn't
            // auto-close when the user clicks inside it.
            this.popoverEl.addEventListener(
                'click',
                () => {
                    this.userInteractedDuringToast = true
                    if (this.toastTimer !== null) {
                        clearTimeout(this.toastTimer)
                        this.toastTimer = null
                    }
                },
                { signal }
            )

            // Eager-but-lazy: pull the audio module on idle so first user
            // interaction is hot. The bridge loads tracks.json + zzfxm
            // here too.
            const onIdle =
                window.requestIdleCallback ??
                ((cb: () => void) => window.setTimeout(cb, 1))
            onIdle(() => {
                if (signal.aborted) return
                this.loadSounds()
            })

            // Close the popover on scroll — it's a transient surface,
            // not a sticky modal. Passive listener so scrolling stays
            // smooth; checking matches(:popover-open) each tick is
            // O(1).
            window.addEventListener(
                'scroll',
                () => {
                    if (
                        (this.popoverEl as HTMLElement & { matches: (s: string) => boolean }).matches(
                            ':popover-open'
                        )
                    ) {
                        try {
                            ;(this.popoverEl as HTMLElement & { hidePopover: () => void }).hidePopover()
                        } catch {}
                    }
                },
                { passive: true, signal }
            )
        }

        disconnectedCallback() {
            this.cleanup?.abort()
            this.cleanup = undefined
            if (this.toastTimer !== null) clearTimeout(this.toastTimer)
            if (this.progressRaf) cancelAnimationFrame(this.progressRaf)
        }

        private loadSounds(): Promise<SoundsModule> {
            if (!this.soundsPromise) {
                this.soundsPromise = import(
                    /* @vite-ignore */
                    '../../../../../docs/src/scripts/sounds'
                ) as Promise<SoundsModule>
                this.soundsPromise.then(async (sounds) => {
                    // Force the bridge to materialize so we can subscribe
                    // to its state. initAudio resolves once the bridge is
                    // constructed (it needs a user gesture to fully unlock,
                    // but the singleton + library are ready immediately).
                    await sounds.initAudio()
                    const bridge = (window as unknown as { __threeFlatlandAudio?: { subscribe: (cb: (s: AudioState) => void) => () => void } })
                        .__threeFlatlandAudio
                    if (!bridge) return
                    // Bridge exposes subscribe(cb): unsubscribe; cb receives state.
                    // Don't destructure — destructured methods lose their
                    // `this` binding and `subscribe` would call into a
                    // detached function, breaking `this.listeners.add()`.
                    bridge.subscribe((state) => this.applyState(state))
                })
            }
            return this.soundsPromise
        }

        private getBridge(): {
            playTrack: (t: Track, opts?: { fromUserGesture?: boolean }) => void
            pauseMusic: () => void
            resumeMusic: () => void
            restartMusic: () => void
            nextTrack: () => void
            prevTrack: () => void
            setMusicVolume: (v: number) => void
            getState: () => AudioState
        } | undefined {
            return (window as unknown as { __threeFlatlandAudio?: unknown })
                .__threeFlatlandAudio as ReturnType<FlatlandMusicPlayer['getBridge']>
        }

        private async ensureBridge() {
            await this.loadSounds()
            return this.getBridge()
        }

        // ────────── Popover open/close ──────────
        //
        // Native popover API handles user-driven open/close via the
        // `popovertarget` attribute on the trigger button + the
        // `popover="auto"` attribute on the panel. Light dismiss
        // (click outside) and Escape close are automatic.
        //
        // This component only programmatically opens the popover as a
        // *toast* on track change — see `openAsToast`. Closing the toast
        // is also explicit: a timer fires `hidePopover()` after TOAST_MS
        // unless the user interacted with the panel during the window.

        /** Open as a transient toast on track change. Auto-closes after
         * TOAST_MS unless the user clicks inside the popover during the
         * window (in which case it stays open until they dismiss it via
         * Escape or outside click — both browser-handled). */
        private openAsToast(): void {
            // Already open (user clicked through to it) — leave alone.
            const popoverEl = this.popoverEl as HTMLElement & { matches: (s: string) => boolean }
            if (popoverEl.matches(':popover-open')) return
            this.userInteractedDuringToast = false
            try {
                ;(this.popoverEl as HTMLElement & { showPopover: () => void }).showPopover()
            } catch {
                // showPopover throws if browser doesn't support the API or
                // the popover is already open from a stale state — silent
                // fallback is fine.
                return
            }
            this.toastTimer = window.setTimeout(() => {
                this.toastTimer = null
                if (this.userInteractedDuringToast) return
                try {
                    ;(this.popoverEl as HTMLElement & { hidePopover: () => void }).hidePopover()
                } catch {}
            }, TOAST_MS)
        }

        // ────────── State sync ──────────

        private applyState(state: AudioState): void {
            const track = state.currentTrack
            const title = track?.title ?? 'No track loaded'
            const credit = track?.credit ?? ''
            this.titleEl.textContent = title
            this.creditEl.textContent = credit

            // Toggle button reflects play/pause state.
            const playing = state.musicPlaying
            this.toggleBtn.setAttribute('aria-label', playing ? 'Pause' : 'Play')
            this.toggleBtn.setAttribute('title', playing ? 'Pause' : 'Play')
            this.toggleBtn.dataset.playing = playing ? 'true' : 'false'

            // External takeover disables transport controls.
            const ducked = state.musicDuckedExternal
            this.controls.dataset.ducked = ducked ? 'true' : 'false'
            this.prevBtn.disabled = ducked || !state.library?.tracks?.length
            this.nextBtn.disabled = ducked || !state.library?.tracks?.length
            this.restartBtn.disabled = ducked || !track
            this.toggleBtn.disabled = ducked || !track

            // Volume slider mirrors music bus (0..1 → 0..100).
            const vol100 = Math.round(state.musicVolume * 100)
            if (parseInt(this.volumeInput.value, 10) !== vol100) {
                this.volumeInput.value = String(vol100)
            }

            // Indicate external state on the trigger button so the user can
            // see the music dipped without opening the popover.
            this.trigger.dataset.state = ducked ? 'ducked' : playing ? 'playing' : 'idle'

            // Track changed → open as toast (unless popover already open).
            const trackId = track?.id ?? null
            if (trackId !== this.lastTrackId && trackId !== null) {
                this.lastTrackId = trackId
                this.openAsToast()
            }
        }

        // ────────── Transport handlers ──────────

        private async handleToggle(): Promise<void> {
            const sounds = await this.loadSounds()
            const bridge = await this.ensureBridge()
            if (!bridge) return
            const state = bridge.getState()
            if (state.musicDuckedExternal) return
            if (state.musicPlaying) {
                bridge.pauseMusic()
                return
            }
            // Authority model: SoundToggle is the global audio gate.
            //   - level > 0           → play normally
            //   - level = 0, never set → auto-unlock to low (icon updates
            //                            reactively via bridge subscription)
            //   - level = 0, explicit  → respect user's mute, don't play
            // Explicit mute is detected by the presence of the localStorage
            // key (any value set, even "0", means the user has interacted).
            if (state.masterLevel === 0) {
                const explicit = localStorage.getItem('flatland-sound-volume') !== null
                if (explicit) return // muted on purpose; honor the choice
                // Default off → elevate to low. setVolumeLevel writes
                // storage + calls bridge.setMasterLevel which fires the
                // first-unmute autostart path (music begins automatically
                // because we've now transitioned from 0 → 1).
                sounds.setVolumeLevel(1)
                return
            }
            bridge.resumeMusic()
        }

        private async handlePrev(): Promise<void> {
            const bridge = await this.ensureBridge()
            bridge?.prevTrack()
        }

        private async handleNext(): Promise<void> {
            const bridge = await this.ensureBridge()
            bridge?.nextTrack()
        }

        private async handleRestart(): Promise<void> {
            const bridge = await this.ensureBridge()
            bridge?.restartMusic()
        }

        private async handleVolume(e: Event): Promise<void> {
            const v = parseInt((e.target as HTMLInputElement).value, 10) / 100
            const bridge = await this.ensureBridge()
            bridge?.setMusicVolume(v)
        }

        // ────────── Progress line ──────────

        /** Drive the progress fill via rAF only while the popover is
         * open. Reads track length from the bridge state and current
         * audioContext time. Kept fragile-free — pull rates from the
         * bridge if available, otherwise show empty. */
        private startProgressLoop(): void {
            if (this.progressRaf) return
            const tick = () => {
                this.progressRaf = requestAnimationFrame(tick)
                this.updateProgress()
            }
            this.progressRaf = requestAnimationFrame(tick)
        }

        private stopProgressLoop(): void {
            if (this.progressRaf) {
                cancelAnimationFrame(this.progressRaf)
                this.progressRaf = 0
            }
        }

        private updateProgress(): void {
            const bridge = this.getBridge()
            if (!bridge) {
                this.progressFill.style.transform = 'scaleX(0)'
                return
            }
            const state = bridge.getState()
            if (!state.musicPlaying || state.musicDuckedExternal) {
                this.progressFill.style.transform = 'scaleX(0)'
                return
            }
            // Bridge doesn't currently expose track length/position; show
            // a constant nominal half-fill so the line reads as "active."
            // Hook into real progress when bridge.musicProgress lands.
            this.progressFill.style.transform = 'scaleX(0.6)'
        }
    }

    if (!customElements.get('flatland-music-player')) {
        customElements.define('flatland-music-player', FlatlandMusicPlayer)
    }
</script>

<style>
    flatland-music-player {
        position: relative;
        display: inline-block;
    }

    .music-trigger {
        all: unset;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: calc(var(--radius) - 2px);
        cursor: pointer;
        color: color-mix(in oklab, var(--foreground) 76%, var(--muted-foreground));
        background-color: transparent;
        transition:
            color 160ms cubic-bezier(0.2, 0.8, 0.2, 1),
            background-color 160ms cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .music-trigger:hover,
    .music-trigger[aria-expanded='true'] {
        color: var(--accent-foreground);
        background-color: color-mix(in oklab, var(--accent) 80%, transparent);
    }
    .music-trigger:focus-visible {
        outline: 2px solid color-mix(in oklab, var(--amethyst) 80%, transparent);
        outline-offset: 2px;
    }
    /* Trigger state tints — `playing` warms to amethyst, `ducked` fades. */
    .music-trigger[data-state='playing'] {
        color: color-mix(in oklab, var(--foreground) 60%, var(--amethyst) 40%);
    }
    .music-trigger[data-state='ducked'] {
        color: color-mix(in oklab, var(--muted-foreground) 80%, var(--amethyst) 20%);
    }
    .music-trigger svg {
        flex-shrink: 0;
        pointer-events: none;
    }

    /* Native popover panel — `popover="auto"` puts this in the top
     * layer when open (above everything, no z-index battles).
     *
     * Positioning: the UA stylesheet for `[popover]` defaults to
     * `inset: 0; margin: auto; width/height: fit-content` which centers
     * the popover in the viewport. We override the insets to pin it
     * just below the header on the right side — anchored under the
     * music trigger icon. Static positioning is fine because the
     * trigger button doesn't move laterally across routes.
     *
     *   top:   --header-height + 0.5rem gap below the chrome
     *   right: container padding (--spacing × 6) so the popover's
     *          right edge aligns with the audio cluster's right edge */
    .music-popover {
        top: calc(var(--header-height, 3.5rem) + 0.5rem);
        right: calc(var(--spacing) * 6);
        bottom: auto;
        left: auto;
        margin: 0;
        width: 18rem;
        background: var(--card);
        border: 1px solid color-mix(in oklab, var(--amethyst) 18%, var(--border));
        border-radius: var(--radius);
        box-shadow:
            0 10px 30px -10px rgb(0 0 0 / 0.45),
            0 0 0 1px color-mix(in oklab, var(--amethyst) 6%, transparent);
        padding: 0.75rem 0.75rem 0.625rem;
        flex-direction: column;
        gap: 0.5rem;
        font-family: 'Inter', system-ui, sans-serif;
    }
    .music-popover:popover-open {
        display: flex;
        /* Entry animation — fade + tiny slide. Runs every time the
         * popover transitions to open. Native popover handles the
         * display: none ↔ flex flip; animation handles the visual
         * polish on top. `both` keeps the final keyframe state applied
         * after the animation ends so we don't snap-back to opacity:0. */
        animation: music-popover-in 180ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
    }
    @keyframes music-popover-in {
        from {
            opacity: 0;
            transform: translateY(-4px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    @media (prefers-reduced-motion: reduce) {
        .music-popover:popover-open {
            animation: none;
        }
    }
    /* Mobile: popover spans most of the viewport with the right edge
     * still aligned to the container padding. Width capped just under
     * full viewport so the rounded corners and shadow are visible. */
    @media (max-width: 32rem) {
        .music-popover {
            width: calc(100vw - calc(var(--spacing) * 12));
            max-width: 22rem;
        }
    }

    .music-meta {
        display: flex;
        flex-direction: column;
        gap: 0.125rem;
        min-width: 0;
    }
    .music-title {
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--foreground);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .music-credit {
        font-size: 0.6875rem;
        color: var(--muted-foreground);
        font-family: 'JetBrains Mono', ui-monospace, monospace;
    }

    .music-controls {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.25rem;
    }
    .music-btn {
        all: unset;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.75rem;
        height: 1.75rem;
        border-radius: calc(var(--radius) - 4px);
        cursor: pointer;
        color: var(--muted-foreground);
        transition:
            color 140ms cubic-bezier(0.2, 0.8, 0.2, 1),
            background-color 140ms cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .music-btn:hover:not(:disabled) {
        color: var(--foreground);
        background-color: color-mix(in oklab, var(--amethyst) 12%, transparent);
    }
    .music-btn:focus-visible {
        outline: 2px solid color-mix(in oklab, var(--amethyst) 80%, transparent);
        outline-offset: 1px;
    }
    .music-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }
    .music-toggle {
        width: 2rem;
        height: 2rem;
        color: var(--foreground);
        background-color: color-mix(in oklab, var(--amethyst) 14%, transparent);
    }
    .music-toggle:hover:not(:disabled) {
        background-color: color-mix(in oklab, var(--amethyst) 24%, transparent);
    }
    /* Play vs pause icon driven by data-playing on toggle. */
    .music-toggle .icon-pause,
    .music-toggle[data-playing='true'] .icon-play {
        display: none;
    }
    .music-toggle[data-playing='true'] .icon-pause {
        display: block;
    }

    .music-volume-label {
        display: block;
        padding: 0 0.125rem;
    }
    .music-volume {
        appearance: none;
        -webkit-appearance: none;
        width: 100%;
        height: 4px;
        background: color-mix(in oklab, var(--border) 70%, transparent);
        border-radius: 2px;
        cursor: pointer;
    }
    .music-volume::-webkit-slider-thumb {
        appearance: none;
        -webkit-appearance: none;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--amethyst);
        border: 1px solid color-mix(in oklab, var(--amethyst) 80%, white);
        cursor: pointer;
    }
    .music-volume::-moz-range-thumb {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--amethyst);
        border: 1px solid color-mix(in oklab, var(--amethyst) 80%, white);
        cursor: pointer;
    }
    .music-volume:focus-visible {
        outline: 2px solid color-mix(in oklab, var(--amethyst) 80%, transparent);
        outline-offset: 4px;
    }

