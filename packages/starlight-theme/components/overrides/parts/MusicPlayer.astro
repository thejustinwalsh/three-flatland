         * (1.375rem) = 3.25rem. */
        width: 3.25rem;
    }
    .music-avatar {
        width: 1.625rem;
        height: 1.625rem;
        flex: none;
        color: var(--player-gem);
        image-rendering: pixelated;
        border-radius: 2px;
        background: color-mix(in oklab, var(--player-gem) 8%, var(--background));
        box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--player-gem) 28%, transparent);
        padding: 1px;
        box-sizing: content-box;
    }
    .music-meta {
        display: flex;
        flex-direction: column;
        gap: 0.0625rem;
        min-width: 0;
        flex: 1;
    }
    /* Title — ellipsized at rest, marquee on hover. The inner span
     * (.music-title-text) translates left to reveal the hidden tail,
     * pauses, returns. JS sets `--marquee-end` on `.music-title` based
     * on overflow measured at render time. */
    .music-title {
        display: block;
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--foreground);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.2;
        cursor: default;
    }
    .music-title:hover {
        /* Ellipsis dropped on hover — text just clips at the right edge
         * while the marquee scrolls. */
        text-overflow: clip;
    }
    /* At rest the inner element is INLINE so the outer's
     * text-overflow: ellipsis can draw the "..." indicator. (CSS
     * text-overflow only paints on text overflow, not inline-block
     * overflow.) On hover we promote to inline-block so the translate
     * animation actually shifts the content within the clipping
     * window. The display flip is paired with the text-overflow flip
     * to clip — no double-up of indicators. */
    .music-title-text {
        display: inline;
        white-space: nowrap;
        transform: translateX(0);
        transition: transform 320ms cubic-bezier(0.4, 0, 0.2, 1);
        will-change: transform;
    }
    /* Marquee animation — only attaches while hovering AND when the
     * title is wide enough to overflow (JS gates `--marquee-end`; when
     * 0 the keyframes are flat and nothing visibly happens). Phases:
     *   0–15%   pause at start
     *  15–50%   scroll to end
     *  50–65%   pause at end
     *  65–100%  scroll back to start  */
    .music-title:hover .music-title-text {
        display: inline-block;
        animation: music-title-marquee 4.6s cubic-bezier(0.4, 0, 0.2, 1) 0s infinite;
    }
    /* Animation starts in motion immediately on hover (no leading pause).
     * Phases:
     *   0–45%   scroll to end
     *  45–55%   pause at end (~460ms)
     *  55–100%  scroll back to start (loops without a trailing pause) */
    @keyframes music-title-marquee {
        0%   { transform: translateX(0); }
        45%, 55% { transform: translateX(var(--marquee-end, 0px)); }
        100% { transform: translateX(0); }
    }
    @media (prefers-reduced-motion: reduce) {
        .music-title:hover .music-title-text {
            animation: none;
        }
        .music-title-text {
            transition: none;
        }
    }
    .music-credit {
        font-size: 0.625rem;
        color: var(--muted-foreground);
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        line-height: 1.2;
    }
    .music-credit-link {
        color: inherit;
        text-decoration: none;
        border-bottom: 1px dotted color-mix(in oklab, var(--player-gem) 50%, transparent);
        transition: color 140ms ease, border-color 140ms ease;
    }
    .music-credit-link:hover {
        color: var(--player-gem);
        border-bottom-color: var(--player-gem);
    }

    /* FFT visualizer canvas — full-width, short. Bars rendered in JS
     * with --player-gem fill. CSS only sets the box; pixel paint is
     * canvas. */
    .music-fft {
        display: block;
        width: 100%;
        height: 28px;
        border-radius: 2px;
        background: color-mix(in oklab, var(--background) 88%, var(--player-gem));
        box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--player-gem) 16%, transparent);
    }

    .music-controls {
        display: flex;
        align-items: center;
        gap: 0.25rem;
    }
    /* Holofoil buttons — `u-holo` utility (defined in starlight-theme/
