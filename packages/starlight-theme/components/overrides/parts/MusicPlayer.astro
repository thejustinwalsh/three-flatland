        cursor: pointer;
    }
    .music-volume::-moz-range-thumb {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: var(--player-gem);
        border: 1px solid color-mix(in oklab, var(--player-gem) 70%, white);
        cursor: pointer;
    }
    .music-volume:focus-visible {
        outline: 2px solid color-mix(in oklab, var(--player-gem) 80%, transparent);
        outline-offset: 3px;
    }

    /* Bottom row — thin progress bar fills width; monospace playtime
