---
/**
 * MusicPlayer — header popover for the docs jukebox. Sits LEFT of
 * SoundToggle in the header audio cluster so master mute stays
 * rightmost (per design). Renders a small icon button; click opens
 * a popover with track metadata, prev/play-pause/restart/next, music
 * volume slider, and a thin progress line.
 *
 * Toast behavior: when the active track changes (auto-start, user
 * clicks next/prev, restart, or an external — game — source takes
 * over the music bus), the popover auto-opens for ~3s as a "now
 * playing" toast then auto-closes. If the user interacts with the
 * popover during the open window, it stays open until they explicitly
 * close.
 *
 * External takeover: when `state.musicDuckedExternal` is true, all
 * jukebox transport controls (prev/play-pause/restart/next) disable;
 * volume slider remains active (controls the docs music bus only,
 * which is ducked). The popover title swaps to show the external
 * (game) track. On unduck, controls re-enable.
 */
---

<flatland-music-player>
    {/* Native HTML Popover API — `popover="auto"` gives us light dismiss
        (click outside) + Escape close + top-layer rendering for free.
        The trigger uses `popovertarget` to reference the popover by id;
        the browser also wires implicit aria-expanded on the button so
        we don't have to manage that attribute manually. */}
    <button
        type="button"
        class="music-trigger"
        aria-label="Open music player"
        popovertarget="flatland-music-popover"
        title="Music — click to open player"
    >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 18V5l12-2v13" />
            <circle cx="6" cy="18" r="3" />
            <circle cx="18" cy="16" r="3" />
        </svg>
    </button>

    <div
        id="flatland-music-popover"
        class="music-popover u-light"
        role="dialog"
        aria-label="Music player"
        popover="auto"
        data-gem="amethyst"
    >
        <div class="music-row music-row-top">
            {/* Retro 5×5 mirrored avatar — generated client-side from
                the track id (deterministic, FNV-style hash). Fill color
                tracks the gem of the active track. */}
            <svg class="music-avatar" data-music-avatar viewBox="0 0 5 5" aria-hidden="true" focusable="false"></svg>
            <div class="music-meta">
                {/* Title is a clipped outer element with an inline-block
                    inner span. On hover the inner span ping-pongs via
                    keyframe animation (start → end → start) with pauses
                    at each extreme. JS measures overflow and sets
                    `--marquee-end` so the animation only travels the
                    actual hidden distance. */}
                <span class="music-title">
                    <span class="music-title-text" data-music-title>Loading…</span>
                </span>
                <span class="music-credit" data-music-credit></span>
            </div>
            {/* Right-side action stack: play+next on top, volume slider
                directly underneath. Total width is constrained by the
                buttons; slider matches that width. */}
            <div class="music-actions">
                <div class="music-controls" data-music-controls>
                    <button type="button" class="music-btn u-holo" data-music-toggle aria-label="Play" title="Play">
                        <svg class="icon-play" xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                            <polygon points="5 3 19 12 5 21 5 3" />
                        </svg>
                        <svg class="icon-pause" xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" stroke="none">
                            <rect x="6" y="4" width="4" height="16" />
                            <rect x="14" y="4" width="4" height="16" />
                        </svg>
                    </button>
                    <button type="button" class="music-btn u-holo" data-music-next aria-label="Next track" title="Next track">
                        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polygon points="5 4 15 12 5 20 5 4" />
                            <line x1="19" y1="5" x2="19" y2="19" />
                        </svg>
                    </button>
                </div>
                <label class="music-volume-label">
                    <span class="sr-only">Music volume</span>
                    <input
                        type="range"
                        class="music-volume"
                        data-music-volume
                        min="0"
                        max="100"
                        value="30"
                        aria-label="Music volume"
                    />
                </label>
            </div>
        </div>

        {/* FFT visualizer — canvas spans full width. Bars are painted in
            JS with gem-blended colors across the spectrum. */}
        <canvas class="music-fft" data-music-fft width="256" height="32" aria-hidden="true"></canvas>

        {/* Progress + time row */}
        <div class="music-row music-row-bottom">
            <div class="music-progress" aria-hidden="true">
                <span class="music-progress-fill" data-music-progress></span>
            </div>
            <span class="music-time" data-music-time>0:00</span>
        </div>
    </div>
</flatland-music-player>

<script>
    type SoundsModule = typeof import('../../../../../docs/src/scripts/sounds')

    type Track = {
        id: string
        title: string
        credit?: string
        /** Optional URL for the credit — when present, the credit text
         * renders as a link. Defaults to the zzfx-studio site when
         * credit === "zzfx-studio" and the field is absent. */
        creditUrl?: string
        gem?: string
        bpm: number
    }

    const ZZFX_STUDIO_URL = 'https://thejustinwalsh.github.io/zzfx-studio/'
    const VALID_GEMS = new Set([
        'gold', 'ruby', 'emerald', 'diamond', 'amethyst', 'pink', 'salmon', 'turquoize'
    ])

    type AudioState = {
        masterLevel: 0 | 1 | 2 | 3
        musicVolume: number
        musicPlaying: boolean
        musicTrackIndex: number
        musicUserStopped: boolean
        musicDuckedExternal: boolean
        currentTrack: Track | null
        library: { tracks: Track[] } | null
    }

    const TOAST_MS = 3000

    class FlatlandMusicPlayer extends HTMLElement {
        private cleanup?: AbortController
        private toastTimer: number | null = null
        private soundsPromise?: Promise<SoundsModule>
        private lastTrackId: string | null = null
        private userInteractedDuringToast = false

        private trigger!: HTMLButtonElement
        private popoverEl!: HTMLElement
        private titleEl!: HTMLElement
        private creditEl!: HTMLElement
        private avatarEl!: SVGSVGElement
        private toggleBtn!: HTMLButtonElement
        private nextBtn!: HTMLButtonElement
        private volumeInput!: HTMLInputElement
        private fftCanvas!: HTMLCanvasElement
        private fftCtx2d: CanvasRenderingContext2D | null = null
        private controls!: HTMLElement
        private progressEl!: HTMLElement
        private timeEl!: HTMLElement
        /** rAF id for the FFT/progress loop. Only running while the
         * popover is open (started/stopped in the toggle handler). */
        private fftRaf = 0
        private analyserData?: Uint8Array
        /** Cached gem RGB triplets for the spectrum blend. Re-resolved
         * when the popover opens (so a light/dark theme flip picks up
         * the new computed token values). */
        private spectrumColors: { r: number; g: number; b: number }[] = []

        constructor() {
            super()
            const ctrl = new AbortController()
            this.cleanup = ctrl
            const { signal } = ctrl

            this.trigger = this.querySelector<HTMLButtonElement>('.music-trigger')!
            this.popoverEl = this.querySelector<HTMLElement>('.music-popover')!
            this.titleEl = this.querySelector<HTMLElement>('[data-music-title]')!
            this.creditEl = this.querySelector<HTMLElement>('[data-music-credit]')!
            this.avatarEl = this.querySelector<SVGSVGElement>('[data-music-avatar]')!
            this.toggleBtn = this.querySelector<HTMLButtonElement>('[data-music-toggle]')!
            this.nextBtn = this.querySelector<HTMLButtonElement>('[data-music-next]')!
            this.volumeInput = this.querySelector<HTMLInputElement>('[data-music-volume]')!
            this.fftCanvas = this.querySelector<HTMLCanvasElement>('[data-music-fft]')!
            this.fftCtx2d = this.fftCanvas.getContext('2d')
            this.controls = this.querySelector<HTMLElement>('[data-music-controls]')!
            this.progressEl = this.querySelector<HTMLElement>('[data-music-progress]')!
            this.timeEl = this.querySelector<HTMLElement>('[data-music-time]')!

            // Transport handlers — the popover open/close itself is owned
            // by the native `popover` attribute on the panel + the
            // `popovertarget` attribute on the trigger button. The browser
            // handles light dismiss + Escape + top-layer rendering.
            this.toggleBtn.addEventListener('click', () => this.handleToggle(), { signal })
            this.nextBtn.addEventListener('click', () => this.handleNext(), { signal })
            this.volumeInput.addEventListener('input', (e) => this.handleVolume(e), { signal })

            // Anchor the popover so its LEFT edge aligns with the search
            // button's left edge, and its RIGHT edge stays at the audio
            // cluster's right edge (same spot as the SoundToggle icon).
            // Net effect: popover spans from search-left to audio-cluster-
            // right — a hair wider than search, visually a clean rectangle
            // anchored to the same vertical column as the search bar.
            //
            // Fallback when search isn't rendered: position the left edge
            // where search would be (uses its standard 16rem width
            // at desktop / 12rem at tablet, offset from the audio-cluster
            // right edge).
            this.popoverEl.addEventListener(
                'beforetoggle',
                (e: Event) => {
                    const ev = e as { newState?: string } & Event
                    if (ev.newState !== 'open') return
                    const search = document.querySelector<HTMLElement>(
                        'site-search button[data-open-modal], button[data-open-modal]'
                    )
                    const cluster = this.closest('.audio-cluster') as HTMLElement | null
                    // Right edge: align to the audio cluster's right edge
                    // (its rightmost child = SoundToggle icon).
                    const rightOffset = cluster
                        ? window.innerWidth - cluster.getBoundingClientRect().right
                        : 24
                    if (search) {
                        const r = search.getBoundingClientRect()
                        this.popoverEl.style.left = `${r.left}px`
                        this.popoverEl.style.right = `${Math.max(8, rightOffset)}px`
                        this.popoverEl.style.width = 'auto'
                    } else {
                        // No search — pretend it had its standard width and
                        // align left edge accordingly.
                        const searchW = window.matchMedia('(min-width: 64rem)').matches ? 256 : 192
                        const rightEdge = window.innerWidth - rightOffset
                        this.popoverEl.style.left = `${rightEdge - searchW}px`
                        this.popoverEl.style.right = `${Math.max(8, rightOffset)}px`
                        this.popoverEl.style.width = 'auto'
                    }
                },
                { signal }
            )

            // Toast logic + progress loop hook into the popover's state
            // changes. `toggle` fires after the state has changed.
            this.popoverEl.addEventListener(
                'toggle',
                (e: Event) => {
                    const ev = e as { newState?: string } & Event
                    if (ev.newState === 'open') {
                        this.startProgressLoop()
                    } else {
                        this.stopProgressLoop()
                        if (this.toastTimer !== null) {
                            clearTimeout(this.toastTimer)
                            this.toastTimer = null
                        }
                    }
                },
                { signal }
            )

            // Track user interaction with the popover so a toast doesn't
            // auto-close when the user clicks inside it.
            this.popoverEl.addEventListener(
                'click',
                () => {
                    this.userInteractedDuringToast = true
                    if (this.toastTimer !== null) {
                        clearTimeout(this.toastTimer)
                        this.toastTimer = null
                    }
                },
                { signal }
            )

            // Eager-but-lazy: pull the audio module on idle so first user
            // interaction is hot. The bridge loads tracks.json + zzfxm
            // here too.
            const onIdle =
                window.requestIdleCallback ??
                ((cb: () => void) => window.setTimeout(cb, 1))
            onIdle(() => {
                if (signal.aborted) return
                this.loadSounds()
            })

            // Auto-close on scroll. Re-opening at any scroll position
            // re-anchors the popover at its CSS `top: --header-height +
            // gap` (position: fixed via popover UA), so it always
            // floats right under the header on reopen. Passive listener
            // keeps scrolling smooth; the `:popover-open` check is O(1).
            window.addEventListener(
                'scroll',
                () => {
                    if (
                        (this.popoverEl as HTMLElement & {
                            matches: (s: string) => boolean
                        }).matches(':popover-open')
                    ) {
                        try {
                            ;(this.popoverEl as HTMLElement & {
                                hidePopover: () => void
                            }).hidePopover()
                        } catch {}
                    }
                },
                { passive: true, signal }
            )

            // Manual pointer-tracking for the rim-glint. motion.ts'
            // global registry doesn't pick up the popover because it's
            // a native top-layer element (display: none until opened,
            // and its IntersectionObserver semantics differ from
            // regular flow elements). Run a scoped pointermove listener
            // here so the cursor-driven `--mx`/`--my` highlight ON THE
            // popover surface tracks the actual mouse position, like
            // every other .u-light card/button in the design system.
            this.popoverEl.addEventListener(
                'pointermove',
                (e: PointerEvent) => {
                    const r = this.popoverEl.getBoundingClientRect()
                    const mx = ((e.clientX - r.left) / r.width) * 100
                    const my = ((e.clientY - r.top) / r.height) * 100
                    this.popoverEl.style.setProperty('--mx', `${mx.toFixed(2)}%`)
                    this.popoverEl.style.setProperty('--my', `${my.toFixed(2)}%`)
                    this.popoverEl.style.setProperty('--mouse-active', '1')
                },
                { passive: true, signal }
            )
            this.popoverEl.addEventListener(
                'pointerleave',
                () => {
                    this.popoverEl.style.setProperty('--mouse-active', '0')
                },
                { signal }
            )
        }

        disconnectedCallback() {
            this.cleanup?.abort()
            this.cleanup = undefined
            if (this.toastTimer !== null) clearTimeout(this.toastTimer)
            if (this.fftRaf) cancelAnimationFrame(this.fftRaf)
        }

        private loadSounds(): Promise<SoundsModule> {
            if (!this.soundsPromise) {
                this.soundsPromise = import(
                    /* @vite-ignore */
                    '../../../../../docs/src/scripts/sounds'
                ) as Promise<SoundsModule>
                this.soundsPromise.then(async (sounds) => {
                    // Force the bridge to materialize so we can subscribe
                    // to its state. initAudio resolves once the bridge is
                    // constructed (it needs a user gesture to fully unlock,
                    // but the singleton + library are ready immediately).
                    await sounds.initAudio()
                    const bridge = (window as unknown as { __threeFlatlandAudio?: { subscribe: (cb: (s: AudioState) => void) => () => void } })
                        .__threeFlatlandAudio
                    if (!bridge) return
                    // Bridge exposes subscribe(cb): unsubscribe; cb receives state.
                    // Don't destructure — destructured methods lose their
                    // `this` binding and `subscribe` would call into a
                    // detached function, breaking `this.listeners.add()`.
                    bridge.subscribe((state) => this.applyState(state))
                })
            }
            return this.soundsPromise
        }

        private getBridge(): {
            playTrack: (t: Track, opts?: { fromUserGesture?: boolean }) => void
            pauseMusic: () => void
            resumeMusic: () => void
            nextTrack: () => void
            setMusicVolume: (v: number) => void
            getState: () => AudioState
            musicAnalyser?: AnalyserNode
        } | undefined {
            return (window as unknown as { __threeFlatlandAudio?: unknown })
                .__threeFlatlandAudio as ReturnType<FlatlandMusicPlayer['getBridge']>
        }

        private async ensureBridge() {
            await this.loadSounds()
            return this.getBridge()
        }

        // ────────── Popover open/close ──────────
        //
        // Native popover API handles user-driven open/close via the
        // `popovertarget` attribute on the trigger button + the
        // `popover="auto"` attribute on the panel. Light dismiss
        // (click outside) and Escape close are automatic.
        //
        // This component only programmatically opens the popover as a
        // *toast* on track change — see `openAsToast`. Closing the toast
        // is also explicit: a timer fires `hidePopover()` after TOAST_MS
        // unless the user interacted with the panel during the window.

        /** Open as a transient toast on track change. Auto-closes after
         * TOAST_MS unless the user clicks inside the popover during the
         * window (in which case it stays open until they dismiss it via
         * Escape or outside click — both browser-handled). */
        private openAsToast(): void {
            // Already open (user clicked through to it) — leave alone.
            const popoverEl = this.popoverEl as HTMLElement & { matches: (s: string) => boolean }
            if (popoverEl.matches(':popover-open')) return
            this.userInteractedDuringToast = false
            try {
                ;(this.popoverEl as HTMLElement & { showPopover: () => void }).showPopover()
            } catch {
                // showPopover throws if browser doesn't support the API or
                // the popover is already open from a stale state — silent
                // fallback is fine.
                return
            }
            this.toastTimer = window.setTimeout(() => {
                this.toastTimer = null
                if (this.userInteractedDuringToast) return
                try {
                    ;(this.popoverEl as HTMLElement & { hidePopover: () => void }).hidePopover()
                } catch {}
            }, TOAST_MS)
        }

        // ────────── State sync ──────────

        private applyState(state: AudioState): void {
            const track = state.currentTrack
            const title = track?.title ?? 'No track loaded'
            this.titleEl.textContent = title
            // Measure overflow so the marquee animation only travels the
            // hidden distance. Run after the text mutation has settled.
            // Deferred via rAF so layout has refreshed the inline-block
            // child's scrollWidth before we read it.
            requestAnimationFrame(() => {
                const outer = this.titleEl.parentElement as HTMLElement | null
                if (!outer) return
                const overflow = this.titleEl.scrollWidth - outer.clientWidth
                outer.style.setProperty('--marquee-end', overflow > 0 ? `${-overflow - 4}px` : '0px')
            })

            // Credit renders as a link when a URL is known. Defaults to
            // the ZzFX Studio site when credit === "zzfx-studio" and no
            // explicit creditUrl was set during ingestion.
            const credit = track?.credit ?? ''
            const creditUrl =
                track?.creditUrl ??
                (credit === 'zzfx-studio' ? ZZFX_STUDIO_URL : undefined)
            this.creditEl.textContent = ''
            if (credit) {
                if (creditUrl) {
                    const a = document.createElement('a')
                    a.href = creditUrl
                    a.textContent = credit
                    a.target = '_blank'
                    a.rel = 'noopener noreferrer'
                    a.className = 'music-credit-link'
                    this.creditEl.appendChild(a)
                } else {
                    this.creditEl.textContent = credit
                }
            }

            // Bind the current track's gem to a CSS custom property so
            // the popover surface (rim, FFT bars, holofoil) tints to
            // match. Falls back to amethyst when no gem is declared.
            const gem = track?.gem && VALID_GEMS.has(track.gem) ? track.gem : 'amethyst'
            this.popoverEl.style.setProperty('--player-gem', `var(--${gem})`)
            this.popoverEl.style.setProperty('--player-gem-low', `var(--${gem}-low, var(--${gem}))`)
            this.popoverEl.dataset.gem = gem

            // Generate (and cache by track id) the retro 5×5 avatar. The
            // grid pattern is deterministic from the track id via a
            // FNV-style hash — same track always produces the same icon.
            if (track && track.id !== this.lastAvatarTrackId) {
                this.lastAvatarTrackId = track.id
                this.renderAvatar(track.id, gem)
            }

            // Toggle button reflects play/pause state.
            const playing = state.musicPlaying
            this.toggleBtn.setAttribute('aria-label', playing ? 'Pause' : 'Play')
            this.toggleBtn.setAttribute('title', playing ? 'Pause' : 'Play')
            this.toggleBtn.dataset.playing = playing ? 'true' : 'false'

            // External takeover disables transport controls.
            const ducked = state.musicDuckedExternal
            this.controls.dataset.ducked = ducked ? 'true' : 'false'
            this.nextBtn.disabled = ducked || !state.library?.tracks?.length
            this.toggleBtn.disabled = ducked || !track

            // Volume slider mirrors music bus (0..1 → 0..100).
            const vol100 = Math.round(state.musicVolume * 100)
            if (parseInt(this.volumeInput.value, 10) !== vol100) {
                this.volumeInput.value = String(vol100)
            }

            // Indicate external state on the trigger button so the user can
            // see the music dipped without opening the popover.
            this.trigger.dataset.state = ducked ? 'ducked' : playing ? 'playing' : 'idle'

            // Track changed → open as toast (unless popover already open).
            const trackId = track?.id ?? null
            if (trackId !== this.lastTrackId && trackId !== null) {
                this.lastTrackId = trackId
                this.openAsToast()
            }
        }

        // ────────── Avatar generation ──────────

        private lastAvatarTrackId: string | null = null

        /** FNV-1a hash → array of unsigned 32-bit ints. Deterministic per
         * input string; used to seed the avatar's pixel grid bits. */
        private hashString(str: string): number[] {
            const out: number[] = []
            let h = 0x811c9dc5 >>> 0
            for (let i = 0; i < str.length; i++) {
                h ^= str.charCodeAt(i)
                h = Math.imul(h, 0x01000193) >>> 0
            }
            for (let i = 0; i < 20; i++) {
                h ^= i + 1
                h = Math.imul(h, 0x01000193) >>> 0
                out.push(h >>> 0)
            }
            return out
        }

        /** Generate a 5×5 mirrored pixel grid + paint into the avatar
         * SVG. The left 3 columns are derived from the hash, columns 4-5
         * mirror columns 1-0 for horizontal symmetry (the retro pattern
         * ZzFX Studio uses on track cards). Fill color tracks --player-gem. */
        private renderAvatar(seed: string, _gem: string): void {
            const tiles = 5
            const mid = Math.ceil(tiles / 2)
            const hash = this.hashString(seed || 'flatland')
            const pixels: boolean[][] = []
            let bitIdx = 1
            let filled = 0
            const total = tiles * mid
            for (let row = 0; row < tiles; row++) {
                pixels[row] = []
                for (let col = 0; col < mid; col++) {
                    const val = hash[bitIdx % hash.length] ?? 0
                    const bit = ((val >>> ((bitIdx * 3) % 28)) & 1) === 1
                    pixels[row][col] = bit
                    if (bit) filled++
                    bitIdx++
                }
            }
            // Coerce density into a comfortable middle band — too sparse
            // or too dense reads as random pixels rather than a sigil.
            const ratio = filled / total
            if (ratio < 0.3) {
                outer: for (let row = 0; row < tiles; row++) {
                    for (let col = 0; col < mid; col++) {
                        if (!pixels[row]![col]) {
                            pixels[row]![col] = true
                            filled++
                            if (filled / total >= 0.3) break outer
                        }
                    }
                }
            } else if (ratio > 0.85) {
                outer: for (let row = tiles - 1; row >= 0; row--) {
                    for (let col = mid - 1; col >= 0; col--) {
                        if (pixels[row]![col]) {
                            pixels[row]![col] = false
                            filled--
                            if (filled / total <= 0.85) break outer
                        }
                    }
                }
            }
            // Render: 5×5 SVG rects, mirrored.
            const ns = 'http://www.w3.org/2000/svg'
            while (this.avatarEl.firstChild) this.avatarEl.removeChild(this.avatarEl.firstChild)
            for (let row = 0; row < tiles; row++) {
                for (let col = 0; col < tiles; col++) {
                    const srcCol = col < mid ? col : tiles - 1 - col
                    if (!pixels[row]![srcCol]) continue
                    const r = document.createElementNS(ns, 'rect')
                    r.setAttribute('x', String(col))
                    r.setAttribute('y', String(row))
                    r.setAttribute('width', '1')
                    r.setAttribute('height', '1')
                    r.setAttribute('fill', 'currentColor')
                    this.avatarEl.appendChild(r)
                }
            }
        }

        // ────────── Transport handlers ──────────

        private async handleToggle(): Promise<void> {
            const sounds = await this.loadSounds()
            const bridge = await this.ensureBridge()
            if (!bridge) return
            const state = bridge.getState()
            if (state.musicDuckedExternal) return
            if (state.musicPlaying) {
                bridge.pauseMusic()
                return
            }
            // Authority model: SoundToggle is the global audio gate.
            //   - level > 0           → play normally
            //   - level = 0, never set → auto-unlock to low (icon updates
            //                            reactively via bridge subscription)
            //   - level = 0, explicit  → respect user's mute, don't play
            // Explicit mute is detected by the presence of the localStorage
            // key (any value set, even "0", means the user has interacted).
            if (state.masterLevel === 0) {
                const explicit = localStorage.getItem('flatland-sound-volume') !== null
                if (explicit) return // muted on purpose; honor the choice
                // Default off → elevate to low. setVolumeLevel writes
                // storage + calls bridge.setMasterLevel which fires the
                // first-unmute autostart path (music begins automatically
                // because we've now transitioned from 0 → 1).
                sounds.setVolumeLevel(1)
                return
            }
            bridge.resumeMusic()
        }

        private async handleNext(): Promise<void> {
            const bridge = await this.ensureBridge()
            bridge?.nextTrack()
        }

        private async handleVolume(e: Event): Promise<void> {
            const v = parseInt((e.target as HTMLInputElement).value, 10) / 100
            const bridge = await this.ensureBridge()
            bridge?.setMusicVolume(v)
        }

        // ────────── FFT visualizer ──────────

        /** rAF-driven loop reading byte-frequency data off the bridge's
         * music analyser. Runs ONLY while the popover is open (started
         * by the toggle/show event, stopped on close) so we don't burn
         * CPU on an invisible canvas. */
        private startProgressLoop(): void {
            if (this.fftRaf) return
            this.refreshSpectrumColors()
            const tick = () => {
                this.fftRaf = requestAnimationFrame(tick)
                this.drawFft()
                this.updateProgress()
            }
            this.fftRaf = requestAnimationFrame(tick)
        }

        private stopProgressLoop(): void {
            if (this.fftRaf) {
                cancelAnimationFrame(this.fftRaf)
                this.fftRaf = 0
            }
            // Leave one final flat-line frame so a paused popover doesn't
            // freeze on the last energetic frame.
            this.drawFlat()
        }

        /** Parse a CSS color string returned by `getComputedStyle` into
         * an RGB triplet. Handles `rgb(r g b)`, `rgb(r, g, b)`, `oklch(...)`
         * (browsers compute oklch to a final rgb-space at use sites in
         * most modern engines; falls back to muted gray on parse fail). */
        private parseRgb(css: string): { r: number; g: number; b: number } {
            const trimmed = css.trim()
            const rgbMatch = trimmed.match(/(?:rgb|rgba)\s*\(\s*(\d+)[\s,]+(\d+)[\s,]+(\d+)/i)
            if (rgbMatch) {
                return { r: +rgbMatch[1]!, g: +rgbMatch[2]!, b: +rgbMatch[3]! }
            }
            // Fallback: probe via a hidden element to get a resolved rgb()
            // form. Only run when the simple regex misses (rare).
            try {
                const probe = document.createElement('div')
                probe.style.color = trimmed
                probe.style.display = 'none'
                document.body.appendChild(probe)
                const resolved = getComputedStyle(probe).color
                document.body.removeChild(probe)
                const m = resolved.match(/(\d+)[\s,]+(\d+)[\s,]+(\d+)/)
                if (m) return { r: +m[1]!, g: +m[2]!, b: +m[3]! }
            } catch {}
            return { r: 180, g: 180, b: 180 }
        }

        /** Resolve the gem palette to live RGB triplets for the FFT
         * blend. Order goes lows→highs across the spectrum: ruby → salmon
         * → gold → emerald → diamond → amethyst. Like a heat map but
         * across our gem palette. Re-resolves each time the popover
         * opens so theme/token shifts (light↔dark) take effect. */
        private refreshSpectrumColors(): void {
            const cs = getComputedStyle(this.popoverEl)
            const names = ['ruby', 'salmon', 'gold', 'emerald', 'diamond', 'amethyst']
            this.spectrumColors = names.map((n) =>
                this.parseRgb(cs.getPropertyValue(`--${n}`).trim() || '#888')
            )
        }

        private drawFft(): void {
            const ctx = this.fftCtx2d
            if (!ctx) return
            const bridge = this.getBridge()
            if (!bridge?.musicAnalyser) {
                this.drawFlat()
                return
            }
            const analyser = bridge.musicAnalyser
            if (!this.analyserData || this.analyserData.length !== analyser.frequencyBinCount) {
                this.analyserData = new Uint8Array(analyser.frequencyBinCount)
            }
            analyser.getByteFrequencyData(this.analyserData)
            const w = this.fftCanvas.width
            const h = this.fftCanvas.height
            ctx.clearRect(0, 0, w, h)
            const bins = this.analyserData.length
            const barCount = Math.min(28, bins)
            const binsPerBar = Math.floor(bins / barCount)
            const gap = 1
            const barW = (w - gap * (barCount - 1)) / barCount
            // Single-gem fill — the previous multi-gem spectrum blend
            // didn't read clearly at this size. Each bar uses the active
            // track's gem (--player-gem). Quiet bars get lower alpha so
            // they fade quietly rather than reading as a uniform strip.
            const gem = getComputedStyle(this.popoverEl).getPropertyValue('--player-gem').trim() || '#bbb'
            const rgb = this.parseRgb(gem)
            for (let i = 0; i < barCount; i++) {
                let sum = 0
                for (let j = 0; j < binsPerBar; j++) {
                    sum += this.analyserData[i * binsPerBar + j] ?? 0
                }
                const avg = sum / binsPerBar / 255
                const barH = Math.max(1, Math.round(avg * h))
                const x = i * (barW + gap)
                const y = h - barH
                const alpha = 0.55 + 0.45 * avg
                ctx.fillStyle = `rgba(${rgb.r},${rgb.g},${rgb.b},${alpha.toFixed(3)})`
                ctx.fillRect(x, y, barW, barH)
            }
        }

        /** Draw a 1px gem-tinted baseline so the canvas region stays
         * visually anchored even when the music is paused or muted. */
        private drawFlat(): void {
            const ctx = this.fftCtx2d
            if (!ctx) return
            const w = this.fftCanvas.width
            const h = this.fftCanvas.height
            ctx.clearRect(0, 0, w, h)
            const gem = getComputedStyle(this.popoverEl).getPropertyValue('--player-gem').trim() || '#bbb'
            ctx.fillStyle = gem
            ctx.globalAlpha = 0.35
            ctx.fillRect(0, h - 1, w, 1)
            ctx.globalAlpha = 1
        }

        private updateProgress(): void {
            const bridge = this.getBridge() as
                | (ReturnType<FlatlandMusicPlayer['getBridge']> & {
                      getMusicProgress?: () => { position: number; duration: number }
                  })
                | undefined
            if (!bridge || !bridge.getMusicProgress) return
            const { position, duration } = bridge.getMusicProgress()
            const pct = duration > 0 ? Math.min(1, position / duration) : 0
            this.progressEl.style.transform = `scaleX(${pct.toFixed(4)})`
            const m = Math.floor(position / 60)
            const s = Math.floor(position % 60)
            this.timeEl.textContent = `${m}:${String(s).padStart(2, '0')}`
        }
    }

    if (!customElements.get('flatland-music-player')) {
        customElements.define('flatland-music-player', FlatlandMusicPlayer)
    }
</script>

<style>
    flatland-music-player {
        position: relative;
        display: inline-block;
    }

    .music-trigger {
        all: unset;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: calc(var(--radius) - 2px);
        cursor: pointer;
        color: color-mix(in oklab, var(--foreground) 76%, var(--muted-foreground));
        background-color: transparent;
        transition:
            color 160ms cubic-bezier(0.2, 0.8, 0.2, 1),
            background-color 160ms cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .music-trigger:hover,
    .music-trigger[aria-expanded='true'] {
        color: var(--accent-foreground);
        background-color: color-mix(in oklab, var(--accent) 80%, transparent);
    }
    .music-trigger:focus-visible {
        outline: 2px solid color-mix(in oklab, var(--amethyst) 80%, transparent);
        outline-offset: 2px;
    }
    /* Trigger state tints — `playing` warms to amethyst, `ducked` fades. */
    .music-trigger[data-state='playing'] {
        color: color-mix(in oklab, var(--foreground) 60%, var(--amethyst) 40%);
    }
    .music-trigger[data-state='ducked'] {
        color: color-mix(in oklab, var(--muted-foreground) 80%, var(--amethyst) 20%);
    }
    .music-trigger svg {
        flex-shrink: 0;
        pointer-events: none;
    }

    /* Native popover panel — `popover="auto"` puts this in the top
     * layer when open (above everything, no z-index battles).
     *
     * Positioning: the UA stylesheet for `[popover]` defaults to
     * `inset: 0; margin: auto; width/height: fit-content` which centers
     * the popover in the viewport. We override the insets to pin it
     * just below the header on the right side — anchored under the
     * music trigger icon. Static positioning is fine because the
     * trigger button doesn't move laterally across routes.
     *
     *   top:   --header-height + 0.5rem gap below the chrome
     *   right: container padding (--spacing × 6) so the popover's
     *          right edge aligns with the audio cluster's right edge */
    /* Popover surface — mirrors `.sl-link-button.secondary`'s subtle
     * grayish/black gradient + gem-tinted rim, scaled up to a panel.
     * Background is built from --player-gem so when the track changes,
     * the entire surface re-tints. Rim is a thin gem-colored 1px inner
     * border (via box-shadow inset) — same affordance as the View on
     * GitHub button, just rolled up to popover proportions. */
    .music-popover {
        --player-gem: var(--amethyst);
        --player-gem-low: var(--amethyst-low, var(--amethyst));
        /* The `.u-light` utility on this element sets `position:
         * relative` which overrides the popover UA's `position: fixed`,
         * so without pinning here the popover would scroll with the
         * document. Force fixed so the popover always anchors to the
         * viewport (right under the sticky header) regardless of scroll. */
        position: fixed;
        top: calc(var(--header-height, 3.5rem) + 0.5rem);
        right: calc(var(--spacing) * 6);
        bottom: auto;
        left: auto;
        margin: 0;
        width: 15rem;
        background:
            linear-gradient(
                135deg,
                color-mix(in oklab, var(--player-gem) 8%, var(--background)) 0%,
                color-mix(in oklab, var(--background) 94%, var(--player-gem)) 100%
            );
        border: 0;
        border-radius: var(--radius);
        box-shadow:
            inset 0 0 0 1px color-mix(in oklab, var(--player-gem) 32%, transparent),
            0 10px 30px -10px rgb(0 0 0 / 0.5),
            0 0 0 1px color-mix(in oklab, var(--player-gem) 5%, transparent);
        padding: 0.625rem 0.75rem 0.5rem;
        flex-direction: column;
        gap: 0.5rem;
        font-family: 'Inter', system-ui, sans-serif;
        isolation: isolate;
    }
    /* Bidirectional entry/exit transition. transition-behavior:
     * allow-discrete lets `display` and `overlay` animate alongside
     * opacity + transform, so the popover can fade IN from display:
     * none and fade OUT before the browser flips back to display:
     * none. transform-origin: top right anchors the scale to the
     * trigger corner — popover eases UP toward the button on close. */
    .music-popover {
        opacity: 0;
        transform: translateY(-6px) scale(0.96);
        transform-origin: top right;
        transition:
            opacity 200ms cubic-bezier(0.2, 0.8, 0.2, 1),
            transform 220ms cubic-bezier(0.34, 1.2, 0.46, 1),
            display 220ms allow-discrete,
            overlay 220ms allow-discrete;
    }
    .music-popover:popover-open {
        display: flex;
        opacity: 1;
        transform: translateY(0) scale(1);
    }
    /* @starting-style provides the entry keyframe — without it, the
     * transition would have no "from" state to interpolate from when
     * the element flips display:none → display:flex. The browser starts
     * at these values on the very first frame after :popover-open
     * matches, then transitions to the regular :popover-open target. */
    @starting-style {
        .music-popover:popover-open {
            opacity: 0;
            transform: translateY(-6px) scale(0.96);
        }
    }
    @media (prefers-reduced-motion: reduce) {
