            transition: none;
            transform: none;
        }
        .music-popover:popover-open {
            transform: none;
        }
    }
    /* Mobile: popover spans most of the viewport with the right edge
     * still aligned to the container padding. Width capped just under
     * full viewport so the rounded corners and shadow are visible. */
    @media (max-width: 32rem) {
        .music-popover {
            width: calc(100vw - calc(var(--spacing) * 12));
            max-width: 22rem;
        }
    }

    /* Top row — avatar + title/credit + right-side action stack.
     *   .music-row-top: flex row; meta fills, actions hug right
     *   .music-actions: column; controls on top, volume below */
    .music-row-top {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        min-width: 0;
    }
    .music-actions {
        display: flex;
        flex-direction: column;
        align-items: stretch;
        gap: 0.3125rem;
        flex: none;
        /* Explicit width — without it the column resolves to the
