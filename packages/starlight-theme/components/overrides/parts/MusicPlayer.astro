     * inherits the popover's --player-gem so the foil tracks the song. */
    .music-btn {
        all: unset;
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.375rem;
        height: 1.375rem;
        border-radius: calc(var(--radius) - 5px);
        cursor: pointer;
        color: var(--foreground);
        background: color-mix(in oklab, var(--card) 80%, var(--background));
        box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--foreground) 18%, transparent);
        transition:
            background-color 140ms cubic-bezier(0.2, 0.8, 0.2, 1),
            box-shadow 140ms cubic-bezier(0.2, 0.8, 0.2, 1);
        flex: none;
        isolation: isolate;
        /* Neutralize the u-holo foil — same effect stack (perspective
         * tilt, scene-light drift, mouse-driven highlight, sparkle
         * conic flecks) but with the gem palette swapped for grayscale
         * tokens. Reads as a "polished metal" button rather than a
         * gem-tinted holofoil. */
        --gem-base: color-mix(in oklab, var(--foreground) 25%, var(--background));
        --gem-spec: color-mix(in oklab, var(--foreground) 65%, var(--background));
        --gem-low: var(--card);
    }
    .music-btn svg {
        position: relative;
        z-index: 1;
        pointer-events: none;
    }
    .music-btn:hover:not(:disabled) {
        background: color-mix(in oklab, var(--card) 65%, var(--background));
        box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--foreground) 32%, transparent);
    }
    .music-btn:focus-visible {
        outline: 2px solid color-mix(in oklab, var(--foreground) 50%, transparent);
        outline-offset: 2px;
    }
    .music-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }
    /* Play vs pause icon driven by data-playing on toggle. */
    .music-btn .icon-pause,
    .music-btn[data-playing='true'] .icon-play {
        display: none;
    }
    .music-btn[data-playing='true'] .icon-pause {
        display: block;
    }
    [data-music-toggle] {
        width: 1.625rem;
        height: 1.625rem;
    }

    /* Volume slider — narrow strip directly under the play/next button
     * pair. Width matches the buttons; track is a thin 2px gem-tinted
