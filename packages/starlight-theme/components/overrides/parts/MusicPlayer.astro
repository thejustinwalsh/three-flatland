    .music-volume-label {
        display: flex;
        align-items: center;
        width: 100%;
    }
    .music-volume {
        appearance: none;
        -webkit-appearance: none;
        width: 100%;
        height: 2px;
        background: linear-gradient(
            90deg,
            color-mix(in oklab, var(--player-gem) 60%, transparent) 0%,
