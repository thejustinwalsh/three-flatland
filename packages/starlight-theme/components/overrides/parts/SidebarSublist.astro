---
import type { StarlightRouteData } from '@astrojs/starlight/route-data';

interface Props {
    sublist: StarlightRouteData['sidebar'];
    nested?: boolean;
}

const { sublist } = Astro.props;
---

{
    sublist.map((entry) =>
        entry.type === 'link' ? (
            <a
                href={entry.href}
                aria-current={entry.isCurrent && 'page'}
                class:list={['entry-link', entry.attrs.class]}
                {...entry.attrs}
            >
                <span class="entry-link-inner">
                    {/*
                     * Sidebar icon resolution composes `starlight-plugin-icons`'s
                     * convention: when `Icons()` wraps Starlight, it transforms
                     * `icon: 'i-collection:name'` into `attrs['data-icon']`.
                     * Render that as a span class so UnoCSS materializes the icon.
                     */}
                    {entry.attrs['data-icon'] && (
                        <span class:list={[entry.attrs['data-icon'], 'entry-icon']} aria-hidden="true" />
                    )}
                    <span class="entry-label">{entry.label}</span>
                    {entry.badge && <span class="entry-badge">{entry.badge.text}</span>}
                </span>
            </a>
        ) : (
            <div class="container-sidebar-entry">
                <h4 class="entry-title">{entry.label}</h4>
                <div class="container-group-link">
                    <Astro.self sublist={entry.entries} nested />
                </div>
            </div>
        )
    )
}

<style>
    .container-sidebar-entry {
        gap: 0.25rem;
        flex-direction: column;
        display: flex;
    }

    .entry-title {
        /* Linear/Radix-leaning group label: small caps, tracked, muted. */
        font-family: 'Inter', system-ui, sans-serif;
        font-weight: 600;
        font-size: 0.6875rem;
        line-height: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding-top: calc(var(--spacing) * 1);
        padding-bottom: calc(var(--spacing) * 1);
        padding-left: calc(var(--spacing) * 2);
        padding-right: calc(var(--spacing) * 2);
        color: color-mix(in oklab, var(--muted-foreground) 78%, var(--foreground));
    }

    .container-group-link {
        font-size: 0.875rem;
        line-height: 1.25rem;
        gap: 2px;
        grid-auto-rows: max-content;
        grid-auto-flow: row;
        display: grid;
    }

    .entry-link {
        color: var(--foreground);
        font-weight: 400;
        align-items: center;
        width: 100%;
        height: 1.875rem;
        display: flex;
        text-decoration: none;
        font-size: 0.8rem;
        line-height: 1.125rem;
    }

    .entry-link-inner {
        display: flex;
        align-items: center;
        padding-left: calc(var(--spacing) * 2);
        padding-right: calc(var(--spacing) * 2);
        border-radius: calc(var(--radius) - 2px);
        height: 100%;
        position: relative;
        transition:
            color 0.15s,
            background-color 0.15s;
    }

    .entry-link[aria-current='page'] {
        font-weight: 500;
    }

    /* Active state: refined to a left-edge indicator + lighter tinted bg.
     * Linear-signature treatment — the active item is unmistakable but the
     * sidebar overall stays quiet. */
    .entry-link[aria-current='page'] .entry-link-inner {
        background-color: color-mix(in oklab, var(--accent) 22%, transparent);
        color: var(--foreground);
    }

    .entry-link[aria-current='page'] .entry-link-inner::before {
        content: '';
        position: absolute;
        left: calc(var(--spacing) * -0.75);
        top: 0.3rem;
        bottom: 0.3rem;
        width: 2px;
        border-radius: 1px;
        background-color: var(--primary);
    }

    .entry-link:hover:not([aria-current='page']) .entry-link-inner {
        background-color: var(--secondary);
        color: var(--secondary-foreground);
    }

    .entry-icon {
        display: inline-block;
        width: 0.875rem;
        height: 0.875rem;
        margin-right: calc(var(--spacing) * 2);
        flex-shrink: 0;
        vertical-align: middle;
        color: var(--muted-foreground);
        opacity: 0.7;
    }

    .entry-link[aria-current='page'] .entry-icon {
        color: var(--primary);
        opacity: 1;
    }

    .entry-link:hover:not([aria-current='page']) .entry-icon {
        color: var(--foreground);
        opacity: 0.9;
    }

    .entry-badge {
        color: rgb(0 0 0);
        line-height: 1;
        font-size: 0.75rem;
        padding-top: calc(var(--spacing) * 0.5);
        padding-bottom: calc(var(--spacing) * 0.5);
        padding-left: calc(var(--spacing) * 1.5);
        padding-right: calc(var(--spacing) * 1.5);
        background-color: rgb(173 250 29);
        border-radius: calc(var(--radius) - 2px);
        margin-left: calc(var(--spacing) * 2);
    }
</style>
