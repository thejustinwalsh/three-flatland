---
import type { StarlightRouteData } from '@astrojs/starlight/route-data';

interface Props {
    sublist: StarlightRouteData['sidebar'];
    nested?: boolean;
}

const { sublist, nested } = Astro.props;

/**
 * Top-level sidebar groups cycle through gem accents from the
 * `--sidebar-section-{1..7}` token series so each section reads as its own
 * color identity (Design Context: color-as-taxonomy). Nested levels inherit
 * the parent group's `--section-accent` via CSS variable inheritance.
 */
const sectionGems = 7;
function sectionAccent(idx: number): string {
    return `--section-accent: var(--sidebar-section-${(idx % sectionGems) + 1});`;
}

/**
 * Only certain groups should be collapsable — the API reference (huge,
 * autogenerated) is the obvious one. Most other sidebar groups (Getting
 * Started, Guides, Examples) are short and read better flat. We detect
 * collapsable groups by either an explicit `entry.collapsed` flag set
 * in the Starlight sidebar config, OR by a label match for the API ref.
 */
function isCollapsableGroup(label: string, collapsed: boolean): boolean {
    if (collapsed === true) return true;
    return /^api\b/i.test(label) || /api reference/i.test(label);
}
---

{
    sublist.map((entry, idx) =>
        entry.type === 'link' ? (
            <a
                href={entry.href}
                aria-current={entry.isCurrent && 'page'}
                class:list={['entry-link', entry.attrs.class]}
                {...entry.attrs}
            >
                <span class="entry-link-inner">
                    {/*
                     * Sidebar icon resolution composes `starlight-plugin-icons`'s
                     * convention: when `Icons()` wraps Starlight, it transforms
                     * `icon: 'i-collection:name'` into `attrs['data-icon']`.
                     * Render that as a span class so UnoCSS materializes the icon.
                     */}
                    {entry.attrs['data-icon'] && (
                        <span class:list={[entry.attrs['data-icon'], 'entry-icon']} aria-hidden="true" />
                    )}
                    <span class="entry-label">{entry.label}</span>
                    {entry.badge && <span class="entry-badge">{entry.badge.text}</span>}
                </span>
            </a>
        ) : isCollapsableGroup(entry.label, !!entry.collapsed) ? (
            <details
                class="container-sidebar-entry collapsable"
                style={!nested ? sectionAccent(idx) : undefined}
                open={!entry.collapsed}
            >
                <summary class="entry-title-row">
                    <span class="entry-title">{entry.label}</span>
                    <svg class="caret" viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="2"
                            stroke-linecap="round" stroke-linejoin="round" fill="none" />
                    </svg>
                </summary>
                {/* Caret renders AFTER the title so the title's left edge
                    sits at the same x as static-group titles — no visible
                    indent from a leading icon. */}
                <div class="container-group-link">
                    <Astro.self sublist={entry.entries} nested />
                </div>
            </details>
        ) : (
            <div
                class="container-sidebar-entry static"
                style={!nested ? sectionAccent(idx) : undefined}
            >
                <h4 class="entry-title">{entry.label}</h4>
                <div class="container-group-link">
                    <Astro.self sublist={entry.entries} nested />
                </div>
            </div>
        )
    )
}

<style>
    /* Static groups (most sidebar sections — Getting Started, Guides, etc.)
     * render as plain divs with the existing tracked-uppercase title. */
    .container-sidebar-entry.static {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    /* Collapsable groups (currently API Reference) render as <details>
     * with a clickable summary row and a rotating caret. */
    .container-sidebar-entry.collapsable {
        display: block;
    }
    .container-sidebar-entry.collapsable .container-group-link {
        margin-top: calc(var(--spacing) * 1);
    }

    .entry-title-row {
        /* Title at left edge (matches static groups), caret pushed to right
         * via justify-content: space-between. No leading icon to indent
         * the title text. Padding matches the static .entry-title rule
         * (padding-inline: var(--spacing) * 2) for x-alignment parity. */
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: calc(var(--spacing) * 1.5);
        cursor: pointer;
        list-style: none;
        padding-block: calc(var(--spacing) * 1);
        padding-inline: calc(var(--spacing) * 2);
        border-radius: calc(var(--radius) - 4px);
        transition: background-color 0.15s;
    }
    .entry-title-row::-webkit-details-marker {
        display: none;
    }
    .entry-title-row:hover {
        background-color: color-mix(in oklab, var(--section-accent, var(--secondary)) 8%, transparent);
    }

    .caret {
        width: 0.75rem;
        height: 0.75rem;
        flex-shrink: 0;
        color: color-mix(in oklab, var(--section-accent, var(--muted-foreground)) 65%, var(--muted-foreground));
        transform: rotate(-90deg);
        transition: transform 0.18s ease, color 0.15s;
    }
    .container-sidebar-entry[open] > .entry-title-row > .caret {
        transform: rotate(0);
    }

    /* Tree-nesting visual — nested groups indent and carry a thin vertical
     * guide line on the left so parent/child relationships read at a
     * glance. The line is gem-tinted by the section accent. */
    .container-sidebar-entry .container-sidebar-entry {
        margin-left: calc(var(--spacing) * 2);
        padding-left: calc(var(--spacing) * 2);
        border-left: 1px solid color-mix(in oklab, var(--section-accent, var(--border)) 30%, var(--border));
    }

    /* Nested group title sits at a smaller weight so the hierarchy reads. */
    .container-sidebar-entry .container-sidebar-entry .entry-title {
        font-size: 0.6875rem;
        opacity: 0.85;
    }

    .entry-title {
        /* Group label gets the section's gem accent — color-as-taxonomy
         * (Design Context). Tracked uppercase reads as section identity,
         * the gem hue tells you *which* section without reading the label. */
        font-family: 'Inter', system-ui, sans-serif;
        font-weight: 600;
        font-size: 0.6875rem;
        line-height: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding-top: calc(var(--spacing) * 1);
        padding-bottom: calc(var(--spacing) * 1);
        padding-left: calc(var(--spacing) * 2);
        padding-right: calc(var(--spacing) * 2);
        color: var(--section-accent, color-mix(in oklab, var(--muted-foreground) 78%, var(--foreground)));
    }

    .container-group-link {
        font-size: 0.875rem;
        line-height: 1.25rem;
        gap: 2px;
        grid-auto-rows: max-content;
        grid-auto-flow: row;
        display: grid;
    }

    .entry-link {
        color: var(--foreground);
        font-weight: 400;
        align-items: center;
        width: 100%;
        height: 1.875rem;
        display: flex;
        text-decoration: none;
        font-size: 0.8rem;
        line-height: 1.125rem;
    }

    .entry-link-inner {
        display: flex;
        align-items: center;
        padding-left: calc(var(--spacing) * 2);
        padding-right: calc(var(--spacing) * 2);
        border-radius: calc(var(--radius) - 2px);
        height: 100%;
        position: relative;
        transition:
            color 0.15s,
            background-color 0.15s;
    }

    .entry-link[aria-current='page'] {
        font-weight: 500;
    }

    /* Active state: gem-accented left-edge indicator + tinted bg pulled
     * from the section's accent. Hover state previews the same gem at a
     * lower intensity so the section's identity reads through interaction. */
    .entry-link[aria-current='page'] .entry-link-inner {
        background-color: color-mix(in oklab, var(--section-accent, var(--accent)) 18%, transparent);
        color: var(--foreground);
    }

    .entry-link[aria-current='page'] .entry-link-inner::before {
        content: '';
        position: absolute;
        left: calc(var(--spacing) * -0.75);
        top: 0.3rem;
        bottom: 0.3rem;
        width: 2px;
        border-radius: 1px;
        background-color: var(--section-accent, var(--primary));
        box-shadow: 0 0 6px color-mix(in oklab, var(--section-accent, var(--primary)) 60%, transparent);
    }

    .entry-link:hover:not([aria-current='page']) .entry-link-inner {
        background-color: color-mix(in oklab, var(--section-accent, var(--accent)) 10%, var(--secondary));
        color: var(--foreground);
    }

    .entry-icon {
        display: inline-block;
        width: 0.875rem;
        height: 0.875rem;
        margin-right: calc(var(--spacing) * 2);
        flex-shrink: 0;
        vertical-align: middle;
        color: var(--muted-foreground);
        opacity: 0.7;
    }

    .entry-link[aria-current='page'] .entry-icon {
        color: var(--section-accent, var(--primary));
        opacity: 1;
    }

    .entry-link:hover:not([aria-current='page']) .entry-icon {
        color: color-mix(in oklab, var(--section-accent, var(--foreground)) 70%, var(--foreground));
        opacity: 1;
    }

    .entry-badge {
        color: rgb(0 0 0);
        line-height: 1;
        font-size: 0.75rem;
        padding-top: calc(var(--spacing) * 0.5);
        padding-bottom: calc(var(--spacing) * 0.5);
        padding-left: calc(var(--spacing) * 1.5);
        padding-right: calc(var(--spacing) * 1.5);
        background-color: rgb(173 250 29);
        border-radius: calc(var(--radius) - 2px);
        margin-left: calc(var(--spacing) * 2);
    }
</style>
