---
import type { StarlightRouteData } from '@astrojs/starlight/route-data';

interface Props {
    sublist: StarlightRouteData['sidebar'];
    nested?: boolean;
    /** When true, force every nested group below to render as a
     *  collapsable <details> block so deep trees (typedoc API ref)
     *  behave consistently with their parent. */
    forceCollapsable?: boolean;
}

const { sublist, nested, forceCollapsable } = Astro.props;

/**
 * Top-level sidebar groups cycle through gem accents from the
 * `--sidebar-section-{1..7}` token series so each section reads as its own
 * color identity (Design Context: color-as-taxonomy). Nested levels inherit
 * the parent group's `--section-accent` via CSS variable inheritance.
 */
const sectionGems = 7;
function sectionAccent(idx: number): string {
    return `--section-accent: var(--sidebar-section-${(idx % sectionGems) + 1});`;
}

/**
 * Only certain groups should be collapsable — the API reference (huge,
 * autogenerated) is the obvious one. Most other sidebar groups (Getting
 * Started, Guides, Examples) are short and read better flat. We detect
 * collapsable groups by either an explicit `entry.collapsed` flag set
 * in the Starlight sidebar config, OR by a label match for the API ref.
 */
function isCollapsableGroup(label: string, collapsed: boolean, forced: boolean): boolean {
    if (forced) return true;
    if (collapsed === true) return true;
    return /^api\b/i.test(label) || /api reference/i.test(label);
}
---

{
    sublist.map((entry, idx) =>
        entry.type === 'link' ? (
            <a
                href={entry.href}
                aria-current={entry.isCurrent && 'page'}
                class:list={['entry-link', entry.attrs.class]}
                {...entry.attrs}
            >
                <span class="entry-link-inner">
                    {/*
                     * Sidebar icon resolution composes `starlight-plugin-icons`'s
                     * convention: when `Icons()` wraps Starlight, it transforms
                     * `icon: 'i-collection:name'` into `attrs['data-icon']`.
                     * Render that as a span class so UnoCSS materializes the icon.
                     */}
                    {entry.attrs['data-icon'] && (
                        <span class:list={[entry.attrs['data-icon'], 'entry-icon']} aria-hidden="true" />
                    )}
                    <span class="entry-label">{entry.label}</span>
                    {entry.badge && <span class="entry-badge">{entry.badge.text}</span>}
                </span>
            </a>
        ) : isCollapsableGroup(entry.label, !!entry.collapsed, !!forceCollapsable) ? (
            <details
                class="container-sidebar-entry collapsable"
                style={!nested ? sectionAccent(idx) : undefined}
                open={!entry.collapsed}
            >
                <summary class="entry-title-row">
                    <svg class="caret" viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="2"
                            stroke-linecap="round" stroke-linejoin="round" fill="none" />
                    </svg>
                    <span class="entry-title">{entry.label}</span>
                </summary>
                {/* Children inherit `forceCollapsable` so deep trees
                    (typedoc API ref) cascade collapsable behavior. */}
                <div class="container-group-link">
                    <Astro.self
                        sublist={entry.entries}
                        nested
                        forceCollapsable={
                            !!forceCollapsable ||
                            isCollapsableGroup(entry.label, !!entry.collapsed, false)
                        }
                    />
                </div>
            </details>
        ) : (
            <div
                class="container-sidebar-entry static"
                style={!nested ? sectionAccent(idx) : undefined}
            >
                <h4 class="entry-title">{entry.label}</h4>
                <div class="container-group-link">
                    <Astro.self sublist={entry.entries} nested />
                </div>
            </div>
        )
    )
}

<style>
    /* Static groups (most sidebar sections — Getting Started, Guides, etc.)
     * render as plain divs with the existing tracked-uppercase title. */
    .container-sidebar-entry.static {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    /* Collapsable groups (currently API Reference) render as <details>
     * with a clickable summary row and a rotating caret. */
    .container-sidebar-entry.collapsable {
        display: block;
    }
    .container-sidebar-entry.collapsable > .container-group-link {
        margin-top: calc(var(--spacing) * 1.5);
        position: relative;
    }
    /* Continuous indent guide — one absolutely-positioned line per
     * collapsable folder, spanning the full vertical range of its
     * children. Aligned with the chevron's center (chevron is 0.75rem
     * wide, so center sits at 0.375rem from the row's left edge).
     * Single element per group ⇒ no gaps where individual sibling
     * borders used to break. */
    .container-sidebar-entry.collapsable > .container-group-link::before {
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        left: 0.375rem;
        width: 1px;
        transform: translateX(-50%);
        background-color: color-mix(in oklab, var(--section-accent, var(--border)) 30%, var(--border));
        pointer-events: none;
    }
    /* Folder-to-folder breathing room — adjacent collapsable siblings
     * get extra margin so the section breaks read as deliberate. The
     * default container-group-link `gap: 2px` is for entry-to-entry. */
    .container-sidebar-entry.collapsable + .container-sidebar-entry.collapsable {
        margin-top: calc(var(--spacing) * 2.5);
    }

    .entry-title-row {
        /* Caret leads, then title — folder-tree affordance. No padding,
         * no rounded hover rect: the chevron + indent guide line do the
         * affordance work; a hover-fill on top reads as overactive
         * chrome and breaks visual continuity with the indent line. */
        display: flex;
        align-items: center;
        gap: calc(var(--spacing) * 1);
        cursor: pointer;
        list-style: none;
        padding: 0;
    }
    .entry-title-row::-webkit-details-marker {
        display: none;
    }

    .caret {
        width: 0.75rem;
        height: 0.75rem;
        flex-shrink: 0;
        color: color-mix(in oklab, var(--section-accent, var(--muted-foreground)) 65%, var(--muted-foreground));
        transform: rotate(-90deg);
        transition: transform 0.18s ease, color 0.15s;
    }
    .container-sidebar-entry[open] > .entry-title-row > .caret {
        transform: rotate(0);
    }

    /* Tree-nesting visual — children of a collapsable folder indent
     * past the parent's guide line. The guide line is now a single
     * continuous ::before on the parent's container-group-link
     * (no gaps between sibling groups) — see below. */
    .container-sidebar-entry .container-sidebar-entry {
        margin-left: 0;
        padding-left: calc(var(--spacing) * 2);
        border-left: 0;
    }

    /* Nested group title sits at a smaller weight so the hierarchy reads. */
    .container-sidebar-entry .container-sidebar-entry .entry-title {
        font-size: 0.6875rem;
        opacity: 0.85;
    }

    .entry-title {
        /* Group label gets the section's gem accent — color-as-taxonomy
         * (Design Context). Tracked uppercase reads as section identity,
         * the gem hue tells you *which* section without reading the label. */
        font-family: 'Inter', system-ui, sans-serif;
        font-weight: 600;
        font-size: 0.6875rem;
        line-height: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--section-accent, color-mix(in oklab, var(--muted-foreground) 78%, var(--foreground)));
    }
    /* Static group label (h4 outside <summary>) keeps an inset so the
     * top-level section heading has breathing room above its links. */
    h4.entry-title {
        padding-block: calc(var(--spacing) * 1);
        padding-inline: calc(var(--spacing) * 2);
    }
    /* Collapsable group label (span inside <summary>) is flush — the
     * chevron + row gap define the spacing; an extra inline pad here
     * would push the label past the indent guide line. */
    .entry-title-row .entry-title {
        padding: 0;
    }

    .container-group-link {
        font-size: 0.875rem;
        line-height: 1.25rem;
        gap: 2px;
        grid-auto-rows: max-content;
        grid-auto-flow: row;
        display: grid;
    }

    .entry-link {
        position: relative;
        color: var(--foreground);
        font-weight: 400;
        align-items: stretch;
        width: 100%;
        height: 1.625rem;
        display: flex;
        text-decoration: none;
        font-size: 0.8rem;
        line-height: 1.125rem;
    }

    .entry-link-inner {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding-left: calc(var(--spacing) * 2);
        padding-right: calc(var(--spacing) * 2);
        height: 100%;
        width: 100%;
        min-width: 0;
        position: relative;
        transition:
            color 0.15s,
            background-color 0.15s;
    }

    /* API ref / sidebar entries truncate with ellipsis instead of
     * wrapping. Long typedoc identifiers (e.g. `MaterialEffectClass`)
     * stay on one line; the sidebar column doesn't grow with them. */
    .entry-link .entry-label {
        flex: 1 1 auto;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .entry-link[aria-current='page'] {
        font-weight: 500;
    }

    /* Single-indicator system: section-gem left-edge bar carries
     * BOTH active and hover states (full intensity active, faint
     * hover preview). Previously paired this with a rounded-pill
     * background fill — the two indicators read as competing systems,
     * so the pill was dropped. The section gem still surfaces via
     * the entry-icon color change and the font-weight bump. */
    .entry-link[aria-current='page'] .entry-link-inner,
    .entry-link:hover:not([aria-current='page']) .entry-link-inner {
        background-color: transparent;
        color: var(--foreground);
    }

    /* Active / hover marker — 2px-wide vertical pip aligned with the
     * chevron's center (0.375rem from the entry-link's left edge,
     * matching the indent guide line above). The pip OVERLAYS that
     * section of the guide line, so the active entry visually
     * "thickens" the line at its row — a single, coherent indicator. */
    .entry-link[aria-current='page']::before,
    .entry-link:hover:not([aria-current='page'])::before {
        content: '';
        position: absolute;
        top: 0.25rem;
        bottom: 0.25rem;
        left: 0.375rem;
        width: 2px;
        transform: translateX(-50%);
        border-radius: 1px;
        pointer-events: none;
    }
    .entry-link[aria-current='page']::before {
        background-color: var(--section-accent, var(--primary));
    }
    .entry-link:hover:not([aria-current='page'])::before {
        background-color: color-mix(in oklab, var(--section-accent, var(--primary)) 35%, transparent);
    }

    .entry-icon {
        display: inline-block;
        width: 0.875rem;
        height: 0.875rem;
        margin-right: calc(var(--spacing) * 2);
        flex-shrink: 0;
        vertical-align: middle;
        color: var(--muted-foreground);
        opacity: 0.7;
    }

    .entry-link[aria-current='page'] .entry-icon {
        color: var(--section-accent, var(--primary));
        opacity: 1;
    }

    .entry-link:hover:not([aria-current='page']) .entry-icon {
        color: color-mix(in oklab, var(--section-accent, var(--foreground)) 70%, var(--foreground));
        opacity: 1;
    }

    .entry-badge {
        color: rgb(0 0 0);
        line-height: 1;
        font-size: 0.75rem;
        padding-top: calc(var(--spacing) * 0.5);
        padding-bottom: calc(var(--spacing) * 0.5);
        padding-left: calc(var(--spacing) * 1.5);
        padding-right: calc(var(--spacing) * 1.5);
        background-color: rgb(173 250 29);
        border-radius: calc(var(--radius) - 2px);
        margin-left: calc(var(--spacing) * 2);
    }
</style>
