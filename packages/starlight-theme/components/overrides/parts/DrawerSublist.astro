---
/**
 * Recursive sub-list for the mobile drawer. Renders both flat sections
 * (Getting Started, Guides — children are all leaf links) and nested
 * sections (API Reference — children are subgroups with leaf links one
 * level deeper). Mirrors the structure of `SidebarSublist.astro` but
 * with mobile-thumb sizing and the drawer's design language.
 *
 * The section-gem accent is set ONCE on the wrapping <section> in
 * `Drawer.astro` (via `--section-accent`) and inherits through every
 * level of recursion below via CSS cascade — DrawerSublist itself
 * doesn't reassign it. That keeps every link/sub-label in a section
 * carrying the same gem identity, no matter how deeply nested.
 */
import type { StarlightRouteData } from '@astrojs/starlight/route-data';

interface Props {
    sublist: StarlightRouteData['sidebar'];
    /** Set true by the recursive call. Top-level invocation leaves
     *  unset so root-level groups skip the indent + smaller-label
     *  treatment. */
    nested?: boolean;
    /** Forced down through recursion: once we're inside a known-
     *  collapsable subtree (e.g. API Reference), every nested group
     *  also renders as collapsable for consistency. */
    forceCollapsable?: boolean;
}

const { sublist, nested, forceCollapsable } = Astro.props;

/** Matches SidebarSublist's heuristic — only the API ref is force-
 *  collapsable by default. Other groups can opt in via `collapsed`. */
function isCollapsableGroup(label: string, collapsed: boolean, forced: boolean): boolean {
    if (forced) return true;
    if (collapsed === true) return true;
    return /^api\b/i.test(label) || /api reference/i.test(label);
}
---

{
    sublist.map((entry) =>
        entry.type === 'link' ? (
            <a
                href={entry.href}
                class="entry-link"
                aria-current={entry.isCurrent ? 'page' : undefined}
                {...entry.attrs}
            >
                <span class="entry-link-label">{entry.label}</span>
            </a>
        ) : isCollapsableGroup(entry.label, !!entry.collapsed, !!forceCollapsable) ? (
            <details class="entry-group collapsable" open={!entry.collapsed}>
                <summary class="entry-group-summary">
                    <svg class="caret" viewBox="0 0 16 16" aria-hidden="true">
                        <path
                            d="M4 6l4 4 4-4"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            fill="none"
                        />
                    </svg>
                    <span class="entry-group-label">{entry.label}</span>
                </summary>
                <div class="entry-group-children">
                    <Astro.self
                        sublist={entry.entries}
                        nested
                        forceCollapsable={
                            !!forceCollapsable ||
                            isCollapsableGroup(entry.label, !!entry.collapsed, false)
                        }
                    />
                </div>
            </details>
        ) : (
            <div class="entry-group static">
                {nested && <span class="entry-group-label">{entry.label}</span>}
                <div class="entry-group-children">
                    <Astro.self sublist={entry.entries} nested />
                </div>
            </div>
        )
    )
}

<style>
    /* ────────── Drawer link/group styling ──────────
     * Scoped to DrawerSublist so the same selectors used by the desktop
     * sidebar (SidebarSublist) don't collide. Visuals match the rest of
     * the drawer's gem-led design — single-indicator rule (pip + color
     * shift, no rounded-rect bg fill) per design system. */

    .entry-link {
        position: relative;
        display: flex;
        align-items: center;
        min-height: 2.25rem;
        padding: calc(var(--spacing) * 1.5) calc(var(--spacing) * 3);
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.875rem;
        line-height: 1.25rem;
        color: var(--muted-foreground);
        text-decoration: none;
        transition: color 150ms cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .entry-link:hover {
        color: var(--foreground);
    }
    .entry-link[aria-current='page'] {
        color: var(--foreground);
        font-weight: 500;
    }
    /* Left pip — gem-tinted indicator. Same single-indicator system as
     * SidebarSublist.astro and the rest of the design system. */
    .entry-link[aria-current='page']::before,
    .entry-link:hover:not([aria-current='page'])::before {
        content: '';
        position: absolute;
        top: 0.4375rem;
        bottom: 0.4375rem;
        left: 0;
        width: 2px;
        border-radius: 1px;
        pointer-events: none;
    }
    .entry-link[aria-current='page']::before {
        background-color: var(--section-accent, var(--primary));
    }
    .entry-link:hover:not([aria-current='page'])::before {
        background-color: color-mix(
            in oklab,
            var(--section-accent, var(--primary)) 40%,
            transparent
        );
    }

    .entry-link-label {
        flex: 1 1 auto;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* ────────── Nested groups ──────────
     * Collapsable groups (API Reference's subgroups) get a clickable
     * summary row with a rotating caret. Static groups (rare at this
     * depth) just render their label + children inline. */

    .entry-group.collapsable {
        display: block;
    }
    .entry-group.collapsable + .entry-group.collapsable {
        margin-top: calc(var(--spacing) * 2);
    }

    .entry-group-summary {
        display: flex;
        align-items: center;
        gap: calc(var(--spacing) * 1.5);
        min-height: 2.25rem;
        padding: calc(var(--spacing) * 1.5) 0;
        cursor: pointer;
        list-style: none;
        font-family: 'Inter', system-ui, sans-serif;
        font-weight: 500;
        font-size: 0.8125rem;
        line-height: 1.125rem;
        color: var(--muted-foreground);
        transition: color 150ms cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .entry-group-summary::-webkit-details-marker {
        display: none;
    }
    .entry-group-summary:hover {
        color: var(--foreground);
    }

    .caret {
        width: 0.75rem;
        height: 0.75rem;
        flex-shrink: 0;
        color: color-mix(
            in oklab,
            var(--section-accent, var(--muted-foreground)) 65%,
            var(--muted-foreground)
        );
        transform: rotate(-90deg);
        transition:
            transform 0.18s ease,
            color 0.15s;
    }
    .entry-group.collapsable[open] > .entry-group-summary > .caret {
        transform: rotate(0);
    }

    .entry-group-children {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    /* Indent for nested levels — children of a collapsed group sit
     * deeper than their summary. Continuous gem-tinted guide line
     * spans the full vertical range so the hierarchy reads at a
     * glance. */
    .entry-group .entry-group-children {
        position: relative;
        margin-left: calc(var(--spacing) * 1.5);
        padding-left: calc(var(--spacing) * 3);
    }
    .entry-group .entry-group-children::before {
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        left: 0.375rem;
        width: 1px;
        transform: translateX(-50%);
        background-color: color-mix(
            in oklab,
            var(--section-accent, var(--border)) 28%,
            var(--border)
        );
        pointer-events: none;
    }

    /* Static nested groups (rare — most nesting at depth > 0 is
     * collapsable). Their label is smaller and dimmer so it reads as
     * sub-header within the parent section. */
    .entry-group.static .entry-group-label {
        display: block;
        font-family: 'Inter', system-ui, sans-serif;
        font-weight: 600;
        font-size: 0.625rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: color-mix(
            in oklab,
            var(--section-accent, var(--muted-foreground)) 55%,
            var(--muted-foreground)
        );
        padding: calc(var(--spacing) * 2) 0 calc(var(--spacing) * 1);
    }

    @media (prefers-reduced-motion: reduce) {
        .entry-link,
        .entry-group-summary,
        .caret {
            transition: none;
        }
    }
</style>
