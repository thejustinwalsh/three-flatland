---
import type { MarkdownHeading } from 'astro';
import { Badge } from '@astrojs/starlight/components';

interface TocItem extends MarkdownHeading {
    children: TocItem[];
}

interface Props {
    toc: TocItem[];
    depth?: number;
    isMobile?: boolean;
}

const { toc, depth = 0 } = Astro.props;

/**
 * Deserialize starlight-heading-badges markers from TOC heading text.
 * Inlined here because we override Starlight's `TableOfContents` instead
 * of letting the plugin do it — without this the raw `__SHB__…__SHB__`
 * markers leak into the on-this-page links. Format mirrors the plugin:
 * `<text>__SHB__<variant>__SHB__<text>__SHB__` with spaces in badge
 * text encoded as `__SHB_SPACE__`.
 */
const SHB_DELIM = '__SHB__';
const SHB_SPACE = '__SHB_SPACE__';
const SHB_VARIANTS = [
    'caution',
    'danger',
    'default',
    'note',
    'success',
    'tip',
] as const;
type ShbVariant = (typeof SHB_VARIANTS)[number];

interface ParsedHeading {
    title: string;
    badges: { text: string; variant: ShbVariant }[];
}

function parseHeading(text: string): ParsedHeading {
    const parts = text.split(' ').toReversed();
    const badges: ParsedHeading['badges'] = [];
    for (const part of parts) {
        const segments = part.split(SHB_DELIM);
        const variant = segments[1];
        const badgeText = segments[2];
        if (
            !variant ||
            !badgeText ||
            !SHB_VARIANTS.includes(variant as ShbVariant)
        ) {
            break;
        }
        badges.unshift({
            text: badgeText.replaceAll(SHB_SPACE, ' '),
            variant: variant as ShbVariant,
        });
    }
    if (badges.length === 0) return { title: text, badges: [] };
    const title = text
        .replace(new RegExp(`${SHB_DELIM}.*${SHB_DELIM}`), '')
        .trim();
    return { title, badges };
}
---

<ul>
    {
        toc.map((heading) => {
            const parsed = parseHeading(heading.text);
            return (
                <li>
                    <a href={'#' + heading.slug}>
                        {parsed.title}
                        {parsed.badges.map((b) => (
                            <Badge
                                size="small"
                                text={b.text}
                                variant={b.variant}
                            />
                        ))}
                    </a>
                    {heading.children.length > 0 && (
                        <Astro.self toc={heading.children} depth={depth + 1} />
                    )}
                </li>
            );
        })
    }
</ul>

<style define:vars={{ depth }}>
    ul {
        list-style-type: none;
        margin: 0;
        padding: 0;
    }
    li {
        line-height: 1;
        padding-top: 0;
        margin-top: 0;
        position: relative;
    }

    li + li {
        margin-top: calc(var(--spacing) * 2);
    }

    a {
        font-family: 'Inter', system-ui, sans-serif;
        text-decoration: none;
        color: var(--muted-foreground);
        display: inline-flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.4em;
        font-size: 0.8125rem;
        font-weight: 400;
        line-height: 1.4;
        padding-block: calc(var(--spacing) * 0.5);
        transition: color 0.15s;
    }

    /* Inline TOC badges sit alongside the heading title — Starlight's
     * default Badge sizing is too loud for the compass column. */
    a :global(.sl-badge) {
        font-size: 0.625rem;
        line-height: 1.2;
        padding: 0.0625rem 0.3rem;
        font-weight: 500;
    }

    a:hover {
        color: var(--foreground);
    }

    /* Hover marker — faint diamond-tinted left edge that previews the
     * active-marker placement. Lower opacity than the active state so
     * the cursor's affordance is felt without competing with the
     * actual current-section indicator. */
    a:hover::before {
        content: '';
        position: absolute;
        left: calc(var(--spacing) * -2);
        top: 0.5rem;
        bottom: 0.5rem;
        width: 2px;
        border-radius: 1px;
        background-color: color-mix(in oklab, var(--diamond) 35%, transparent);
    }

    /* Active TOC link — diamond accent (TOC = compass; diamond is the
     * neutral high-contrast gem for "you are here"). Left-edge marker
     * with a soft diamond glow, plus the link text gem-mixed toward
     * foreground for legibility. The hover marker (above) inherits
     * the same geometry so hover→active is positionally continuous. */
    a[aria-current] {
        color: color-mix(in oklab, var(--diamond) 70%, var(--foreground));
        font-weight: 500;
    }

    a[aria-current]::before {
        content: '';
        position: absolute;
        left: calc(var(--spacing) * -2);
        top: 0.4rem;
        bottom: 0.4rem;
        width: 2px;
        border-radius: 1px;
        background-color: var(--diamond);
    }

    /* Nested TOC items indent + thin guide line, mirroring the sidebar.
     * Guide line is diamond-tinted at low alpha so it reads warmer
     * than a bare border-color and ties to the active marker's hue. */
    ul > li > ul {
        --pad-inline: calc(var(--spacing) * 3);
        margin-top: calc(var(--spacing) * 1.5);
        padding-inline: calc((1rem - var(--pad-inline)) / var(--depth) + var(--pad-inline))
            var(--pad-inline);
        border-left: 1px solid color-mix(in oklab, var(--diamond) 18%, var(--border));
        margin-left: calc(var(--spacing) * 1);
    }
</style>
