---
import type { MarkdownHeading } from 'astro';

interface TocItem extends MarkdownHeading {
    children: TocItem[];
}

interface Props {
    toc: TocItem[];
    depth?: number;
    isMobile?: boolean;
}

const { toc, depth = 0 } = Astro.props;
---

<ul>
    {
        toc.map((heading) => (
            <li>
                <a href={'#' + heading.slug}>{heading.text}</a>
                {heading.children.length > 0 && (
                    <Astro.self toc={heading.children} depth={depth + 1} />
                )}
            </li>
        ))
    }
</ul>

<style define:vars={{ depth }}>
    ul {
        list-style-type: none;
        margin: 0;
        padding: 0;
    }
    li {
        line-height: 1;
        padding-top: 0;
        margin-top: 0;
        position: relative;
    }

    li + li {
        margin-top: calc(var(--spacing) * 2);
    }

    a {
        font-family: 'Inter', system-ui, sans-serif;
        text-decoration: none;
        color: var(--muted-foreground);
        display: inline-block;
        font-size: 0.8125rem;
        font-weight: 400;
        line-height: 1.4;
        padding-block: calc(var(--spacing) * 0.5);
        transition: color 0.15s;
    }

    a:hover {
        color: var(--foreground);
    }

    /* Hover marker — faint diamond-tinted left edge that previews the
     * active-marker placement. Lower opacity than the active state so
     * the cursor's affordance is felt without competing with the
     * actual current-section indicator. */
    a:hover::before {
        content: '';
        position: absolute;
        left: calc(var(--spacing) * -2);
        top: 0.5rem;
        bottom: 0.5rem;
        width: 2px;
        border-radius: 1px;
        background-color: color-mix(in oklab, var(--diamond) 35%, transparent);
    }

    /* Active TOC link — diamond accent (TOC = compass; diamond is the
     * neutral high-contrast gem for "you are here"). Left-edge marker
     * with a soft diamond glow, plus the link text gem-mixed toward
     * foreground for legibility. The hover marker (above) inherits
     * the same geometry so hover→active is positionally continuous. */
    a[aria-current] {
        color: color-mix(in oklab, var(--diamond) 70%, var(--foreground));
        font-weight: 500;
    }

    a[aria-current]::before {
        content: '';
        position: absolute;
        left: calc(var(--spacing) * -2);
        top: 0.4rem;
        bottom: 0.4rem;
        width: 2px;
        border-radius: 1px;
        background-color: var(--diamond);
    }

    /* Nested TOC items indent + thin guide line, mirroring the sidebar.
     * Guide line is diamond-tinted at low alpha so it reads warmer
     * than a bare border-color and ties to the active marker's hue. */
    ul > li > ul {
        --pad-inline: calc(var(--spacing) * 3);
        margin-top: calc(var(--spacing) * 1.5);
        padding-inline: calc((1rem - var(--pad-inline)) / var(--depth) + var(--pad-inline))
            var(--pad-inline);
        border-left: 1px solid color-mix(in oklab, var(--diamond) 18%, var(--border));
        margin-left: calc(var(--spacing) * 1);
    }
</style>
