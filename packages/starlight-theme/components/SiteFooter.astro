---
/**
 * SiteFooter — site-wide footer rendered on every page via PageFrame.
 *
 * Brand block + link-column grid + bottom attribution row. Defaults
 * pull from starlight's user-config (title, description) so the theme
 * works out-of-the-box for any starlight site; columns and version
 * are overridable per project.
 *
 * Visual: horizontal foil rule at the top (cursor-driven peak via
 * --mx, same pattern as ValueProp's vertical rule). Column headings
 * carry sidebar-section gem tints for section identity.
 *
 * Auto-discovery: the Packages column and the core-package version
 * are read from `packages/* /package.json` at build time so adding
 * a new workspace package surfaces it in the footer automatically.
 * If the workspace layout isn't there (theme used outside this repo),
 * falls back to hard-coded defaults.
 */
import config from 'virtual:starlight/user-config'
import { workspacePackages, getPackageBadge, getPackageVersion } from '../lib/packages'

type Gem =
    | 'gold'
    | 'ruby'
    | 'emerald'
    | 'diamond'
    | 'amethyst'
    | 'pink'
    | 'salmon'
    | 'turquoize'

interface FooterLink {
    label: string
    href: string
    external?: boolean
    badge?: string
}

interface FooterColumn {
    heading: string
    gem?: Gem
    /** Stable identifier — used by layout for column-specific tweaks. */
    id?: string
    links: FooterLink[]
}

interface Props {
    /** Brand wordmark text. Defaults to `config.title`. */
    wordmark?: string
    /** Brand tagline. Defaults to `config.description`. */
    tagline?: string
    /** Link columns. Defaults to three-flatland's IA. */
    columns?: FooterColumn[]
    /** Copyright holder. Defaults to "Justin Walsh". */
    copyrightHolder?: string
    /** Copyright year. Defaults to the current year. */
    copyrightYear?: number
    /** Package version string. Auto-detected if omitted. */
    version?: string
    /** npm package name shown beside the version. */
    versionPackage?: string
}

/**
 * Build the Packages column from the workspace's detected packages.
 * `workspacePackages` is read once at module load by lib/packages.ts.
 * Falls back to a single-link list when no workspace is available
 * (e.g., theme installed from npm outside this monorepo).
 *
 * Badge-suppression rule: hide footer badges that match the project-
 * level baseline (the brand package's badge). When every package
 * shares the same release state — currently everything is `Alpha` —
 * tagging each entry with "alpha" is noise. Only divergent badges
 * (preview, beta, deprecated, etc.) earn their visual cost.
 *
 * The corner alpha-ribbon (PageFrame) reads the same `flatland.badge`
 * for project-level signaling; this filter only affects the footer
 * Packages column.
 */
function buildPackagesColumn(brandPackageName: string = 'three-flatland'): FooterColumn {
    if (workspacePackages.length === 0) {
        return {
            heading: 'Packages',
            gem: 'amethyst',
            id: 'packages',
            links: [
                { label: 'three-flatland', href: 'https://www.npmjs.com/package/three-flatland', external: true },
            ],
        }
    }
    const baseline = getPackageBadge(brandPackageName)?.toLowerCase()
    return {
        heading: 'Packages',
        gem: 'amethyst',
        id: 'packages',
        links: workspacePackages.map((pkg) => ({
            label: pkg.name,
            href: `https://www.npmjs.com/package/${pkg.name}`,
            external: true,
            badge: pkg.badge && pkg.badge.toLowerCase() !== baseline ? pkg.badge : undefined,
        })),
    }
}

const defaultColumns: FooterColumn[] = [
    {
        heading: 'Docs',
        gem: 'diamond',
        links: [
            { label: 'Get started', href: '/getting-started/introduction/' },
            { label: 'Guides', href: '/guides/sprites/' },
            { label: 'API reference', href: '/api/' },
            { label: 'Examples', href: '/examples/' },
            { label: 'Showcases', href: '/showcases/' },
        ],
    },
    buildPackagesColumn(),
    {
        heading: 'Community',
        gem: 'emerald',
        links: [
            { label: 'GitHub', href: 'https://github.com/thejustinwalsh/three-flatland', external: true },
            { label: 'Changelog', href: 'https://github.com/thejustinwalsh/three-flatland/releases', external: true },
            { label: 'Issues', href: 'https://github.com/thejustinwalsh/three-flatland/issues', external: true },
            { label: 'Discord', href: 'https://discord.gg/kjHdXR7W83', external: true },
        ],
    },
]

/**
 * Starlight stores `title` and `description` internally as
 * `LocalizedString` — `string | Record<locale, string>`. The virtual
 * user-config module hands back the record form even for sites that
 * configured a plain string (Starlight normalizes on load). Rendering
 * the record directly produces literal "[object Object]" on the page.
 * Unwrap to the active locale's string, falling back to first value.
 */
function unwrapLocalized(value: unknown, fallback: string): string {
    if (typeof value === 'string') return value
    if (value && typeof value === 'object') {
        const locale = Astro.currentLocale
        const record = value as Record<string, string>
        if (locale && typeof record[locale] === 'string') return record[locale]
        const first = Object.values(record)[0]
        if (typeof first === 'string') return first
    }
    return fallback
}

const {
    wordmark = unwrapLocalized(config.title, 'flatland'),
    tagline = unwrapLocalized(config.description, ''),
    columns = defaultColumns,
    copyrightHolder = 'Justin Walsh',
    copyrightYear = new Date().getFullYear(),
    versionPackage = 'three-flatland',
    version = getPackageVersion(versionPackage),
} = Astro.props

/**
 * When the Packages column has more than this many entries, the grid
 * gives it a 2x-wide slot and the link list splits into 2 sub-columns.
 * Threshold tuned so today's 5 packages stay single-column and the
 * layout transitions cleanly as new `@three-flatland/*` packages ship.
 */
const PACKAGES_WIDE_THRESHOLD = 6
const packagesCol = columns.find((col) => col.id === 'packages')
const packagesWide = (packagesCol?.links.length ?? 0) > PACKAGES_WIDE_THRESHOLD

/**
 * Resolve a link href against Astro's BASE_URL. Internal links that
 * start with "/" need the site base ("/three-flatland/") prepended
 * or they'll 404 against the deployed subpath. External links and
 * already-absolute paths pass through untouched.
 */
function resolveHref(href: string, external?: boolean): string {
    if (external) return href
    if (!href.startsWith('/')) return href
    const base = (import.meta.env.BASE_URL ?? '/').replace(/\/$/, '')
    return base + href
}
---

<footer class="site-footer u-reveal" data-slot="site-footer">
    <div class="site-footer-rule" aria-hidden="true"></div>

    <div class="site-footer-inner">
        <div class="site-footer-grid" data-packages-wide={packagesWide ? '' : undefined}>
            <div class="site-footer-brand">
                {/*
                 * Brand lockup — alternate shorthand "FL" + full
                 * wordmark "Flatland" rendered as two distinct
                 * elements. The <abbr> carries the expansion as a
                 * title attribute so screen readers and search engines
                 * associate FL with Flatland. The SVG separator is
                 * intentionally taller than the cap height so it
                 * reads as a divider rule, not a Silkscreen glyph.
                 */}
                <div class="site-footer-wordmark">
                    <abbr class="site-footer-wordmark-short" title="Flatland">FL</abbr>
                    <svg
                        class="site-footer-wordmark-sep"
                        width="2"
                        height="32"
                        viewBox="0 0 2 32"
                        preserveAspectRatio="none"
                        aria-hidden="true"
                        focusable="false"
                    >
                        <line x1="1" y1="0" x2="1" y2="32" stroke="currentColor" stroke-width="2" vector-effect="non-scaling-stroke" />
                    </svg>
                    <span class="site-footer-wordmark-full">{wordmark}</span>
                </div>
                {tagline && <p class="site-footer-tagline">{tagline}</p>}
            </div>

            {columns.map((col) => (
                <div class="site-footer-column" data-gem={col.gem} data-id={col.id}>
                    <h2 class="site-footer-heading">{col.heading}</h2>
                    <ul class="site-footer-links">
                        {col.links.map((link) => (
                            <li>
                                <a
                                    class="site-footer-link"
                                    href={resolveHref(link.href, link.external)}
                                    target={link.external ? '_blank' : undefined}
                                    rel={link.external ? 'noopener noreferrer' : undefined}
                                >
                                    <span>{link.label}</span>
                                    {link.badge && <span class="site-footer-badge">{link.badge}</span>}
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>
            ))}
        </div>

        <div class="site-footer-bottom">
            <span class="site-footer-copyright">© {copyrightYear} {copyrightHolder}</span>
            {version && (
                <span class="site-footer-version"><code>{versionPackage}</code> {version}</span>
            )}
        </div>
    </div>
</footer>

<style>
    .site-footer {
        position: relative;
        width: 100%;
        background: var(--background);
        margin-top: calc(var(--spacing) * 16);
        padding-top: calc(var(--spacing) * 12);
        padding-bottom: calc(var(--spacing) * 8);
    }

    /* Horizontal foil rule — gem gradient with cursor-driven peak
     * via --mx (same affordance as ValueProp's vertical .vp-rule).
     * Quiet when idle, brightens where the cursor hovers above. */
    .site-footer-rule {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(
            90deg,
            color-mix(in oklab, var(--diamond) 16%, transparent) 0%,
            color-mix(in oklab, var(--amethyst) 32%, transparent) calc(max(0%, var(--mx, 50%) - 18%)),
            color-mix(in oklab, var(--amethyst) 90%, white) var(--mx, 50%),
            color-mix(in oklab, var(--emerald) 32%, transparent) calc(min(100%, var(--mx, 50%) + 18%)),
            color-mix(in oklab, var(--gold) 16%, transparent) 100%
        );
        pointer-events: none;
    }

    .site-footer-inner {
        max-width: var(--container-max-width);
        margin-inline: auto;
        padding-inline: clamp(1.5rem, 4vw, 3rem);
    }

    .site-footer-grid {
        display: grid;
        grid-template-columns: 1.4fr 1fr 1fr 1fr;
        gap: calc(var(--spacing) * 12);
        margin-bottom: calc(var(--spacing) * 10);
    }

    /* Packages column outgrows its slot — give it a 2x slot in the grid
     * and split the link list into 2 sub-columns. Threshold is tunable
     * (PACKAGES_WIDE_THRESHOLD in the frontmatter) and the attribute is
     * only emitted when crossed, so today's 5 packages stay single-col
     * and the layout shifts automatically as new packages ship. */
    .site-footer-grid[data-packages-wide] {
        grid-template-columns: 1.2fr 1fr 2fr 1fr;
    }

    .site-footer-grid[data-packages-wide] .site-footer-column[data-id='packages'] .site-footer-links {
        columns: 2;
        column-gap: calc(var(--spacing) * 6);
        column-fill: balance;
    }

    /* Each <li> shouldn't break across columns — keeps badges + labels
     * on the same row when the column split lands mid-row. */
    .site-footer-grid[data-packages-wide] .site-footer-column[data-id='packages'] .site-footer-links > li {
        break-inside: avoid;
    }

    @media (max-width: 900px) {
        .site-footer-grid,
        .site-footer-grid[data-packages-wide] {
            grid-template-columns: 1fr 1fr;
            gap: calc(var(--spacing) * 8);
        }

        /* Tablet: drop the multicol — narrower column slots can't host
         * two sub-columns readably. */
        .site-footer-grid[data-packages-wide] .site-footer-column[data-id='packages'] .site-footer-links {
            columns: auto;
        }
    }

    @media (max-width: 560px) {
        .site-footer-grid,
        .site-footer-grid[data-packages-wide] {
            grid-template-columns: 1fr;
            gap: calc(var(--spacing) * 6);
        }
    }

    /* Brand block */
    .site-footer-brand {
        display: flex;
        flex-direction: column;
        gap: calc(var(--spacing) * 3);
    }

    /* Brand lockup — two Silkscreen pixel-font tokens flanking a thin
     * SVG separator. The SVG rule is deliberately taller than the
     * cap height so the bar reads as a divider, not as part of the
     * pixel font. */
    .site-footer-wordmark {
        display: inline-flex;
        align-items: center;
        gap: calc(var(--spacing) * 2.5);
        font-family: 'Silkscreen', monospace;
        font-size: 1.375rem;
        font-weight: 400;
        line-height: 1;
        letter-spacing: 0.01em;
        color: var(--foreground);
    }

    /* Shorthand initials (FL). <abbr> default underline is suppressed
     * because the SVG bar already signals brand-mark structure. */
    .site-footer-wordmark-short {
        text-decoration: none;
        cursor: help;
    }

    /* Separator rule — 2px wide SVG line, currentColor, sized to the
     * font height plus a small overreach on each side. Non-scaling
     * stroke locks the rule at 2 device pixels regardless of viewBox
     * scaling.
     *
     * Visual centering: Silkscreen glyphs sit low in their em-box (a
     * pixel-font metric quirk), so a flex-aligned bar at em-box center
     * lands above the visible glyph center. The 3px downward offset
     * pushes the bar to optical center with the visible glyphs. */
    .site-footer-wordmark-sep {
        display: block;
        flex: none;
        width: 2px;
        height: calc(1em + 6px);
        position: relative;
        top: 2px;
        opacity: 0.6;
    }

    /* Full wordmark — capitalized for the alternate lockup display
     * ("flatland" → "Flatland"). Keeps the prop-driven `wordmark`
     * value flexible across themes; only the display form changes. */
    .site-footer-wordmark-full {
        text-transform: capitalize;
    }

    .site-footer-tagline {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 0.75rem;
        line-height: 1.55;
        color: var(--muted-foreground);
        max-width: 26ch;
        margin: 0;
    }

    /* Link columns */
    .site-footer-column {
        display: flex;
        flex-direction: column;
        gap: calc(var(--spacing) * 4);
    }

    .site-footer-heading {
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.6875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--col-gem, var(--muted-foreground));
        margin: 0;
    }

    .site-footer-column[data-gem='diamond']  { --col-gem: var(--diamond); }
    .site-footer-column[data-gem='amethyst'] { --col-gem: var(--amethyst); }
    .site-footer-column[data-gem='emerald']  { --col-gem: var(--emerald); }
    .site-footer-column[data-gem='gold']     { --col-gem: var(--gold); }
    .site-footer-column[data-gem='ruby']     { --col-gem: var(--ruby); }
    .site-footer-column[data-gem='pink']     { --col-gem: var(--pink); }
    .site-footer-column[data-gem='salmon']   { --col-gem: var(--salmon); }
    .site-footer-column[data-gem='turquoize']{ --col-gem: var(--turquoize); }

    .site-footer-links {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: calc(var(--spacing) * 2);
    }

    .site-footer-link {
        display: inline-flex;
        align-items: center;
        gap: calc(var(--spacing) * 2);
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.8125rem;
        font-weight: 400;
        color: var(--muted-foreground);
        text-decoration: none;
        transition: color 160ms ease;
    }

    /* Hover + focus take the parent column's section gem (--col-gem),
     * so each link picks up the same accent as its heading. Falls back
     * to the project-level link-hover when no column gem is set. */
    .site-footer-link:hover {
        color: var(--col-gem, var(--link-hover));
    }

    .site-footer-link:focus-visible {
        outline: 2px solid var(--col-gem, var(--link-hover));
        outline-offset: 2px;
        border-radius: 2px;
    }

    /* Inline badge — alpha / in-flight / etc. Gold-low tinted pill
     * matching the heading-badge convention used elsewhere in the
     * theme for in-development surface markers. */
    .site-footer-badge {
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.5625rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 0.125rem 0.375rem;
        border-radius: 0.25rem;
        background: color-mix(in oklab, var(--gold) 14%, transparent);
        color: var(--gold);
        border: 1px solid color-mix(in oklab, var(--gold) 28%, transparent);
        line-height: 1;
        white-space: nowrap;
    }

    /* Bottom row */
    .site-footer-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: calc(var(--spacing) * 2);
        padding-top: calc(var(--spacing) * 6);
        border-top: 1px solid color-mix(in oklab, var(--border) 50%, transparent);
    }

    .site-footer-copyright,
    .site-footer-version {
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.75rem;
        color: var(--muted-foreground);
        margin: 0;
    }

    .site-footer-version code {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 0.75rem;
        background: none;
        padding: 0;
        color: var(--foreground);
    }

    @media (max-width: 560px) {
        .site-footer-bottom {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>
