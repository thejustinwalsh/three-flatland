{
  "name": "@three-flatland/uikit-lucide",
  "version": "0.1.0-alpha.0",
  "description": "Lucide icon set for @three-flatland/uikit, generated as filled-path Svg components",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "source": "./src/react.ts",
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./react/*": {
      "source": "./src/react/*.ts",
      "import": {
        "types": "./dist/react/*.d.ts",
        "default": "./dist/react/*.js"
      },
      "require": {
        "types": "./dist/react/*.d.cts",
        "default": "./dist/react/*.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "convert": "node --loader ts-node/esm ./scripts/convert.ts",
    "generate": "node --loader ts-node/esm ./scripts/generate.ts && node --loader ts-node/esm ./scripts/generate-react.ts",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "ensure": "grep -q 'ChevronDown' src/index.ts 2>/dev/null || (pnpm run convert && pnpm run generate)",
    "pretypecheck": "pnpm run ensure",
    "prebuild": "pnpm run ensure"
  },
  "peerDependencies": {
    "three": "catalog:"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    }
  },
  "dependencies": {
    "@three-flatland/uikit": "workspace:*"
  },
  "devDependencies": {
    "@react-three/fiber": "catalog:",
    "@types/react": "catalog:",
    "@types/three": "catalog:",
    "lucide-static": "^0.511.0",
    "oslllo-svg-fixer": "^5.0.0",
    "react": "catalog:",
    "three": "catalog:",
    "ts-node": "^10.9.2"
  },
  "keywords": [
    "three.js",
    "tsl",
    "uikit",
    "lucide",
    "icons",
    "svg",
    "webgpu"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thejustinwalsh/three-flatland.git",
    "directory": "packages/uikit-lucide"
  }
}
