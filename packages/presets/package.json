{
  "name": "@three-flatland/presets",
  "version": "0.1.0-alpha.4",
  "description": "Pre-configured setups for three-flatland",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "source": "./src/react.ts",
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "three": "catalog:",
    "@react-three/fiber": "catalog:"
  },
  "peerDependenciesMeta": {
    "@react-three/fiber": { "optional": true }
  },
  "dependencies": {
    "three-flatland": "workspace:*",
    "@three-flatland/nodes": "workspace:*"
  },
  "devDependencies": {
    "@types/three": "catalog:",
    "three": "catalog:",
    "@react-three/fiber": "catalog:"
  },
  "keywords": [
    "three.js",
    "sprites",
    "presets",
    "effects"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thejustinwalsh/three-flatland.git",
    "directory": "packages/presets"
  }
}
