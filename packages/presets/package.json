{
  "name": "@three-flatland/presets",
  "version": "0.1.0-alpha.8",
  "description": "Pre-configured setups for three-flatland",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./react": {
      "source": "./src/react.ts",
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "nx": {
    "tags": [
      "scope:consumer"
    ],
    "targets": {
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "oxlint --type-aware .",
          "cwd": "{projectRoot}"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@react-three/fiber": "catalog:",
    "three": "catalog:"
  },
  "peerDependenciesMeta": {
    "@react-three/fiber": {
      "optional": true
    }
  },
  "dependencies": {
    "@three-flatland/nodes": "workspace:*",
    "three-flatland": "workspace:*"
  },
  "devDependencies": {
    "@react-three/fiber": "catalog:",
    "@types/three": "catalog:",
    "three": "catalog:"
  },
  "keywords": [
    "three.js",
    "sprites",
    "presets",
    "effects"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thejustinwalsh/three-flatland.git",
    "directory": "packages/presets"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      },
      "./react": {
        "import": {
          "types": "./dist/react.d.ts",
          "default": "./dist/react.js"
        }
      }
    }
  }
}
