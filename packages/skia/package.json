{
  "name": "@three-flatland/skia",
  "version": "0.1.0-alpha.1",
  "description": "Lightweight CanvasKit alternative — Skia's core GPU rendering in ~1 MB of WASM, built with Zig",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/ts/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./three": {
      "source": "./src/ts/three/index.ts",
      "import": {
        "types": "./dist/three/index.d.ts",
        "default": "./dist/three/index.js"
      },
      "require": {
        "types": "./dist/three/index.d.cts",
        "default": "./dist/three/index.cjs"
      }
    },
    "./three/*": {
      "source": "./src/ts/three/*.ts",
      "import": {
        "types": "./dist/three/*.d.ts",
        "default": "./dist/three/*.js"
      },
      "require": {
        "types": "./dist/three/*.d.cts",
        "default": "./dist/three/*.cjs"
      }
    },
    "./react": {
      "source": "./src/ts/react/index.ts",
      "import": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "require": {
        "types": "./dist/react/index.d.cts",
        "default": "./dist/react/index.cjs"
      }
    },
    "./react/*": {
      "source": "./src/ts/react/*.ts",
      "import": {
        "types": "./dist/react/*.d.ts",
        "default": "./dist/react/*.js"
      },
      "require": {
        "types": "./dist/react/*.d.cts",
        "default": "./dist/react/*.cjs"
      }
    },
    "./wasm": "./dist/skia-gl/skia-gl.wasm",
    "./wasm/gl": "./dist/skia-gl/skia-gl.wasm"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "THIRD_PARTY_LICENSES"
  ],
  "sideEffects": false,
  "scripts": {
    "skia:setup": "node scripts/setup.mjs",
    "skia:check": "node scripts/setup.mjs --check",
    "skia:tools": "node scripts/setup.mjs --tools",
    "build": "node scripts/build-wasm.mjs --gl-only --skip-if-fresh && tsup",
    "build:wasm": "node scripts/build-wasm.mjs --gl-only",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tools"
  },
  "peerDependencies": {
    "three": ">=0.170.0",
    "@react-three/fiber": ">=8.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "three": { "optional": true },
    "@react-three/fiber": { "optional": true },
    "react": { "optional": true }
  },
  "devDependencies": {
    "@bytecodealliance/componentize-js": "^0.19.3",
    "@bytecodealliance/jco": "^1.17.6",
    "@react-three/fiber": "catalog:",
