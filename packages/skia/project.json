{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@three-flatland/skia",
  "tags": ["scope:sibling"],
  "targets": {
    "build:wasm": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{projectRoot}/build.zig",
        "{projectRoot}/build.zig.zon",
        "{projectRoot}/src/zig/**/*",
        "{projectRoot}/patches/**/*",
        "{projectRoot}/vendor/**/*",
        "{projectRoot}/wit/**/*",
        "{projectRoot}/scripts/build-wasm.mjs",
        "{projectRoot}/scripts/setup.mjs",
        "{projectRoot}/package.json",
        { "runtime": "git rev-parse HEAD:packages/skia/third_party/skia" }
      ],
      "outputs": ["{projectRoot}/lib/skia-gl.wasm", "{projectRoot}/lib/skia-wgpu.wasm"],
      "options": {
        "command": "node scripts/build-wasm.mjs",
        "cwd": "{projectRoot}"
      }
    }
  }
}
