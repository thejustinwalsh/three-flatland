{
  "name": "@three-flatland/slug",
  "version": "0.1.0-alpha.4",
  "description": "GPU-accelerated resolution-independent font rendering for Three.js via the Slug algorithm",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./react": {
      "source": "./src/react.ts",
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      }
    },
    "./react/*": {
      "source": "./src/react/*.ts",
      "import": {
        "types": "./dist/react/*.d.ts",
        "default": "./dist/react/*.js"
      }
    },
    "./bake": {
      "source": "./src/bake.ts",
      "import": {
        "types": "./dist/bake.d.ts",
        "default": "./dist/bake.js"
      }
    },
    "./pipeline": {
      "source": "./src/pipeline/index.ts",
      "import": {
        "types": "./dist/pipeline/index.d.ts",
        "default": "./dist/pipeline/index.js"
      }
    },
    "./pipeline/*": {
      "source": "./src/pipeline/*.ts",
      "import": {
        "types": "./dist/pipeline/*.d.ts",
        "default": "./dist/pipeline/*.js"
      }
    },
    "./shaders": {
      "source": "./src/shaders/index.ts",
      "import": {
        "types": "./dist/shaders/index.d.ts",
        "default": "./dist/shaders/index.js"
      }
    },
    "./shaders/*": {
      "source": "./src/shaders/*.ts",
      "import": {
        "types": "./dist/shaders/*.d.ts",
        "default": "./dist/shaders/*.js"
      }
    }
  },
  "bin": {
    "slug-bake": "./dist/cli.js"
  },
  "flatland": {
    "bake": [
      {
        "name": "slug",
        "description": "Bake a Slug font sidecar (.slug.glb — pre-parsed glyphs, optional baked strokes)",
        "entry": "./dist/baker.js"
      }
    ]
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "LICENSE",
    "THIRD_PARTY_LICENSES",
    "README.md"
  ],
  "sideEffects": false,
  "nx": {
    "tags": [
      "scope:sibling"
    ],
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vitest run",
          "cwd": "{projectRoot}"
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "oxlint --type-aware .",
          "cwd": "{projectRoot}"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "three": "catalog:"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    }
  },
  "dependencies": {
    "@gltf-transform/core": "catalog:",
    "@three-flatland/bake": "workspace:*",
    "opentype.js": "^1.3.4"
  },
  "devDependencies": {
    "@react-three/fiber": "catalog:",
    "@types/opentype.js": "^1.3.9",
    "@types/react": "catalog:",
    "@types/three": "catalog:",
    "gltf-validator": "^2.0.0-dev.3.10",
    "react": "catalog:",
    "three": "catalog:"
  },
  "keywords": [
    "three.js",
    "tsl",
    "font",
    "text",
    "slug",
    "webgpu",
    "bezier",
    "gpu-rendering"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thejustinwalsh/three-flatland.git",
    "directory": "packages/slug"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      },
      "./react": {
        "import": {
          "types": "./dist/react.d.ts",
          "default": "./dist/react.js"
        }
      },
      "./react/*": {
        "import": {
          "types": "./dist/react/*.d.ts",
          "default": "./dist/react/*.js"
        }
      },
      "./bake": {
        "import": {
          "types": "./dist/bake.d.ts",
          "default": "./dist/bake.js"
        }
      },
      "./pipeline": {
        "import": {
          "types": "./dist/pipeline/index.d.ts",
          "default": "./dist/pipeline/index.js"
        }
      },
      "./pipeline/*": {
        "import": {
          "types": "./dist/pipeline/*.d.ts",
          "default": "./dist/pipeline/*.js"
        }
      },
      "./shaders": {
        "import": {
          "types": "./dist/shaders/index.d.ts",
          "default": "./dist/shaders/index.js"
        }
      },
      "./shaders/*": {
        "import": {
          "types": "./dist/shaders/*.d.ts",
          "default": "./dist/shaders/*.js"
        }
      }
    }
  }
}
