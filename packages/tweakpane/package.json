{
  "name": "@three-flatland/tweakpane",
  "version": "0.1.0-alpha.1",
  "description": "Tweakpane v4 integration for three-flatland examples — theme, helpers, and React hooks",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "source": "./src/react.ts",
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./react/*": {
      "source": "./src/react/*.ts",
      "import": {
        "types": "./dist/react/*.d.ts",
        "default": "./dist/react/*.js"
      },
      "require": {
        "types": "./dist/react/*.d.cts",
        "default": "./dist/react/*.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@react-three/fiber": "^10.0.0-alpha.2",
    "@tweakpane/plugin-essentials": "^0.2.1",
    "react": "^19.0.0",
    "three": "^0.183.0",
    "tweakpane": "^4.0.5"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    },
    "three": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-three/fiber": "catalog:",
    "@tweakpane/core": "catalog:",
    "@tweakpane/plugin-essentials": "catalog:",
    "@types/react": "catalog:",
    "@types/three": "catalog:",
    "react": "catalog:",
    "three": "catalog:",
    "tweakpane": "catalog:",
    "typescript": "catalog:"
  },
  "keywords": [
    "three.js",
    "tweakpane",
    "debug",
    "controls",
    "webgpu"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thejustinwalsh/three-flatland.git",
    "directory": "packages/tweakpane"
  }
}
