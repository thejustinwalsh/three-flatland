{
  "name": "@three-flatland/uikit-default",
  "version": "0.1.0-alpha.0",
  "description": "Default (shadcn) component kit for @three-flatland/uikit",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "source": "./src/react.ts",
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./react/*": {
      "source": "./src/react/*.ts",
      "import": {
        "types": "./dist/react/*.d.ts",
        "default": "./dist/react/*.js"
      },
      "require": {
        "types": "./dist/react/*.d.cts",
        "default": "./dist/react/*.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "three": "catalog:"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    }
  },
  "dependencies": {
    "@three-flatland/uikit": "workspace:*",
    "@three-flatland/uikit-lucide": "workspace:*",
    "@preact/signals-core": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@react-three/fiber": "catalog:",
    "@types/react": "catalog:",
    "@types/three": "catalog:",
    "happy-dom": "^20.8.9",
    "react": "catalog:",
    "three": "catalog:",
    "yoga-layout": "catalog:"
  },
  "keywords": [
    "three.js",
    "tsl",
    "uikit",
    "shadcn",
    "flexbox",
    "yoga",
    "webgpu"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thejustinwalsh/three-flatland.git",
    "directory": "packages/uikit-default"
  }
}
