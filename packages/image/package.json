{
  "name": "@three-flatland/image",
  "version": "0.1.0-alpha.1",
  "description": "WASM image encoder package — PNG/WebP/AVIF/KTX2 with browser+Node+CLI surfaces",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thejustinwalsh/three-flatland.git",
    "directory": "packages/image"
  },
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "node": {
        "types": "./dist/node.d.ts",
        "import": "./dist/node.js"
      },
      "browser": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "default": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "./node": {
      "source": "./src/node.ts",
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./cli": {
      "source": "./src/cli.ts",
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    },
    "./loaders/ktx2": {
      "source": "./src/loaders/Ktx2Loader.ts",
      "types": "./dist/loaders/Ktx2Loader.d.ts",
      "import": "./dist/loaders/Ktx2Loader.js"
    }
  },
  "peerDependencies": {
    "three": "catalog:"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/libs",
    "libs"
  ],
  "sideEffects": false,
  "nx": {
    "tags": [
      "scope:sibling"
    ],
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vitest run",
          "cwd": "{projectRoot}"
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "oxlint --type-aware .",
          "cwd": "{projectRoot}"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "build:wasm": "PATH=\"$PWD/node_modules/.bin:$PATH\" zig build",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@jsquash/avif": "catalog:",
    "@jsquash/png": "catalog:",
    "@jsquash/webp": "catalog:",
    "@three-flatland/bake": "workspace:*",
    "uwasi": "catalog:"
  },
  "devDependencies": {
    "@types/three": "catalog:",
    "binaryen": "^123.0.0",
    "three": "catalog:"
  },
  "flatland": {
    "bake": [
      {
        "name": "encode",
        "description": "Encode image to PNG/WebP/AVIF/KTX2",
        "entry": "./dist/cli.js"
      }
    ]
  },
  "publishConfig": {
    "exports": {
      ".": {
        "node": {
          "types": "./dist/node.d.ts",
          "import": "./dist/node.js"
        },
        "browser": {
          "types": "./dist/index.d.ts",
          "import": "./dist/index.js"
        },
        "default": {
          "types": "./dist/index.d.ts",
          "import": "./dist/index.js"
        }
      },
      "./node": {
        "types": "./dist/node.d.ts",
        "import": "./dist/node.js"
      },
      "./cli": {
        "types": "./dist/cli.d.ts",
        "import": "./dist/cli.js"
      },
      "./loaders/ktx2": {
        "types": "./dist/loaders/Ktx2Loader.d.ts",
        "import": "./dist/loaders/Ktx2Loader.js"
      }
    }
  }
}
