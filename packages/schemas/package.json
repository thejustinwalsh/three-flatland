{
  "name": "@three-flatland/schemas",
  "version": "1.0.0",
  "private": true,
  "description": "JSON Schemas + Ajv validators for three-flatland data formats. Tool/dev-time only — no runtime consumers in three-flatland.",
  "type": "module",
  "exports": {
    "./atlas": {
      "source": "./src/atlas/index.ts",
      "import": {
        "types": "./dist/atlas/index.d.ts",
        "default": "./dist/atlas/index.js"
      }
    },
    "./normal-descriptor": {
      "source": "./src/normal-descriptor/index.ts",
      "import": {
        "types": "./dist/normal-descriptor/index.d.ts",
        "default": "./dist/normal-descriptor/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "nx": {
    "tags": [
      "scope:foundation"
    ],
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vitest run",
          "cwd": "{projectRoot}"
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "oxlint --type-aware .",
          "cwd": "{projectRoot}"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "ts-json-schema-generator": "catalog:"
  }
}
