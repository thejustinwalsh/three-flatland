{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "@three-flatland/devtools",
  "tags": ["scope:consumer"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "vitest run", "cwd": "{projectRoot}" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "oxlint --type-aware .", "cwd": "{projectRoot}" }
    }
  }
}
