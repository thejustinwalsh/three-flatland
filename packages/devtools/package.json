{
  "name": "@three-flatland/devtools",
  "version": "1.0.0-alpha.4",
  "description": "Dev-time introspection toolkit for three-flatland — Tweakpane v4 UI plugin, stats monitor, and buffer inspection",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./react": {
      "source": "./src/react.ts",
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      }
    },
    "./react/*": {
      "source": "./src/react/*.ts",
      "import": {
        "types": "./dist/react/*.d.ts",
        "default": "./dist/react/*.js"
      }
    },
    "./vite": {
      "source": "./src/vite-plugin.ts",
      "import": {
        "types": "./dist/vite-plugin.d.ts",
        "default": "./dist/vite-plugin.js"
      }
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "nx": {
    "tags": [
      "scope:consumer"
    ],
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "vitest run",
          "cwd": "{projectRoot}"
        }
      },
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "oxlint --type-aware .",
          "cwd": "{projectRoot}"
        }
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "build:bundle": "vite build --config vite.config.bundle.ts",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/dashboard/tsconfig.json",
    "clean": "rm -rf dist bundle"
  },
  "peerDependencies": {
    "@react-three/fiber": "^10.0.0-alpha.2",
    "@tweakpane/plugin-essentials": "^0.2.1",
    "react": "^19.2.0",
    "three": "^0.183.0",
    "three-flatland": "^0.1.0-alpha.7",
    "tweakpane": "^4.0.5",
    "vite": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    },
    "three": {
      "optional": true
    },
    "three-flatland": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-three/fiber": "catalog:",
    "@testing-library/react": "^16.1.0",
    "@tweakpane/core": "catalog:",
    "@tweakpane/plugin-essentials": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/three": "catalog:",
    "happy-dom": "^20.8.9",
    "react": "catalog:",
    "react-dom": "catalog:",
    "three": "catalog:",
    "three-flatland": "workspace:*",
    "tweakpane": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "keywords": [
    "three.js",
    "tweakpane",
    "debug",
    "controls",
    "webgpu"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thejustinwalsh/three-flatland.git",
    "directory": "packages/devtools"
  },
  "bin": {
    "flatland-devtools-relay": "./dist/relay.js"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        }
      },
      "./react": {
        "import": {
          "types": "./dist/react.d.ts",
          "default": "./dist/react.js"
        }
      },
      "./react/*": {
        "import": {
          "types": "./dist/react/*.d.ts",
          "default": "./dist/react/*.js"
        }
      },
      "./vite": {
        "import": {
          "types": "./dist/vite-plugin.d.ts",
          "default": "./dist/vite-plugin.js"
        }
      }
    }
  }
}
