{
  "name": "@three-flatland/mini-driller",
  "private": true,
  "version": "0.0.1-alpha.0",
  "description": "Driller Homie — Mr. Driller × tamagotchi mini-game for the docs hero",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite build --config vite.lib.config.ts --watch",
    "dev:app": "vite dev --port ${TURBO_MFE_PORT:-5210}",
    "build": "vite build --config vite.lib.config.ts && tsc --project tsconfig.build.json",
    "build:app": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --ignore-pattern 'tests/integration/probes/**'",
    "lint:fix": "eslint src tests --ignore-pattern 'tests/integration/probes/**' --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@three-flatland/devtools": "^1.0.0-alpha.4",
    "@three-flatland/nodes": "^0.1.0-alpha.7",
    "@three-flatland/presets": "^0.1.0-alpha.7",
    "@tweakpane/plugin-essentials": "^0.2.1",
    "koota": "^0.6.5",
    "three-flatland": "^0.1.0-alpha.7",
    "tweakpane": "^4.0.5",
    "zzfx": "^1.3.2"
  },
  "peerDependencies": {
    "@react-three/fiber": "10.0.0-alpha.2",
    "react": "^19.2.0",
    "three": "^0.183.1"
  },
  "devDependencies": {
    "@react-three/fiber": "10.0.0-alpha.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.33.5",
    "three": "^0.183.1",
    "tsup": "^8.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.4.3",
    "vitest": "^3.0.0",
    "vitexec": "^0.1.18"
  },
  "keywords": [
    "three.js",
    "mini-game",
    "driller",
    "arcade",
    "ecs",
    "koota"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thejustinwalsh/three-flatland.git",
    "directory": "minis/driller"
  }
}
