    {
      "type": "text",
      "id": "s4_node_t",
      "x": 758,
      "y": 1040,
      "width": 524,
      "height": 108,
      "text": "let color = baseColor\nfor (const { effect, bitIndex } of effects) {\n  const enabled = mod(floor(enableBits / (1<<bitIndex)), 2)\n  const result  = effect.node({ color, uv })\n  color = mix(color, result, enabled)   // branchless gate\n}",
      "originalText": "let color = baseColor\nfor (const { effect, bitIndex } of effects) {\n  const enabled = mod(floor(enableBits / (1<<bitIndex)), 2)\n  const result  = effect.node({ color, uv })\n  color = mix(color, result, enabled)   // branchless gate\n}",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#e6edf3",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 140304,
