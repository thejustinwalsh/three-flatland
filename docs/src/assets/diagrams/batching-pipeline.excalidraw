    {
      "type": "text",
      "id": "flush-txt",
      "x": 56.69183783844778,
      "y": 1121.197850307524,
      "width": 1140,
      "height": 122.5,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 1058,
      "version": 35,
      "versionNonce": 1686058845,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1779046254025,
      "link": null,
      "locked": false,
      "fontSize": 14,
      "fontFamily": 3,
      "text": "markDirty(slot):  b = slot >>> 8   \u2192   bucketState[b] = min,  bucketLastSlot[b] = max     (~5 ns,  no allocs)\n\nflush()  decides per-attr threshold:\n    dirtyBuckets \u2265 threshold   \u2192   clearUpdateRanges() + needsUpdate     \u2192  three picks bufferData fast-path (1 upload)\n    else                        \u2192   one addUpdateRange(first*stride, (last-first+1)*stride) per dirty bucket\n\nThresholds:  matrix = 5    interleaved = 3    custom (effectBuf) = 3        Bucket = 256  (power of 2)",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "markDirty(slot):  b = slot >>> 8   \u2192   bucketState[b] = min,  bucketLastSlot[b] = max     (~5 ns,  no allocs)\n\nflush()  decides per-attr threshold:\n    dirtyBuckets \u2265 threshold   \u2192   clearUpdateRanges() + needsUpdate     \u2192  three picks bufferData fast-path (1 upload)\n    else                        \u2192   one addUpdateRange(first*stride, (last-first+1)*stride) per dirty bucket\n\nThresholds:  matrix = 5    interleaved = 3    custom (effectBuf) = 3        Bucket = 256  (power of 2)",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 12,
      "index": "ax"
    },
    {
      "type": "text",
      "id": "title-4",
