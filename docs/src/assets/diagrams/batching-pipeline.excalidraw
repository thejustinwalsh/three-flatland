      "text": "sprite.addEffect(Dissolve)   \u2192   _effectFlags |= (1 << bitIdx)   \u2192   mesh.writeEnableBits(slot, flags)\nsprite.removeEffect(Dissolve)  \u2192  _effectFlags &= ~(1 << bitIdx)   \u2192   mesh.writeEnableBits(slot, flags)\n\n  // 1 float write into the interleaved buffer.  No rebuilds.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "sprite.addEffect(Dissolve)   \u2192   _effectFlags |= (1 << bitIdx)   \u2192   mesh.writeEnableBits(slot, flags)\nsprite.removeEffect(Dissolve)  \u2192  _effectFlags &= ~(1 << bitIdx)   \u2192   mesh.writeEnableBits(slot, flags)\n\n  // 1 float write into the interleaved buffer.  No rebuilds.",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 12,
      "index": "b08"
    },
