    {
      "type": "text",
      "id": "gpu-3-t",
      "x": 658.5198976202533,
      "y": 2493.7461929166234,
      "width": 565,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
