      "fontSize": 14,
      "fontFamily": 3,
      "text": "\u2461 Pipeline + vertex bindings\n\n  1 pipeline state per material\n  (effect toggles \u2260 pipeline rebuild)\n\n  8 vertex buffers bound:\n  3 geom + matrix + interleaved core + effectBuf0..2",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\u2461 Pipeline + vertex bindings\n\n  1 pipeline state per material\n  (effect toggles \u2260 pipeline rebuild)\n\n  8 vertex buffers bound:\n  3 geom + matrix + interleaved core + effectBuf0..2",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 12,
      "index": "b0P"
    },
