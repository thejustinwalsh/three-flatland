      "link": null,
      "locked": false,
      "fontSize": 14,
      "fontFamily": 5,
      "text": "WebGPU cap: 8 vertex bindings\n\n  3 (geom) + 1 (matrix) + 1 (interleaved)\n+ 3 (effectBuf0..2)  =  8 \u2713\n\nInterleaving collapsed 4 attrs \u2192 1 binding,\nfreeing 3 slots for effectBuf*.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "callout-1",
      "originalText": "WebGPU cap: 8 vertex bindings\n\n  3 (geom) + 1 (matrix) + 1 (interleaved)\n+ 3 (effectBuf0..2)  =  8 \u2713\n\nInterleaving collapsed 4 attrs \u2192 1 binding,\nfreeing 3 slots for effectBuf*.",
      "autoResize": true,
      "lineHeight": 1.25,
      "baseline": 12,
      "index": "aX"
    },
