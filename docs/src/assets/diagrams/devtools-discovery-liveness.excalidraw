    { "type": "text", "id": "noteCt", "x": 180, "y": 744, "width": 320, "height": 48, "text": "no server msg for SERVER_LIVENESS_MS =\n5000 ms → presume gone, re-subscribe", "originalText": "no server msg for SERVER_LIVENESS_MS =\n5000 ms → presume gone, re-subscribe", "fontSize": 13, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#e6edf3", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 330003, "version": 1, "versionNonce": 330004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "noteC", "lineHeight": 1.25 },

