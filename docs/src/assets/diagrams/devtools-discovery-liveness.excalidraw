    { "type": "text", "id": "gatenotet", "x": 440, "y": 462, "width": 540, "height": 40, "text": "provider now collects only the subscribed features —\ncollapse a panel, the work stops", "originalText": "provider now collects only the subscribed features —\ncollapse a panel, the work stops", "fontSize": 13, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#e6edf3", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 320023, "version": 1, "versionNonce": 320024, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "gatenote", "lineHeight": 1.25 },

