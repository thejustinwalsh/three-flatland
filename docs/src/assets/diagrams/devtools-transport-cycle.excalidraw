  "elements": [
    { "type": "text", "id": "title", "x": 40, "y": 28, "width": 1000, "height": 36, "text": "The zero-allocation transport cycle", "originalText": "The zero-allocation transport cycle", "fontSize": 28, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#a85ff1", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 400001, "version": 1, "versionNonce": 400002, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "subtitle", "x": 40, "y": 72, "width": 780, "height": 44, "text": "One pool buffer makes the round trip every flush. The render thread avoids the\nexpensive structured clone; the worker runs it, once per subscriber.", "originalText": "One pool buffer makes the round trip every flush. The render thread avoids the\nexpensive structured clone; the worker runs it, once per subscriber.", "fontSize": 15, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#9aa7b0", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 400003, "version": 1, "versionNonce": 400004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

    { "type": "text", "id": "laneA", "x": 40, "y": 122, "width": 400, "height": 22, "text": "RENDER THREAD  ·  producer", "originalText": "RENDER THREAD  ·  producer", "fontSize": 16, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#c7910c", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 400005, "version": 1, "versionNonce": 400006, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

    { "type": "rectangle", "id": "p1", "x": 60, "y": 152, "width": 320, "height": 104, "strokeColor": "#c7910c", "backgroundColor": "#211c12", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 410001, "version": 1, "versionNonce": 410002, "isDeleted": false, "groupIds": [], "boundElements": [{"id": "p1t", "type": "text"}, {"id": "a_p1p2", "type": "arrow"}], "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "p1t", "x": 70, "y": 170, "width": 300, "height": 68, "text": "endFrame\none sample → pre-allocated ring\nno allocation", "originalText": "endFrame\none sample → pre-allocated ring\nno allocation", "fontSize": 15, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#e6edf3", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 410003, "version": 1, "versionNonce": 410004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "p1", "lineHeight": 1.25 },

    { "type": "rectangle", "id": "p2", "x": 420, "y": 152, "width": 480, "height": 104, "strokeColor": "#c7910c", "backgroundColor": "#211c12", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 410005, "version": 1, "versionNonce": 410006, "isDeleted": false, "groupIds": [], "boundElements": [{"id": "p2t", "type": "text"}, {"id": "a_p1p2", "type": "arrow"}, {"id": "a_p2p3", "type": "arrow"}, {"id": "a_bounce", "type": "arrow"}], "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "p2t", "x": 430, "y": 162, "width": 460, "height": 84, "text": "flush @ 250 ms  (STATS_BATCH_MS)\nacquireMedium() → memcpy ring snapshot\ntyped-array views over the pool buffer", "originalText": "flush @ 250 ms  (STATS_BATCH_MS)\nacquireMedium() → memcpy ring snapshot\ntyped-array views over the pool buffer", "fontSize": 15, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#e6edf3", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 410007, "version": 1, "versionNonce": 410008, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "p2", "lineHeight": 1.25 },

    { "type": "rectangle", "id": "p3", "x": 940, "y": 152, "width": 340, "height": 104, "strokeColor": "#c7910c", "backgroundColor": "#211c12", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 410009, "version": 1, "versionNonce": 410010, "isDeleted": false, "groupIds": [], "boundElements": [{"id": "p3t", "type": "text"}, {"id": "a_p2p3", "type": "arrow"}, {"id": "a_p3w1", "type": "arrow"}], "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "p3t", "x": 950, "y": 178, "width": 320, "height": 52, "text": "worker.postMessage(msg, [poolBuf])\ntransfer — zero-copy", "originalText": "worker.postMessage(msg, [poolBuf])\ntransfer — zero-copy", "fontSize": 15, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#e6edf3", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 410011, "version": 1, "versionNonce": 410012, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "p3", "lineHeight": 1.25 },

    { "type": "text", "id": "laneB", "x": 40, "y": 340, "width": 400, "height": 22, "text": "WORKER  ·  bus offload", "originalText": "WORKER  ·  bus offload", "fontSize": 16, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#a85ff1", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 400007, "version": 1, "versionNonce": 400008, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

