    { "type": "text", "id": "c1t", "x": 830, "y": 636, "width": 440, "height": 52, "text": "BroadcastChannel delivers to each subscriber\nits own structured-clone copy", "originalText": "BroadcastChannel delivers to each subscriber\nits own structured-clone copy", "fontSize": 15, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#e6edf3", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 430003, "version": 1, "versionNonce": 430004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "c1", "lineHeight": 1.25 },

