    { "type": "text", "id": "w1t", "x": 850, "y": 388, "width": 420, "height": 68, "text": "bc.postMessage(msg)\nStructuredSerialize — the clone runs\non the worker, not the render thread", "originalText": "bc.postMessage(msg)\nStructuredSerialize — the clone runs\non the worker, not the render thread", "fontSize": 15, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#e6edf3", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 420003, "version": 1, "versionNonce": 420004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "w1", "lineHeight": 1.25 },

    { "type": "rectangle", "id": "w2", "x": 360, "y": 370, "width": 400, "height": 104, "strokeColor": "#00a884", "backgroundColor": "#11201a", "fillStyle": "solid", "strokeWidth": 2, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 420005, "version": 1, "versionNonce": 420006, "isDeleted": false, "groupIds": [], "boundElements": [{"id": "w2t", "type": "text"}, {"id": "a_w1w2", "type": "arrow"}, {"id": "a_bounce", "type": "arrow"}], "link": null, "locked": false, "roundness": {"type": 3} },
    { "type": "text", "id": "w2t", "x": 370, "y": 396, "width": 380, "height": 52, "text": "postMessage({__release__, buf}, [buf])\nbounce pool buffer back to producer", "originalText": "postMessage({__release__, buf}, [buf])\nbounce pool buffer back to producer", "fontSize": 15, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#e6edf3", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 420007, "version": 1, "versionNonce": 420008, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "w2", "lineHeight": 1.25 },

    { "type": "text", "id": "laneC", "x": 40, "y": 578, "width": 400, "height": 22, "text": "CONSUMERS  ·  many, per-provider channel", "originalText": "CONSUMERS  ·  many, per-provider channel", "fontSize": 16, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#11b7d4", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 400009, "version": 1, "versionNonce": 400010, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

