    { "type": "text", "id": "c2t", "x": 310, "y": 636, "width": 440, "height": 52, "text": "decode Int16 / Uint16 / Uint32\n→ Float32 rings, keyed by startFrame", "originalText": "decode Int16 / Uint16 / Uint32\n→ Float32 rings, keyed by startFrame", "fontSize": 15, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#e6edf3", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 430007, "version": 1, "versionNonce": 430008, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "c2", "lineHeight": 1.25 },

    { "type": "text", "id": "cbounce", "x": 360, "y": 486, "width": 400, "height": 20, "text": "pool buffer reused every flush — never reallocated", "originalText": "pool buffer reused every flush — never reallocated", "fontSize": 13, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#00a884", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 400011, "version": 1, "versionNonce": 400012, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

