    { "type": "text", "id": "poolt", "x": 76, "y": 786, "width": 1188, "height": 64, "text": "buffer pool — allocated once in the worker, transferred to the producer at boot:\n  small 4 KB ×8    ·    medium 256 KB ×4  (per-flush data packet)    ·    large 16 MB ×4  (texture readback)", "originalText": "buffer pool — allocated once in the worker, transferred to the producer at boot:\n  small 4 KB ×8    ·    medium 256 KB ×4  (per-flush data packet)    ·    large 16 MB ×4  (texture readback)", "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#e6edf3", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 440003, "version": 1, "versionNonce": 440004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "poolbox", "lineHeight": 1.25 },

