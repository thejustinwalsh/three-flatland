    { "type": "text", "id": "b1t", "x": 70, "y": 190, "width": 340, "height": 60, "text": "endFrame readback\nRenderTarget / DataTexture\nlarge 16 MB pool buffer", "originalText": "endFrame readback\nRenderTarget / DataTexture\nlarge 16 MB pool buffer", "fontSize": 15, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#e6edf3", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 610003, "version": 1, "versionNonce": 610004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "b1", "lineHeight": 1.25 },

