    { "type": "text", "id": "fidcallout", "x": 60, "y": 480, "width": 620, "height": 18, "text": "every chunk carries frame — bound to the render frame (Figure 2)", "originalText": "every chunk carries frame — bound to the render frame (Figure 2)", "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#00a884", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 600005, "version": 1, "versionNonce": 600006, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

