  "elements": [
    { "type": "text", "id": "title", "x": 40, "y": 28, "width": 1100, "height": 36, "text": "Compressed buffer streaming with WebCodecs", "originalText": "Compressed buffer streaming with WebCodecs", "fontSize": 28, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#a85ff1", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 600001, "version": 1, "versionNonce": 600002, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },
    { "type": "text", "id": "subtitle", "x": 40, "y": 72, "width": 1240, "height": 22, "text": "Raw RGBA8 readbacks are too large to ship per frame, so the buffer channel carries video — each frame still tagged with its render frame.", "originalText": "Raw RGBA8 readbacks are too large to ship per frame, so the buffer channel carries video — each frame still tagged with its render frame.", "fontSize": 15, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top", "strokeColor": "#9aa7b0", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 600003, "version": 1, "versionNonce": 600004, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25 },

