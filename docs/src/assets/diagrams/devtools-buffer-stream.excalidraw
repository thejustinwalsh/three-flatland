    { "type": "text", "id": "b5t", "x": 470, "y": 390, "width": 340, "height": 40, "text": "BroadcastChannel\nper-provider data channel", "originalText": "BroadcastChannel\nper-provider data channel", "fontSize": 15, "fontFamily": 3, "textAlign": "center", "verticalAlign": "middle", "strokeColor": "#e6edf3", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0, "seed": 610019, "version": 1, "versionNonce": 610020, "isDeleted": false, "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": "b5", "lineHeight": 1.25 },

