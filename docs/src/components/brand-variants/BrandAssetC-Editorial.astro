---
import BrandIcon from '../BrandIcon.astro'

interface Props {
    id: string
    type: 'banner' | 'og' | 'wide' | 'social-x' | 'icon-only'
    title?: string
    tagline?: string
    info?: boolean
    isCapture?: boolean
}

const {
    id,
    type,
    title = 'flatland',
    tagline = 'Sprite-first 2D for Three.js + R3F. WebGPU-native.',
    info = true,
    isCapture = false,
} = Astro.props

interface Dimensions {
    w: number
    h: number
}

const dimensions: Record<Props['type'], Dimensions> = {
    banner: { w: 1280, h: 640 },
    og: { w: 1200, h: 630 },
    wide: { w: 3000, h: 1000 },
    'social-x': { w: 1200, h: 628 },
    'icon-only': { w: 512, h: 512 },
}

const { w: width, h: height } = dimensions[type] ?? dimensions['og']
const showInfo = info && type !== 'icon-only'
const isWide = type === 'wide'
const isIconOnly = type === 'icon-only'

const repoLine = 'thejustinwalsh/three-flatland'
const installLine = '# npm i three-flatland@alpha'

// Decorative typographic ghost — set huge in thin Public Sans behind the wordmark.
// Reads as a printer's watermark / mid-century imprint slug.
const ghostWord = 'TWO·D'

// Masthead-style top eyebrow text.
const topRule = 'A FLATLAND IMPRINT · VOLUME 01'
const bottomRule = 'EST · MMXXVI'
---

<div
    class:list={['brand-asset-root', 'editorial-variant', 'not-content', type, { 'capture-mode': isCapture }]}
    id={id}
    style={`--asset-width: ${width}; --asset-height: ${height};`}
>
    {/* Sub-perceptual paper-grain noise overlay. Multiplicative to read as paper stock. */}
    <div class="ed-paper" aria-hidden="true"></div>

    {/* Warm gold cast — the page is lit from a single warm source. */}
    <div class="ed-cast" aria-hidden="true"></div>

    {/* Ornamental top + bottom gold double-rule frames with center diamond ornament. */}
    {!isIconOnly && (
        <>
            <svg class="ed-rule ed-rule-top" viewBox="0 0 1000 24" preserveAspectRatio="none" aria-hidden="true">
                <line x1="0" y1="6" x2="430" y2="6" class="ed-rule-line" />
                <line x1="570" y1="6" x2="1000" y2="6" class="ed-rule-line" />
                <line x1="0" y1="14" x2="380" y2="14" class="ed-rule-line ed-rule-thin" />
                <line x1="620" y1="14" x2="1000" y2="14" class="ed-rule-line ed-rule-thin" />
                <g transform="translate(500 10)">
                    <polygon points="0,-7 7,0 0,7 -7,0" class="ed-orn-fill" />
                    <polygon points="0,-3 3,0 0,3 -3,0" class="ed-orn-inner" />
                </g>
            </svg>

            <svg class="ed-rule ed-rule-bottom" viewBox="0 0 1000 24" preserveAspectRatio="none" aria-hidden="true">
                <line x1="0" y1="10" x2="430" y2="10" class="ed-rule-line" />
                <line x1="570" y1="10" x2="1000" y2="10" class="ed-rule-line" />
                <line x1="0" y1="18" x2="380" y2="18" class="ed-rule-line ed-rule-thin" />
                <line x1="620" y1="18" x2="1000" y2="18" class="ed-rule-line ed-rule-thin" />
                <g transform="translate(500 14)">
                    <polygon points="0,-7 7,0 0,7 -7,0" class="ed-orn-fill" />
                    <polygon points="0,-3 3,0 0,3 -3,0" class="ed-orn-inner" />
                </g>
            </svg>
        </>
    )}

    {/* Decorative ghost typography — TWO·D set XL in thin Public Sans, semi-transparent. */}
    {!isIconOnly && (
        <div class="ed-ghost" aria-hidden="true">{ghostWord}</div>
    )}

    {/* Wax-stamp / hot-foil seal — circular text + center gem motif. */}
    {!isIconOnly && (
        <div class="ed-seal" aria-hidden="true">
            <svg viewBox="0 0 200 200">
                <defs>
                    <path id={`ed-seal-path-${id}`} d="M 100,100 m -76,0 a 76,76 0 1,1 152,0 a 76,76 0 1,1 -152,0" />
                </defs>
                <circle cx="100" cy="100" r="92" class="ed-seal-ring ed-seal-ring-outer" />
                <circle cx="100" cy="100" r="84" class="ed-seal-ring ed-seal-ring-inner" />
                <text class="ed-seal-text">
                    <textPath href={`#ed-seal-path-${id}`} startOffset="0%">
                        EST · MMXXVI · ALPHA · TSL · WEBGPU · EST · MMXXVI · ALPHA · TSL · WEBGPU ·
                    </textPath>
                </text>
                <g transform="translate(100 100)">
                    <polygon points="0,-18 18,0 0,18 -18,0" class="ed-seal-gem" />
                    <polygon points="0,-9 9,0 0,9 -9,0" class="ed-seal-gem-inner" />
                </g>
            </svg>
        </div>
    )}

    <div class="ed-content">
        {isIconOnly ? (
            <div class="ed-icon-only-frame">
                {/* Embossed circular plate — printer's mark register. */}
                <div class="ed-icon-plate" aria-hidden="true"></div>
                <BrandIcon size="56%" />
            </div>
        ) : (
            <Fragment>
                {/* Masthead eyebrow — magazine top-line. */}
                <div class="ed-eyebrow" aria-hidden="true">
                    <span>{topRule}</span>
                </div>

                <div class:list={['ed-stack', { 'ed-stack-wide': isWide }]}>
                    {/* Icon as a printer's woodcut mark — small, contained, deliberate. */}
                    <div class="ed-mark">
                        <BrandIcon size={isWide ? '11cqi' : '15cqi'} />
                    </div>

                    <div class="ed-text">
                        {/* Gold-leaf stamped Silkscreen wordmark. */}
                        <h1 class="ed-wordmark"><span class="ed-wordmark-leaf">{title}</span></h1>

                        {/* Tagline as deck — italic small caps register via Public Sans. */}
                        <p class="ed-tagline">{tagline}</p>

                        {isWide && showInfo && (
                            <div class="ed-info ed-info-inline">
                                <span class="ed-chip ed-chip-diamond">{repoLine}</span>
                                <span class="ed-chip-sep">·</span>
                                <span class="ed-chip ed-chip-gold">{installLine}</span>
                            </div>
                        )}
                    </div>
                </div>

                {/* Bottom colophon — wide-margin info row, copyright register. */}
                {showInfo && !isWide && (
                    <div class="ed-info ed-info-row">
                        <span class="ed-chip ed-chip-diamond">{repoLine}</span>
                        <span class="ed-chip-sep">·</span>
                        <span class="ed-chip ed-chip-gold">{installLine}</span>
                    </div>
                )}

                {!showInfo && !isWide && (
                    <div class="ed-info ed-info-row ed-info-fallback">
                        <span class="ed-chip ed-chip-mute">{bottomRule}</span>
                    </div>
                )}
            </Fragment>
        )}
    </div>
</div>

<style>
    /* Editorial variant — gold-leaf book cover register. Tokens scoped locally
     * so capture mode renders identically to live preview. */
    .editorial-variant.brand-asset-root {
        --tf-bg: #14110c;
        --tf-bg-2: #1b1812;
        --tf-paper-warm: rgba(241, 196, 95, 0.06);
        --tf-fg: #f3ecd9;
        --tf-fg-muted: #b6a98a;
        --tf-fg-quiet: #7a6f56;

        /* Gold-leaf gradient stops — light → deep → light suggests brushed metal. */
        --tf-gold-pale: #ffe39a;
        --tf-gold: #f1c45f;
        --tf-gold-deep: #a17a26;
        --tf-gold-shadow: #4a3a14;
        --tf-gold-soft: rgba(241, 196, 95, 0.18);

        --tf-diamond: #6cb8ff;
        --tf-amethyst: #b88af7;
        --tf-rule: rgba(241, 196, 95, 0.55);
        --tf-rule-thin: rgba(241, 196, 95, 0.28);

        position: relative;
        overflow: hidden;
        color: var(--tf-fg);
        background:
            radial-gradient(120% 80% at 50% 0%, var(--tf-bg-2) 0%, var(--tf-bg) 70%),
            var(--tf-bg);
        container-type: inline-size;

        font-family: 'Public Sans', system-ui, sans-serif;
        font-feature-settings: 'ss01';

        width: calc(var(--asset-width) * 1px);
        height: calc(var(--asset-height) * 1px);
        aspect-ratio: var(--asset-width) / var(--asset-height);
    }

    :not(.capture-mode).editorial-variant.brand-asset-root {
        width: 100%;
        height: auto;
    }

    /* --- Substrate layers --- */

    .ed-paper {
        position: absolute;
        inset: 0;
        opacity: 0.06;
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='240' height='240'><filter id='p'><feTurbulence type='fractalNoise' baseFrequency='0.92' numOctaves='2' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.95 0 0 0 0 0.85 0 0 0 0 0.6 0 0 0 0.55 0'/></filter><rect width='100%25' height='100%25' filter='url(%23p)'/></svg>");
        background-size: 240px 240px;
        mix-blend-mode: multiply;
        z-index: 1;
        pointer-events: none;
    }

    .ed-cast {
        position: absolute;
        inset: 0;
        background:
            radial-gradient(80% 60% at 50% 38%, var(--tf-paper-warm) 0%, transparent 70%),
            radial-gradient(40% 30% at 12% 88%, rgba(108, 184, 255, 0.05) 0%, transparent 70%);
        z-index: 1;
        pointer-events: none;
    }

    /* --- Ornamental gold rules — top + bottom of canvas --- */

    .ed-rule {
        position: absolute;
        left: 6cqi;
        right: 6cqi;
        height: 3cqi;
        z-index: 2;
        pointer-events: none;
    }
    .ed-rule-top { top: 4cqi; }
    .ed-rule-bottom { bottom: 4cqi; }

    .ed-rule-line {
        stroke: var(--tf-rule);
        stroke-width: 1.5;
        vector-effect: non-scaling-stroke;
    }
    .ed-rule-line.ed-rule-thin {
        stroke: var(--tf-rule-thin);
        stroke-width: 0.75;
    }
    .ed-orn-fill {
        fill: var(--tf-gold);
    }
    .ed-orn-inner {
        fill: var(--tf-gold-pale);
    }

    /* --- Decorative ghost typography behind the wordmark --- */

    .ed-ghost {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Public Sans', system-ui, sans-serif;
        font-weight: 200;
        font-size: 38cqi;
        line-height: 1;
        letter-spacing: -0.04em;
        color: transparent;
        -webkit-text-stroke: 1px color-mix(in oklab, var(--tf-gold) 20%, transparent);
        opacity: 0.55;
        z-index: 1;
        pointer-events: none;
        user-select: none;
        white-space: nowrap;
    }
    .wide.editorial-variant .ed-ghost {
        font-size: 22cqi;
        justify-content: flex-end;
        padding-right: 8cqi;
    }
    .social-x.editorial-variant .ed-ghost {
        font-size: 42cqi;
    }

    /* --- Wax-stamp / hot-foil seal — corner ornament --- */

    .ed-seal {
        position: absolute;
        bottom: 8cqi;
        right: 7cqi;
        width: 12cqi;
        height: 12cqi;
        z-index: 3;
        pointer-events: none;
        opacity: 0.85;
        filter: drop-shadow(0 0.4cqi 0.8cqi rgba(0, 0, 0, 0.55));
    }
    .wide.editorial-variant .ed-seal {
        width: 7cqi;
        height: 7cqi;
        bottom: 12cqi;
        right: 6cqi;
    }
    .ed-seal svg {
        width: 100%;
        height: 100%;
        display: block;
    }
    .ed-seal-ring {
        fill: none;
        stroke: var(--tf-gold);
        stroke-width: 1;
        vector-effect: non-scaling-stroke;
    }
    .ed-seal-ring-inner {
        stroke: var(--tf-gold-deep);
        stroke-width: 0.5;
    }
    .ed-seal-text {
        fill: var(--tf-gold-pale);
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.18em;
    }
    .ed-seal-gem {
        fill: var(--tf-gold);
    }
    .ed-seal-gem-inner {
        fill: var(--tf-gold-pale);
    }

    /* --- Content layout — generous gutters, magazine masthead vibe --- */

    .ed-content {
        position: relative;
        z-index: 4;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 11cqi 10cqi;
        box-sizing: border-box;
        gap: 4cqi;
    }
    .wide.editorial-variant .ed-content {
        padding: 9cqi 8cqi;
        gap: 2cqi;
    }
    .icon-only.editorial-variant .ed-content {
        padding: 8cqi;
        justify-content: center;
        gap: 0;
    }

    /* --- Eyebrow / masthead line --- */

    .ed-eyebrow {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: clamp(8px, 1.2cqi, 14px);
        font-weight: 500;
        letter-spacing: 0.32em;
        color: var(--tf-fg-quiet);
        text-transform: uppercase;
        text-align: center;
    }
    .ed-eyebrow span {
        display: inline-block;
        padding: 0 1.5em;
        position: relative;
    }

    /* --- Stack composition --- */

    .ed-stack {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 2.6cqi;
    }
    .ed-stack-wide {
        flex-direction: row;
        align-items: center;
        text-align: left;
        gap: 5cqi;
        width: 100%;
        justify-content: center;
    }
    .ed-stack-wide .ed-text {
        align-items: flex-start;
    }

    .ed-mark {
        display: flex;
        align-items: center;
        justify-content: center;
        line-height: 0;
        padding: 1.4cqi;
        border: 1px solid color-mix(in oklab, var(--tf-gold) 35%, transparent);
        background:
            linear-gradient(180deg,
                rgba(241, 196, 95, 0.04) 0%,
                rgba(0, 0, 0, 0.0) 100%);
        filter: drop-shadow(0 0.5cqi 1.2cqi rgba(0, 0, 0, 0.5));
    }

    .ed-text {
        display: flex;
        flex-direction: column;
        gap: 1.6cqi;
        align-items: center;
    }

    /* --- Gold-leaf stamped Silkscreen wordmark --- */

    .ed-wordmark {
        margin: 0;
        line-height: 0.92;
        font-family: 'Silkscreen', monospace;
        font-weight: 700;
        font-size: clamp(36px, 13cqi, 200px);
        letter-spacing: -0.03em;
        position: relative;
    }
    .banner.editorial-variant .ed-wordmark,
    .og.editorial-variant .ed-wordmark {
        font-size: clamp(36px, 11cqi, 160px);
    }
    .wide.editorial-variant .ed-wordmark {
        font-size: clamp(36px, 9cqi, 140px);
    }
    .social-x.editorial-variant .ed-wordmark {
        font-size: clamp(36px, 12cqi, 168px);
    }

    /* The leaf: brushed-gold gradient clipped to the glyphs, plus an inner
     * dark stamp shadow for letterpress depth. */
    .ed-wordmark-leaf {
        background: linear-gradient(
            178deg,
            var(--tf-gold-pale) 0%,
            var(--tf-gold) 28%,
            var(--tf-gold-deep) 52%,
            var(--tf-gold) 76%,
            var(--tf-gold-pale) 100%
        );
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
        /* Letterpress depth — soft warm under-shadow + inner dark hint. */
        filter:
            drop-shadow(0 1px 0 var(--tf-gold-shadow))
            drop-shadow(0 0.4cqi 1.2cqi rgba(241, 196, 95, 0.18));
    }

    /* --- Tagline / deck — Public Sans, restrained --- */

    .ed-tagline {
        margin: 0;
        font-family: 'Public Sans', system-ui, sans-serif;
        font-weight: 400;
        font-style: italic;
        font-size: clamp(11px, 2cqi, 26px);
        line-height: 1.45;
        letter-spacing: 0.005em;
        color: var(--tf-fg-muted);
        max-width: 60cqi;
        text-align: center;
    }
    .ed-stack-wide .ed-tagline {
        text-align: left;
        max-width: 50cqi;
        font-size: clamp(11px, 1.6cqi, 22px);
    }

    /* --- Info row / colophon --- */

    .ed-info {
        display: flex;
        align-items: center;
        gap: 1.4cqi;
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: clamp(9px, 1.35cqi, 15px);
        font-weight: 500;
        letter-spacing: 0.04em;
    }
    .ed-info-row {
        margin-top: 0.5cqi;
    }
    .wide.editorial-variant .ed-info-inline {
        margin-top: 1.2cqi;
        font-size: clamp(9px, 1cqi, 14px);
        gap: 1.2cqi;
    }
    .ed-chip {
        white-space: nowrap;
    }
    .ed-chip-diamond {
        color: var(--tf-diamond);
    }
    .ed-chip-gold {
        color: var(--tf-gold);
    }
    .ed-chip-mute {
        color: var(--tf-fg-quiet);
        letter-spacing: 0.28em;
        text-transform: uppercase;
    }
    .ed-chip-sep {
        color: var(--tf-gold-deep);
        opacity: 0.7;
    }

    /* --- Icon-only register — embossed printer's plate --- */

    .ed-icon-only-frame {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 70cqi;
        max-width: 100%;
        aspect-ratio: 1;
    }
    .ed-icon-plate {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background:
            radial-gradient(circle at 50% 38%,
                rgba(241, 196, 95, 0.12) 0%,
                rgba(0, 0, 0, 0) 60%),
            radial-gradient(circle at 50% 50%,
                rgba(241, 196, 95, 0.04) 0%,
                rgba(0, 0, 0, 0) 70%);
        border: 1px solid color-mix(in oklab, var(--tf-gold) 35%, transparent);
        box-shadow:
            inset 0 0 0 1px rgba(0, 0, 0, 0.4),
            inset 0 0 6cqi rgba(0, 0, 0, 0.5),
            0 1cqi 3cqi rgba(0, 0, 0, 0.55);
    }
    .ed-icon-plate::after {
        content: '';
        position: absolute;
        inset: 5%;
        border-radius: 50%;
        border: 1px dashed color-mix(in oklab, var(--tf-gold) 40%, transparent);
        opacity: 0.6;
    }

    /* --- Hover affordance for branding-page preview --- */

    .asset-preview-link:hover .editorial-variant.brand-asset-root {
        outline: 1px solid color-mix(in oklab, var(--tf-gold) 50%, transparent);
        outline-offset: 4px;
    }
</style>
