---
/**
 * ValueProp — section-block for "BUILT FOR THE FUTURE / PERFORMANCE OBSESSED
 * / DEVELOPER JOY" landing rhythm. Distilled from the original color-blocked
 * variants to a single quiet treatment with a left accent rule and section-y
 * typography. Differentiation between the three blocks comes from copy +
 * the staggered alignment, not from per-block color.
 *
 * The legacy `color` prop is accepted but ignored.
 */
interface Props {
  title: string
  /** @deprecated Retained for back-compat with existing MDX. Ignored. */
  color?: string
  align?: 'left' | 'right'
}

const { title, align = 'left' } = Astro.props
---

<section
  class:list={['value-prop', { 'align-right': align === 'right' }]}
>
  <div class="vp-rule" aria-hidden="true"></div>
  <div class="vp-content">
    <h3 class="vp-title" set:html={title} />
    <div class="vp-body"><slot /></div>
  </div>
</section>

<style>
  .value-prop {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1.25rem, 3vw, 2.25rem);
    margin-block: clamp(2rem, 4vw, 3rem);
    padding-block: clamp(1.25rem, 3vw, 2rem);
    /* Subtle hairline above only — sections accumulate vertical rhythm
     * without each one becoming its own card. */
    border-top: 1px solid color-mix(in oklab, var(--border) 70%, transparent);
  }

  .value-prop.align-right {
    grid-template-columns: 1fr auto;
  }

  .value-prop.align-right .vp-rule {
    order: 2;
  }

  .value-prop.align-right .vp-content {
    text-align: right;
  }

  .vp-rule {
    width: 2px;
    align-self: stretch;
    background-color: var(--primary);
    border-radius: 1px;
  }

  .vp-content {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 3);
    max-width: 60ch;
  }

  .value-prop.align-right .vp-content {
    margin-left: auto;
  }

  .vp-title {
    font-family: 'Public Sans', system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--foreground);
    margin: 0;
    text-transform: none;
  }

  .vp-body {
    font-size: 1rem;
    line-height: 1.65;
    color: color-mix(in oklab, var(--foreground) 88%, var(--muted-foreground));
  }

  .vp-body :global(p) {
    margin: 0 0 0.75rem 0;
  }

  .vp-body :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Strong becomes the accent moment — primary-tinted, not bolder weight. */
  .vp-body :global(strong) {
    color: var(--primary);
    font-weight: 600;
  }
</style>
