---
/**
 * ValueProp — text-heavy section block with a gem-tinted left/right
 * vertical rule (foil-reactive). Pulled back further from the full
 * border ring: just a thin vertical accent bar that catches the
 * global scene light via a directional glow shadow, plus tight
 * whitespace so the prose carries the section.
 */

type Gem =
  | 'gold'
  | 'ruby'
  | 'emerald'
  | 'diamond'
  | 'amethyst'
  | 'pink'
  | 'salmon'
  | 'turquoize'

type LegacyColor = 'cyan' | 'blue' | 'green' | 'orange' | 'red' | 'yellow' | 'purple'

const legacyToGem: Record<LegacyColor, Gem> = {
  cyan: 'diamond',
  blue: 'diamond',
  green: 'emerald',
  orange: 'gold',
  red: 'ruby',
  yellow: 'gold',
  purple: 'amethyst',
}

interface Props {
  title: string
  /** Gem accent — picks from the design-system palette. */
  color?: Gem | LegacyColor
  align?: 'left' | 'right'
}

const { title, color, align = 'left' } = Astro.props

const resolvedGem: Gem | undefined = color
  ? color in legacyToGem
    ? legacyToGem[color as LegacyColor]
    : (color as Gem)
  : undefined

const accentStyle = resolvedGem ? `--vp-accent: var(--${resolvedGem});` : undefined
---

<section
  class:list={['not-content', 'value-prop', 'u-reveal', 'u-light', { 'align-right': align === 'right' }]}
  data-gem={resolvedGem}
  style={accentStyle}
>
  <div class="vp-rule" aria-hidden="true"></div>
  <div class="vp-content">
    <h3 class="vp-title" set:html={title} />
    <div class="vp-body"><slot /></div>
  </div>
</section>

<style>
  .value-prop {
    --vp-accent: var(--primary);
    display: grid;
    grid-template-columns: auto 1fr;
    gap: calc(var(--spacing) * 4);
    padding-block: calc(var(--spacing) * 1);
    margin-block: calc(var(--spacing) * 6);
    max-width: 56rem;
    /* Safari paint-isolation — see GalleryTile for diagnosis. The
     * vp-rule's foil-reactive glow uses --vp-accent + cursor light
     * vars that bubble through the stacking context. contain:paint
     * locks repaint to the section box. */
    contain: paint;
    isolation: isolate;
  }

  .value-prop.align-right {
    grid-template-columns: 1fr auto;
    margin-inline-start: auto;
    text-align: right;
  }

  .value-prop.align-right .vp-rule {
    order: 2;
  }

  /* Foil rule — vertical gem stripe with a cursor-driven bright peak.
   * The gradient stops are anchored to --my (cursor's vertical
   * position 0..100% across the section), so the brightest part of
   * the bar tracks the cursor. With no cursor, --my defaults to 50%
   * (still uses the natural midpoint as the peak). Adds a thin
   * scene-angle drift via --scene-angle mod-mapped to a small
   * vertical offset so the peak breathes when idle.
   *
   * Replaces the previous static dim→bright→dim treatment per user
   * note: "would rather see foil treatment here as well." */
  .vp-rule {
    width: 3px;
    align-self: stretch;
    background: linear-gradient(
      180deg,
      color-mix(in oklab, var(--vp-accent) 18%, transparent) 0%,
      color-mix(in oklab, var(--vp-accent) 35%, transparent)
        calc(max(0%, var(--my, 50%) - 18%)),
      color-mix(in oklab, var(--vp-accent) 95%, white) var(--my, 50%),
      color-mix(in oklab, var(--vp-accent) 35%, transparent)
        calc(min(100%, var(--my, 50%) + 18%)),
      color-mix(in oklab, var(--vp-accent) 18%, transparent) 100%
    );
    border-radius: 2px;
    /* Filter sat/contrast lifts on hover so the bar reads "lit" when
     * the cursor enters. Matches the FeatureList holo-icon treatment
     * for consistency. */
    filter: saturate(calc(0.85 + var(--mouse-active, 0) * 0.4))
            contrast(calc(1.0 + var(--mouse-active, 0) * 0.1));
    transition: filter 200ms ease;
  }
  /* Suppress the .u-light pseudo gem-facet on the section — the foil
   * bar is the only lit affordance we want here; a full-width
   * gem-faceted bg would compete and read as overactive. */
  .value-prop.u-light::before,
  .value-prop.u-light::after,
  .value-prop[data-light]::before,
  .value-prop[data-light]::after {
    display: none;
  }
  /* Section also inherits `transform: perspective(900px) rotateX/Y`
   * from .u-light. Disable the perspective tilt — large prose
   * sections shouldn't lean toward the cursor like cards do. */
  .value-prop.u-light,
  .value-prop[data-light] {
    transform: none;
  }

  .vp-content {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 2);
    max-width: 60ch;
  }

  .value-prop.align-right .vp-content {
    margin-left: auto;
  }

  .vp-title {
    font-family: 'Public Sans', system-ui, sans-serif;
    font-weight: 600;
    font-size: clamp(1.125rem, 2vw, 1.375rem);
    line-height: 1.2;
    letter-spacing: -0.018em;
    color: var(--foreground);
    margin: 0;
  }

  .vp-body {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: color-mix(in oklab, var(--foreground) 88%, var(--muted-foreground));
  }

  .vp-body :global(p) {
    margin: 0 0 0.5rem 0;
  }
  .vp-body :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Strong is the gem accent moment in the body. */
  .vp-body :global(strong) {
    color: var(--vp-accent);
    font-weight: 600;
  }

</style>
