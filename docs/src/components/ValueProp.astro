---
/**
 * ValueProp — text-heavy section block with a gem-foil border ring.
 * Pulled back from the full lit-card treatment: now just a rounded
 * rectangle with a transparent interior and a gem-accented foil
 * border that rotates with the global scene-light. The text carries
 * the section, the border carries the gem identity.
 */

type Gem =
  | 'gold'
  | 'ruby'
  | 'emerald'
  | 'diamond'
  | 'amethyst'
  | 'pink'
  | 'salmon'
  | 'turquoize'

type LegacyColor = 'cyan' | 'blue' | 'green' | 'orange' | 'red' | 'yellow' | 'purple'

const legacyToGem: Record<LegacyColor, Gem> = {
  cyan: 'diamond',
  blue: 'diamond',
  green: 'emerald',
  orange: 'gold',
  red: 'ruby',
  yellow: 'gold',
  purple: 'amethyst',
}

interface Props {
  title: string
  /** Gem accent — picks from the design-system palette. */
  color?: Gem | LegacyColor
  align?: 'left' | 'right'
}

const { title, color, align = 'left' } = Astro.props

const resolvedGem: Gem | undefined = color
  ? color in legacyToGem
    ? legacyToGem[color as LegacyColor]
    : (color as Gem)
  : undefined

const accentStyle = resolvedGem ? `--vp-accent: var(--${resolvedGem});` : undefined
---

<section
  class:list={['not-content', 'value-prop', { 'align-right': align === 'right' }]}
  data-gem={resolvedGem}
  style={accentStyle}
>
  <div class="vp-content">
    <h3 class="vp-title" set:html={title} />
    <div class="vp-body"><slot /></div>
  </div>
</section>

<style>
  .value-prop {
    --vp-accent: var(--primary);
    position: relative;
    padding: clamp(2rem, 4vw, 3rem) clamp(1.75rem, 3vw, 2.75rem);
    margin-block: clamp(1.75rem, 3vw, 2.5rem);
    max-width: 56rem;
    /* Foil border ring — transparent interior, gem-tinted gradient ring
     * around the entire perimeter via background-clip padding-box +
     * border-box trick. The conic gradient rotates with --scene-angle
     * so the border catches the global scene light direction (perlin-
     * driven), making the border read as foil rather than flat color. */
    border: 1.5px solid transparent;
    border-radius: calc(var(--radius) + 0.5rem);
    background:
      linear-gradient(var(--background), var(--background)) padding-box,
      conic-gradient(
        from calc(var(--scene-angle, 135deg) - 90deg),
        color-mix(in oklab, var(--vp-accent) 90%, transparent) 0deg,
        color-mix(in oklab, var(--vp-accent) 30%, var(--border)) 90deg,
        color-mix(in oklab, var(--border) 80%, transparent) 180deg,
        color-mix(in oklab, var(--vp-accent) 30%, var(--border)) 270deg,
        color-mix(in oklab, var(--vp-accent) 90%, transparent) 360deg
      ) border-box;
    background-origin: border-box;
  }

  .value-prop.align-right {
    margin-inline-start: auto;
    text-align: right;
  }

  .vp-content {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 4);
    max-width: 60ch;
  }

  .value-prop.align-right .vp-content {
    margin-left: auto;
  }

  .vp-title {
    font-family: 'Public Sans', system-ui, sans-serif;
    font-weight: 600;
    font-size: clamp(1.25rem, 2.2vw, 1.625rem);
    line-height: 1.2;
    letter-spacing: -0.018em;
    color: var(--foreground);
    margin: 0;
  }

  .vp-body {
    font-size: 1rem;
    line-height: 1.65;
    color: color-mix(in oklab, var(--foreground) 88%, var(--muted-foreground));
  }

  .vp-body :global(p) {
    margin: 0 0 0.75rem 0;
  }
  .vp-body :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Strong is the gem accent moment in the body. */
  .vp-body :global(strong) {
    color: var(--vp-accent);
    font-weight: 600;
  }

  @media (prefers-reduced-motion: reduce) {
    .value-prop {
      background:
        linear-gradient(var(--background), var(--background)) padding-box,
        var(--vp-accent) border-box;
      background-origin: border-box;
    }
  }
</style>
