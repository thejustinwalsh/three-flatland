---
/**
 * ValueProp — section-block for the landing's "Why three-flatland?" rhythm.
 * Each block can opt into a gem accent via `color="<gem>"`; the gem hue
 * drives the left rule, strong-text accent, and title-side glow so each
 * value-prop reads as its own color identity.
 *
 * Conventional names (cyan, blue, green, etc.) are accepted for compat
 * with existing MDX call sites; mapped to the closest gem at render time.
 */

type Gem =
  | 'gold'
  | 'ruby'
  | 'emerald'
  | 'diamond'
  | 'amethyst'
  | 'pink'
  | 'salmon'
  | 'turquoize'

type LegacyColor = 'cyan' | 'blue' | 'green' | 'orange' | 'red' | 'yellow' | 'purple'

const legacyToGem: Record<LegacyColor, Gem> = {
  cyan: 'diamond',
  blue: 'diamond',
  green: 'emerald',
  orange: 'gold',
  red: 'ruby',
  yellow: 'gold',
  purple: 'amethyst',
}

interface Props {
  title: string
  /** Gem accent for the left rule, strong-text emphasis, and title glow. */
  color?: Gem | LegacyColor
  align?: 'left' | 'right'
}

const { title, color, align = 'left' } = Astro.props

const resolvedGem: Gem | undefined = color
  ? color in legacyToGem
    ? legacyToGem[color as LegacyColor]
    : (color as Gem)
  : undefined

const accentStyle = resolvedGem ? `--vp-accent: var(--${resolvedGem});` : undefined
---

<section
  class:list={['not-content', 'value-prop', { 'align-right': align === 'right' }]}
  data-gem={resolvedGem}
  style={accentStyle}
>
  <div class="vp-rule" aria-hidden="true"></div>
  <div class="vp-content">
    <h3 class="vp-title" set:html={title} />
    <div class="vp-body"><slot /></div>
  </div>
</section>

<style>
  .value-prop {
    --vp-accent: var(--primary);
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1.25rem, 3vw, 2.25rem);
    margin-block: clamp(2rem, 4vw, 3rem);
    padding-block: clamp(1.25rem, 3vw, 2rem);
    border-top: 1px solid color-mix(in oklab, var(--vp-accent) 25%, var(--border));
  }

  .value-prop.align-right {
    grid-template-columns: 1fr auto;
  }

  .value-prop.align-right .vp-rule {
    order: 2;
  }

  .value-prop.align-right .vp-content {
    text-align: right;
  }

  /* Vertical rule is gem-tinted with a soft glow that intensifies the
   * accent's color identity without overpowering the prose. */
  .vp-rule {
    width: 2px;
    align-self: stretch;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      var(--vp-accent) 18%,
      var(--vp-accent) 82%,
      transparent 100%
    );
    border-radius: 1px;
    box-shadow: 0 0 16px color-mix(in oklab, var(--vp-accent) 35%, transparent);
  }

  .vp-content {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 3);
    max-width: 60ch;
  }

  .value-prop.align-right .vp-content {
    margin-left: auto;
  }

  /* Title gets a subtle gem-side underline accent — a hairline tinted
   * by the value-prop's gem, just below the title text. */
  .vp-title {
    font-family: 'Public Sans', system-ui, sans-serif;
    font-weight: 700;
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--foreground);
    margin: 0;
    text-transform: none;
    position: relative;
    padding-bottom: calc(var(--spacing) * 2);
    border-bottom: 1px solid color-mix(in oklab, var(--vp-accent) 35%, transparent);
    align-self: start;
  }

  .value-prop.align-right .vp-title {
    align-self: end;
  }

  .vp-body {
    font-size: 1rem;
    line-height: 1.65;
    color: color-mix(in oklab, var(--foreground) 88%, var(--muted-foreground));
  }

  .vp-body :global(p) {
    margin: 0 0 0.75rem 0;
  }

  .vp-body :global(p:last-child) {
    margin-bottom: 0;
  }

  /* Strong becomes the accent moment — gem-tinted text emphasis. */
  .vp-body :global(strong) {
    color: var(--vp-accent);
    font-weight: 600;
  }
</style>
