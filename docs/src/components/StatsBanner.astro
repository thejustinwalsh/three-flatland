---
/**
 * StatsBanner — performance stats strip on the landing page. Distilled
 * from the original "rainbow stripe + cream box + Silkscreen big numbers"
 * treatment to a single quiet horizontal rhythm with monospace numerals,
 * tracked uppercase labels, and a hairline frame.
 *
 * The legacy `color` prop on each stat is accepted but ignored; existing
 * MDX call sites continue to compile.
 */
interface StatItem {
  value: string
  label: string
  /** @deprecated Retained for backward-compat with existing MDX. Ignored. */
  color?: string
}

interface Props {
  stats: StatItem[]
}

const { stats } = Astro.props
---

<aside class="not-content stats-banner" aria-label="Performance highlights">
  <div class="stats-grid">
    {stats.map((stat) => (
      <div class="stat-item">
        <span class="stat-value">{stat.value}</span>
        <span class="stat-label">{stat.label}</span>
      </div>
    ))}
  </div>
</aside>

<style>
  .stats-banner {
    position: relative;
    margin: clamp(2.5rem, 5vw, 4rem) 0;
    padding: clamp(1.5rem, 3vw, 2.25rem) clamp(1rem, 3vw, 2rem);
    border-block: 1px solid color-mix(in oklab, var(--border) 65%, transparent);
    /* Subtle tinted band — not a solid bg block. Reads as "highlight"
     * without forming a card. */
    background-color: color-mix(in oklab, var(--card) 96%, var(--primary));
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
    max-width: 1100px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 1);
    /* Asymmetric: not centered. Left-aligned reads more designed
     * (Design Context principle). */
    align-items: flex-start;
  }

  .stat-value {
    font-family: 'Commit Mono', 'JetBrains Mono', ui-monospace, monospace;
    font-feature-settings:
      'tnum' 1,
      'ss01' 1;
    font-size: clamp(1.75rem, 3.2vw, 2.75rem);
    font-weight: 500;
    color: var(--foreground);
    line-height: 1;
    letter-spacing: -0.025em;
  }

  .stat-label {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.6875rem;
    color: var(--muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
</style>
