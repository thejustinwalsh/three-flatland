---
/**
 * StatsBanner — performance stats strip on the landing page.
 * Each stat opts into a gem accent via `color="<gem>"`; the gem
 * tints the value text and a thin underline beneath the stat,
 * so the four stats read as a colored chord rather than a flat row.
 */

type Gem =
  | 'gold'
  | 'ruby'
  | 'emerald'
  | 'diamond'
  | 'amethyst'
  | 'pink'
  | 'salmon'
  | 'turquoize'

type LegacyColor = 'cyan' | 'blue' | 'green' | 'orange' | 'red' | 'yellow' | 'purple'

const legacyToGem: Record<LegacyColor, Gem> = {
  cyan: 'diamond',
  blue: 'diamond',
  green: 'emerald',
  orange: 'gold',
  red: 'ruby',
  yellow: 'gold',
  purple: 'amethyst',
}

interface StatItem {
  value: string
  label: string
  /** Gem accent — tints the value + underline. */
  color?: Gem | LegacyColor
}

interface Props {
  stats: StatItem[]
}

const { stats } = Astro.props

function resolveGem(c: StatItem['color']): Gem | undefined {
  if (!c) return undefined
  if (c in legacyToGem) return legacyToGem[c as LegacyColor]
  return c as Gem
}
---

<aside class="not-content stats-banner u-reveal" aria-label="Performance highlights">
  <div class="stats-grid">
    {stats.map((stat) => {
      const gem = resolveGem(stat.color)
      // Gem accent is driven by `data-gem` + per-gem CSS rules in the
      // <style> block below rather than inline `--stat-accent: var(--<gem>)`.
      // Safari has a known `color-mix(in oklab, var(--x), ...)` resolution
      // bug when --x is set to another var() in inline style — values
      // resolve correctly through normal CSS cascade but not through
      // double-indirected inline custom properties.
      //
      // Reveal animation moved to the .stats-banner wrapper (singular
      // u-reveal). The four stats are one component visually; staggering
      // them individually read as "loading" rather than "appearing"
      // because they all sit in one row already at the same scroll
      // position. One unified fade is the right gesture.
      return (
        <div class="stat-item" data-gem={gem}>
          <span class="stat-value">{stat.value}</span>
          <span class="stat-label">{stat.label}</span>
        </div>
      )
    })}
  </div>
</aside>

<style>
  .stats-banner {
    position: relative;
    margin: clamp(2.5rem, 5vw, 4rem) 0;
    padding: clamp(1.5rem, 3vw, 2.25rem) clamp(1rem, 3vw, 2rem);
    border-block: 1px solid color-mix(in oklab, var(--border) 65%, transparent);
    background-color: color-mix(in oklab, var(--card) 96%, var(--primary));
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
    max-width: 1100px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Per-gem accent assignment — sets --stat-accent DIRECTLY in CSS
   * via the data-gem attribute rather than via inline-style
   * `--stat-accent: var(--<gem>)`. Safari has a known resolution bug
   * where `color-mix(in oklab, var(--customProp), ...)` fails when
   * --customProp is set to another var() in inline style; values
   * resolve correctly through normal CSS cascade. Mirrors the same
   * data-gem pattern FeatureCard uses for --card-soft. */
  .stat-item[data-gem='gold']      { --stat-accent: var(--gold); }
  .stat-item[data-gem='ruby']      { --stat-accent: var(--ruby); }
  .stat-item[data-gem='emerald']   { --stat-accent: var(--emerald); }
  .stat-item[data-gem='diamond']   { --stat-accent: var(--diamond); }
  .stat-item[data-gem='amethyst']  { --stat-accent: var(--amethyst); }
  .stat-item[data-gem='pink']      { --stat-accent: var(--pink); }
  .stat-item[data-gem='salmon']    { --stat-accent: var(--salmon); }
  .stat-item[data-gem='turquoize'] { --stat-accent: var(--turquoize); }

  .stat-item {
    --stat-accent: var(--primary);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 1.5);
    align-items: flex-start;
    padding-bottom: calc(var(--spacing) * 2);
    /* Safari paint-isolation — see GalleryTile / FeatureCard for the
     * full diagnosis. The gem-tinted underline reads --stat-accent
     * which is per-item; pinning paint to the box stops the global
     * --scene-angle motion arc from invalidating other stat items
     * when one re-renders. */
    contain: paint;
    isolation: isolate;
    /* Gem-tinted underline — thin foil hairline beneath each stat
     * that catches the global scene light direction (cosmetic shadow
     * shifts with --scene-angle). */
    border-bottom: 1.5px solid transparent;
    background-image: linear-gradient(
      90deg,
      var(--stat-accent) 0%,
      color-mix(in oklab, var(--stat-accent) 70%, transparent) 70%,
      transparent 100%
    );
    background-size: 100% 1.5px;
    background-repeat: no-repeat;
    background-position: 0 100%;
  }

  .stat-value {
    font-family: 'Commit Mono', 'JetBrains Mono', ui-monospace, monospace;
    font-feature-settings:
      'tnum' 1,
      'ss01' 1;
    font-size: clamp(1.75rem, 3.2vw, 2.75rem);
    font-weight: 500;
    /* Value pulls from the gem accent so each stat reads its own
     * color. Was: color-mix(in oklab, var(--stat-accent) 65%,
     * var(--foreground)) for a foreground-softened version, but
     * Safari has a confirmed resolution bug where
     * color-mix(in oklab, var(), var()) returns just the second arg
     * when the first is a chained custom property — verified via
     * docs/scripts/diag-stats-color.mjs which read computedStyle
     * and showed the value resolving to --foreground alone, ignoring
     * the gem. In light mode that incidentally resolves to dark text
     * (legible by accident); in dark mode it resolves to near-white
     * text (the user-visible bug). The fallback CSS pattern (two
     * color: declarations) doesn't help because Safari considers
     * the broken color-mix syntactically valid.
     *
     * Fix: use the gem color directly with no mix. Reads slightly
     * more saturated than the previous foreground-mixed version
     * but works identically in both browsers and both themes. */
    color: var(--stat-accent);
    line-height: 1;
    letter-spacing: -0.025em;
  }

  .stat-label {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.6875rem;
    color: var(--muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
</style>
