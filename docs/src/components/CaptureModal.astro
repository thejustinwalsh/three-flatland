<dialog id="capture-modal">
  <div class="modal-ui">
    <button id="close-modal" aria-label="Close Preview">×</button>
    <div id="modal-content"></div>
  </div>
</dialog>

<script is:inline>
  // Wire up asset preview links to open capture modal
  document.querySelectorAll('.asset-preview-link').forEach(link => {
    link.addEventListener('click', () => {
      const type = link.getAttribute('data-type');
      const targetId = `capture-${type}`;
      const asset = document.getElementById(targetId);
      const modalContent = document.getElementById('modal-content');

      if (!asset || !modalContent) return;

      modalContent.innerHTML = '';
      const clone = /** @type {HTMLElement} */ (asset.cloneNode(true));
      clone.style.display = 'block';
      modalContent.appendChild(clone);

      window.dispatchEvent(new CustomEvent('open-capture-modal', {
        detail: { type }
      }));
    });
  });

  const modal = /** @type {HTMLDialogElement | null} */ (document.getElementById('capture-modal'));
  const modalContent = document.getElementById('modal-content');
  const closeBtn = document.getElementById('close-modal');

  if (modal && modalContent && closeBtn) {
    window.addEventListener('open-capture-modal', () => {
      modal.showModal();
      document.body.style.overflow = 'hidden';
    });

    closeBtn.addEventListener('click', () => {
      modal.close();
    });

    modal.addEventListener('close', () => {
      modalContent.innerHTML = '';
      document.body.style.overflow = '';
    });

    // Close on backdrop click
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });
  }
</script>

<style>
  #capture-modal {
    padding: 0;
    border: none;
    background: #000; /* Solid black for clean capture background */
    width: 100vw;
    height: 100vh;
    max-width: none;
    max-height: none;
    color: #f0edd8;
    overflow: hidden;
  }

  #capture-modal::backdrop {
    background: rgba(0, 0, 0, 0.95);
  }

  .modal-ui {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 100px; /* Space for node highlighting in devtools */
    position: relative;
  }

  /* Close button — design-system aligned. Was a hardcoded pink-on-
   * Silkscreen pill that didn't match anything else on the site.
   * Now uses the same tokens as the rest of the chrome:
   *   - --card surface, --border at 1px (matches button pattern)
   *   - --foreground glyph color, Inter for UI parity
   *   - Ruby gem on hover/focus (the "dismiss" gem in our taxonomy)
   *   - Soft scene-light shadow that fits the dark-on-near-black
   *     surface aesthetic
   * Click target stays at 2.75rem (44px+ tap target). */
  #close-modal {
    position: fixed;
    top: calc(var(--spacing) * 4);
    right: calc(var(--spacing) * 4);
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: color-mix(in oklab, var(--card) 92%, var(--background));
    color: var(--foreground);
    border: 1px solid var(--border);
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0;
    cursor: pointer;
    z-index: 10001;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      color 180ms cubic-bezier(0.2, 0.8, 0.2, 1),
      border-color 180ms cubic-bezier(0.2, 0.8, 0.2, 1),
      background-color 180ms cubic-bezier(0.2, 0.8, 0.2, 1),
      box-shadow 180ms cubic-bezier(0.2, 0.8, 0.2, 1);
    box-shadow:
      0 4px 18px -4px color-mix(in oklab, black 70%, transparent),
      0 1px 4px -1px color-mix(in oklab, black 85%, transparent);
    outline-offset: 2px;
  }

  #close-modal:hover {
    color: var(--ruby);
    border-color: color-mix(in oklab, var(--ruby) 55%, var(--border));
    background-color: color-mix(in oklab, var(--ruby) 8%, var(--card));
    box-shadow:
      0 6px 22px -4px color-mix(in oklab, black 65%, transparent),
      0 0 0 1px color-mix(in oklab, var(--ruby) 35%, transparent);
  }

  #close-modal:focus-visible {
    outline: 2px solid var(--ruby);
  }

  @media (prefers-reduced-motion: reduce) {
    #close-modal {
      transition: none;
    }
  }

  #modal-content {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #modal-content :global(.brand-asset-root) {
    box-shadow: 0 40px 100px rgba(0,0,0,1);
    flex-shrink: 0;
  }

  :global(.asset-preview-link) {
    display: block;
    margin: 2rem 0;
    cursor: pointer;
    border: 2px solid var(--sl-color-gray-5);
    background: #00021c;
    border-radius: 0.5rem;
    transition: border-color 0.2s, transform 0.1s;
    overflow-x: auto;
    overflow-y: hidden;
    container-type: inline-size;
    width: 100%;
    max-width: 100%;
  }

  :global(.asset-preview-link:hover) {
    border-color: #47cca9;
    transform: translateY(-2px);
  }

  :global(.hidden-capture-targets) {
    display: none;
  }
</style>
