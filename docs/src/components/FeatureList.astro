---
/**
 * FeatureList — compact, scannable feature callout list. Each row carries
 * a gem accent (icon + title + a hairline left-rule) so the list reads
 * as a colored chord, matching the gem taxonomy used by FeatureCard,
 * ValueProp, and StatsBanner.
 */
import Icon from './Icon.astro'

type Gem =
  | 'gold'
  | 'ruby'
  | 'emerald'
  | 'diamond'
  | 'amethyst'
  | 'pink'
  | 'salmon'
  | 'turquoize'

type LegacyColor = 'cyan' | 'blue' | 'green' | 'orange' | 'red' | 'yellow' | 'purple'

const legacyToGem: Record<LegacyColor, Gem> = {
  cyan: 'diamond',
  blue: 'diamond',
  green: 'emerald',
  orange: 'gold',
  red: 'ruby',
  yellow: 'gold',
  purple: 'amethyst',
}

interface Feature {
  icon: string
  title: string
  description: string
  /** Per-row gem override. Omit to cycle through the default gem ladder. */
  color?: Gem | LegacyColor
}

interface Props {
  features: Feature[]
}

const { features } = Astro.props

/** Default gem cycle — mirrors the FeatureCard grid's defaults so a list
 *  and a card grid on the same topic read in the same color order. */
const defaultGems: Gem[] = [
  'diamond',
  'emerald',
  'amethyst',
  'gold',
  'salmon',
  'pink',
]

function resolveGem(c: Feature['color'], idx: number): Gem {
  if (!c) return defaultGems[idx % defaultGems.length]
  if (c in legacyToGem) return legacyToGem[c as LegacyColor]
  return c as Gem
}
---

<ul class="not-content feature-list">
  {features.map((feature, i) => {
    const gem = resolveGem(feature.color, i)
    return (
      <li class="feature-item u-light u-reveal" data-gem={gem} style={`--feature-accent: var(--${gem}); --reveal-delay: ${i * 60}ms;`}>
        <span class="feature-name">
          <Icon name={feature.icon} size="1.125rem" color="var(--feature-accent)" class="feature-icon-holo" />
          <span class="feature-title">{feature.title}</span>
        </span>
        <span class="feature-desc">{feature.description}</span>
      </li>
    )
  })}
</ul>

<style>
  .feature-list {
    list-style: none;
    padding: 0;
    margin: calc(var(--spacing) * 4) 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .feature-item {
    --feature-accent: var(--diamond);
    /* The .u-light pseudo-element gem facet reads --card-accent. Without
     * this alias, every row's bg falls back to --primary (amethyst) since
     * the only per-gem override in base.css is for `[data-gem='gold']`.
     * Aliasing --card-accent to the row's gem makes the gem-faceted
     * gradient track each row's accent. */
    --card-accent: var(--feature-accent);
    display: grid;
    grid-template-columns: 14rem 1fr;
    align-items: center;
    gap: 1rem;
    line-height: 1.5;
    padding: 0.5rem 0 0.5rem 0.75rem;
    /* Thin gem-tinted left rule — fades top to bottom so the row reads
     * as accented, not boxed. Matches ValueProp's vertical foil rule
     * treatment at smaller scale. */
    background-image: linear-gradient(
      180deg,
      color-mix(in oklab, var(--feature-accent) 25%, transparent) 0%,
      var(--feature-accent) 50%,
      color-mix(in oklab, var(--feature-accent) 25%, transparent) 100%
    );
    background-size: 2px 100%;
    background-repeat: no-repeat;
    background-position: 0 0;
    border-radius: 0;
  }

  .feature-name {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    line-height: 1.5;
  }

  .feature-title {
    font-family: 'Inter', system-ui, sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: color-mix(in oklab, var(--feature-accent) 65%, var(--foreground));
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.5;
  }

  .feature-desc {
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, monospace;
    font-size: 0.875rem;
    color: color-mix(in oklab, var(--foreground) 80%, var(--muted-foreground));
    line-height: 1.5;
  }

  /* ── Holographic icon foil ──
   * Trading-card holographic foil on the row icon. The icon's mask
   * (the lucide glyph shape) is kept intact by UnoCSS's preset-icons
   * mask mode; we replace the solid `background-color: currentColor`
   * with a layered holographic gradient that:
   *   - Cycles hue around the gem accent at rest (scene-angle drives it)
   *   - Sharpens into a bright cursor-tracked stripe on hover
   *
   * Result: idle icons read as gem-tinted with a subtle rainbow shift;
   * hovered icons sweep a sharp prismatic streak as the cursor moves.
   * Reduced-motion: pin to a static gem-tinted gradient.
   */
  .feature-item .feature-icon-holo {
    /* The mask + mask-size already come from i-lucide:* via UnoCSS.
     * Override the default background-color: currentColor with our
     * layered gradients. Background-blend-mode: screen on the bright
     * cursor stripe lifts it above the gem base.
     */
    background-color: transparent;
    background-image:
      /* Cursor-tracked highlight stripe — narrow, bright, follows the
       * cursor angle. Only visible on hover via --mouse-active. */
      linear-gradient(
        calc(var(--light-angle, 135deg)),
        transparent 30%,
        color-mix(in oklab, white 80%, var(--feature-accent)) 50%,
        transparent 70%
      ),
      /* Holo rainbow base — three-color gradient phase-shifted by
       * scene-angle so the hue ladder rotates with the day cycle.
       * Mixed heavily with the gem accent so it stays in-family. */
      linear-gradient(
        calc(var(--scene-angle, 135deg) - 90deg),
        color-mix(in oklab, var(--feature-accent) 50%, hsl(calc(var(--scene-angle, 135deg)), 75%, 60%)),
        color-mix(in oklab, var(--feature-accent) 60%, hsl(calc(var(--scene-angle, 135deg) + 120deg), 75%, 65%)),
        color-mix(in oklab, var(--feature-accent) 50%, hsl(calc(var(--scene-angle, 135deg) + 240deg), 75%, 60%))
      );
    background-blend-mode: screen, normal;
    background-size: 100% 100%, 100% 100%;
    /* Hover: ramp in the cursor stripe via opacity hack on the layer
     * (multi-bg can't have per-layer opacity, so we ramp the whole
     * thing's contrast with a filter that sharpens on hover). */
    filter: saturate(calc(0.85 + var(--mouse-active, 0) * 0.5))
            contrast(calc(1.0 + var(--mouse-active, 0) * 0.15));
    transition: filter 200ms ease;
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-item .feature-icon-holo {
      background-image: linear-gradient(
        135deg,
        var(--feature-accent),
        color-mix(in oklab, var(--feature-accent) 60%, white)
      );
      filter: none;
    }
  }

  /* Mobile: stack vertically, drop the rule to a top edge so it doesn't
   * fight the stacked layout. */
  @media (max-width: 600px) {
    .feature-item {
      grid-template-columns: 1fr;
      gap: 0.25rem;
      padding: 0.5rem 0 0.5rem 0;
      background-image: linear-gradient(
        90deg,
        var(--feature-accent) 0%,
        color-mix(in oklab, var(--feature-accent) 30%, transparent) 70%,
        transparent 100%
      );
      background-size: 100% 1.5px;
      background-position: 0 0;
    }
  }
</style>
