---
interface Props {
  name: string
  label?: string
  size?: string
  color?: string
  class?: string
}

const { name, label, size = '1.5em', color = 'currentColor', class: className } = Astro.props

const fullName = name.includes(':') ? name : `pixelarticons:${name}`
---

<span
  class:list={[`i-${fullName}`, 'pixel-icon', className]}
  style={`width: ${size}; height: ${size}; color: ${color};`}
  role={label ? 'img' : undefined}
  aria-hidden={label ? undefined : 'true'}
  aria-label={label}
></span>

<style>
  .pixel-icon {
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
  }
</style>
