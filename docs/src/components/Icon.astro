---
interface Props {
  name: string
  label?: string
  size?: string
  color?: string
  class?: string
}

const { name, label, size = '1.5em', color = 'currentColor', class: className } = Astro.props

// Default to the `lucide` collection per the Design Context. Pass a prefixed
// name (`tf:logo`, `material-icon-theme:typescript`) to use another collection.
const fullName = name.includes(':') ? name : `lucide:${name}`
---

<span
  class:list={[`i-${fullName}`, 'icon', className]}
  style={`width: ${size}; height: ${size}; color: ${color};`}
  role={label ? 'img' : undefined}
  aria-hidden={label ? undefined : 'true'}
  aria-label={label}
></span>

<style>
  .icon {
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
  }
</style>
