---
import { readFile } from 'node:fs/promises';
import { join } from 'node:path';

interface Props {
  size?: string;
  class?: string;
}

const { size = "100%", class: className } = Astro.props;

// Load the official icon from the root assets directory
let iconSvg = '';
try {
  // Assuming we are running from the /docs directory during development/build
  const iconPath = join(process.cwd(), '../assets/icon.svg');
  iconSvg = await readFile(iconPath, 'utf8');
} catch (e) {
  // Fallback if path logic fails
  console.error("Failed to load icon.svg from root assets:", e);
  iconSvg = '<svg viewBox="0 0 384 384" xmlns="http://www.w3.org/2000/svg"><rect width="100%" height="100%" fill="red" /></svg>';
}
---

<div class:list={["brand-icon-container", className]} style={`width: ${size}; height: ${size};`}>
  <div class="svg-wrapper" set:html={iconSvg} />
</div>

<style is:global>
  .brand-icon-container .svg-wrapper svg {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>
