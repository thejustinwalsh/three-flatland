---
/**
 * FeatureCard — gem-accented card for the landing page feature grid.
 *
 * Pass `color="<gem>"` to anchor the card to a specific accent from the
 * design system's gem palette: gold, ruby, emerald, diamond, amethyst,
 * pink, salmon, turquoize. The accent drives the icon hue, hover border,
 * and a soft tint behind the surface (per Design Context: color-as-taxonomy,
 * cards opt into the palette).
 *
 * Without `color`, the card falls back to `--primary` (amethyst) so plain
 * `<FeatureCard title="…">` calls render coherently against the rest of
 * the design system without forcing every author to pick a gem.
 */
import Icon from './Icon.astro'

type Gem =
  | 'gold'
  | 'ruby'
  | 'emerald'
  | 'diamond'
  | 'amethyst'
  | 'pink'
  | 'salmon'
  | 'turquoize'

/** Conventional color names accepted for transitional compat with existing
 * MDX call sites — mapped to the closest gem at render time. */
type LegacyColor = 'cyan' | 'blue' | 'green' | 'orange' | 'red' | 'yellow' | 'purple'

const legacyToGem: Record<LegacyColor, Gem> = {
  cyan: 'diamond',
  blue: 'diamond',
  green: 'emerald',
  orange: 'gold',
  red: 'ruby',
  yellow: 'gold',
  purple: 'amethyst',
}

interface Props {
  icon?: string
  title: string
  /** Gem accent — picks from the design-system palette. Defaults to `--primary`.
   *  Conventional names (cyan, blue, green, orange, red, yellow, purple) are
   *  accepted for compat and mapped to gems. */
  color?: Gem | LegacyColor
  stat?: string
  statLabel?: string
}

const { icon, title, color, stat, statLabel } = Astro.props

const resolvedGem: Gem | undefined = color
  ? (color in legacyToGem ? legacyToGem[color as LegacyColor] : (color as Gem))
  : undefined

const accentStyle = resolvedGem ? `--card-accent: var(--${resolvedGem});` : undefined
---

<article class="feature-card u-light u-reveal" data-sound="card" data-gem={resolvedGem} style={accentStyle}>
  {icon && (
    <span class="icon-wrap" aria-hidden="true">
      <Icon name={icon} size="1.5rem" />
    </span>
  )}
  <h3 class="title" set:html={title} />
  {stat && (
    <div class="stat-block">
      <span class="stat-value">{stat}</span>
      {statLabel && <span class="stat-label">{statLabel}</span>}
    </div>
  )}
  <p class="description"><slot /></p>
  {/* Top-layer rim ring — sits above the .u-light pseudos to mask any
      displacement-filter edge artifacts AND act as the rim light. The
      rim catches the scene light direction (perlin-driven) so it
      glints organically. */}
  <span class="card-edge" aria-hidden="true"></span>
</article>

<style>
  .feature-card {
    /* Cards CARRY their gem identity at rest — not a neutral surface that
     * lights up to a jewel. The base color is the gem's `*-soft` variant
     * (dark hue-tinted surface defined in theme.css), so even idle the
     * card reads as "this is a ruby card." Light effects layer on top to
     * amplify, not to create the tint from neutral.
     *
     * Default: --card-soft falls back to a darker amethyst tint when no
     * gem prop is passed. Each `data-gem="<name>"` selector below sets
     * --card-soft to that gem's soft variant. */
    --card-soft: color-mix(in oklab, var(--gray-7) 60%, var(--card-accent, var(--primary)));
    --card: var(--card-soft);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 3);
    padding: calc(var(--spacing) * 5) calc(var(--spacing) * 5)
      calc(var(--spacing) * 6);
    background: var(--card-soft);
    border-radius: calc(var(--radius) - 2px);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  /* Top-layer rim ring — last child of .feature-card, absolutely positioned
   * with z-index above the .u-light pseudos so it masks any displacement-
   * filter edge artifacts. The ring is 1.5px thick, gradient-colored via
   * conic-gradient anchored at --scene-angle (perlin-drifted), brighter on
   * the lit side. Mask makes it ring-shaped without an extra wrapper. */
  .feature-card > .card-edge {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    z-index: 4;
    padding: 1.5px;
    background: conic-gradient(
      from calc(var(--effective-light-angle, var(--scene-angle, 135deg)) - 90deg),
      color-mix(in oklab, var(--card-accent, var(--primary)) 80%, transparent) 0deg,
      color-mix(in oklab, var(--card-accent, var(--primary)) 30%, var(--border)) 90deg,
      color-mix(in oklab, var(--border) 90%, transparent) 180deg,
      color-mix(in oklab, var(--card-accent, var(--primary)) 30%, var(--border)) 270deg,
      color-mix(in oklab, var(--card-accent, var(--primary)) 80%, transparent) 360deg
    );
    -webkit-mask:
      linear-gradient(#000, #000) content-box,
      linear-gradient(#000, #000);
    -webkit-mask-composite: xor;
    mask:
      linear-gradient(#000, #000) content-box,
      linear-gradient(#000, #000);
    mask-composite: exclude;
  }
  @media (prefers-reduced-motion: reduce) {
    .feature-card > .card-edge {
      background: var(--border);
    }
  }

  /* Per-gem resting tint — pulls from the dedicated gem-soft tokens
   * defined in theme.css (each is a low-chroma dark surface with the
   * gem's hue baked in, designed for exactly this). */
  .feature-card[data-gem='gold'] { --card-soft: var(--gold-soft); }
  .feature-card[data-gem='ruby'] { --card-soft: var(--ruby-soft); }
  .feature-card[data-gem='emerald'] { --card-soft: var(--emerald-soft); }
  .feature-card[data-gem='diamond'] { --card-soft: var(--diamond-soft); }
  .feature-card[data-gem='amethyst'] { --card-soft: var(--amethyst-soft); }
  .feature-card[data-gem='pink'] { --card-soft: var(--pink-soft); }
  .feature-card[data-gem='salmon'] { --card-soft: var(--salmon-soft); }
  .feature-card[data-gem='turquoize'] { --card-soft: var(--turquoize-soft); }

  .feature-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -12px color-mix(in oklab, var(--card-accent, var(--primary)) 30%, transparent);
  }

  .icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: calc(var(--radius) - 4px);
    background-color: color-mix(in oklab, var(--card-accent, var(--primary)) 18%, transparent);
    color: var(--card-accent, var(--primary));
  }

  .title {
    font-family: 'Public Sans', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1.0625rem;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--foreground);
    margin: 0;
  }

  .stat-block {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    margin-top: calc(var(--spacing) * 1);
  }

  .stat-value {
    font-family: 'Commit Mono', 'JetBrains Mono', ui-monospace, monospace;
    font-feature-settings:
      'tnum' 1,
      'ss01' 1;
    font-size: 1.625rem;
    font-weight: 500;
    color: var(--foreground);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-family: 'Public Sans', system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.6875rem;
    color: var(--muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .description {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--muted-foreground);
    margin: 0;
  }
</style>
