---
/**
 * FeatureCard — gem-accented card for the landing page feature grid.
 *
 * Pass `color="<gem>"` to anchor the card to a specific accent from the
 * design system's gem palette: gold, ruby, emerald, diamond, amethyst,
 * pink, salmon, turquoize. The accent drives the icon hue, hover border,
 * and a soft tint behind the surface (per Design Context: color-as-taxonomy,
 * cards opt into the palette).
 *
 * Without `color`, the card falls back to `--primary` (amethyst) so plain
 * `<FeatureCard title="…">` calls render coherently against the rest of
 * the design system without forcing every author to pick a gem.
 */
import Icon from './Icon.astro'

type Gem =
  | 'gold'
  | 'ruby'
  | 'emerald'
  | 'diamond'
  | 'amethyst'
  | 'pink'
  | 'salmon'
  | 'turquoize'

/** Conventional color names accepted for transitional compat with existing
 * MDX call sites — mapped to the closest gem at render time. */
type LegacyColor = 'cyan' | 'blue' | 'green' | 'orange' | 'red' | 'yellow' | 'purple'

const legacyToGem: Record<LegacyColor, Gem> = {
  cyan: 'diamond',
  blue: 'diamond',
  green: 'emerald',
  orange: 'gold',
  red: 'ruby',
  yellow: 'gold',
  purple: 'amethyst',
}

interface Props {
  icon?: string
  title: string
  /** Gem accent — picks from the design-system palette. Defaults to `--primary`.
   *  Conventional names (cyan, blue, green, orange, red, yellow, purple) are
   *  accepted for compat and mapped to gems. */
  color?: Gem | LegacyColor
  stat?: string
  statLabel?: string
}

const { icon, title, color, stat, statLabel } = Astro.props

const resolvedGem: Gem | undefined = color
  ? (color in legacyToGem ? legacyToGem[color as LegacyColor] : (color as Gem))
  : undefined

const accentStyle = resolvedGem ? `--card-accent: var(--${resolvedGem});` : undefined
---

<article class="not-content feature-card u-light u-reveal" data-sound="card" data-gem={resolvedGem} style={accentStyle}>
  <div class="head">
    {icon && (
      <span class="icon-wrap" aria-hidden="true">
        <Icon name={icon} size="1.5rem" />
      </span>
    )}
    <h3 class="title" set:html={title} />
  </div>
  {stat && (
    <div class="stat-block">
      <span class="stat-value">{stat}</span>
      {statLabel && <span class="stat-label">{statLabel}</span>}
    </div>
  )}
  <p class="description"><slot /></p>
  {/* Top-layer rim ring — sits above the .u-light pseudos to mask any
      displacement-filter edge artifacts AND act as the rim light. The
      rim catches the scene light direction (perlin-driven) so it
      glints organically. */}
  <span class="card-edge" aria-hidden="true"></span>
</article>

<style>
  .feature-card {
    /* Cards CARRY their gem identity at rest — not a neutral surface that
     * lights up to a jewel. The base color is the gem's `*-soft` variant
     * (dark hue-tinted surface defined in theme.css), so even idle the
     * card reads as "this is a ruby card." Light effects layer on top to
     * amplify, not to create the tint from neutral.
     *
     * Default: --card-soft falls back to a darker amethyst tint when no
     * gem prop is passed. Each `data-gem="<name>"` selector below sets
     * --card-soft to that gem's soft variant. */
    --card-soft: color-mix(in oklab, var(--gray-7) 60%, var(--card-accent, var(--primary)));
    --card: var(--card-soft);
    position: relative;
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 3);
    padding: calc(var(--spacing) * 5) calc(var(--spacing) * 5)
      calc(var(--spacing) * 6);
    background: var(--card-soft);
    border-radius: calc(var(--radius) - 2px);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  /* ── Foil rim system ──
   *
   * Three layers stacked on the .card-edge ring (1.5px thick, masked).
   * All three respond to the same motion.ts vars (--scene-angle for
   * ambient day-cycle, --light-angle for cursor angle, --mx/--my for
   * cursor position, --mouse-active 0..1 for hover scalar):
   *
   *   1. Base conic — broad scene-angle rim. The ambient lit half.
   *   2. ::before  — narrow cursor-driven HOTSPOT on the rim. Tracks
   *                  --light-angle. Fades in with --mouse-active.
   *   3. ::after   — star-shaped lens flare anchored to (--mx, --my)
   *                  with mix-blend-mode: screen. Fades in with
   *                  --mouse-active.
   *
   * Together they read as a foil card: ambient scene light bathes the
   * lit half, the cursor drags a sharp glint along the rim, and a
   * star flare blooms where the eye is looking. */
  .feature-card > .card-edge {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    z-index: 4;
    padding: 1.5px;
    background: conic-gradient(
      from calc(var(--effective-light-angle, var(--scene-angle, 135deg)) - 90deg),
      color-mix(in oklab, var(--card-accent, var(--primary)) 80%, transparent) 0deg,
      color-mix(in oklab, var(--card-accent, var(--primary)) 30%, var(--border)) 90deg,
      color-mix(in oklab, var(--border) 90%, transparent) 180deg,
      color-mix(in oklab, var(--card-accent, var(--primary)) 30%, var(--border)) 270deg,
      color-mix(in oklab, var(--card-accent, var(--primary)) 80%, transparent) 360deg
    );
    -webkit-mask:
      linear-gradient(#000, #000) content-box,
      linear-gradient(#000, #000);
    -webkit-mask-composite: xor;
    mask:
      linear-gradient(#000, #000) content-box,
      linear-gradient(#000, #000);
    mask-composite: exclude;
  }

  /* Cursor hotspot: 45°-wide bright peak centered AT --light-angle
   * (the cursor's angular position from card center). mix-blend-mode:
   * screen lifts the color into a glint above the base rim. The
   * `from` offset is `--light-angle - 22deg` so that the gradient's
   * peak (22deg into the cycle) lands exactly at light-angle — i.e.
   * the rim glint is on the SAME side as the cursor, not opposite.
   * Opacity tracks --mouse-active. */
  .feature-card > .card-edge::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1.5px;
    background: conic-gradient(
      from calc(var(--light-angle, 135deg) - 22deg),
      transparent 0deg,
      color-mix(in oklab, white 70%, var(--card-accent, var(--primary))) 22deg,
      transparent 45deg,
      transparent 360deg
    );
    -webkit-mask:
      linear-gradient(#000, #000) content-box,
      linear-gradient(#000, #000);
    -webkit-mask-composite: xor;
    mask:
      linear-gradient(#000, #000) content-box,
      linear-gradient(#000, #000);
    mask-composite: exclude;
    opacity: calc(var(--mouse-active, 0) * 0.85);
    mix-blend-mode: screen;
    pointer-events: none;
  }

  /* Lens-flare star: small radial bloom + star burst, anchored at
   * the cursor (--mx/--my). mix-blend-mode: screen so it brightens
   * the rim where the eye is. Sized as a fraction of the card so it
   * scales with viewport. The outer rays come from a radial-gradient
   * with mask so they read as a soft 4-point star, not a literal
   * polygon. */
  .feature-card > .card-edge::after {
    content: '';
    position: absolute;
    left: var(--mx, 50%);
    top: var(--my, 50%);
    width: 7rem;
    height: 7rem;
    transform: translate(-50%, -50%);
    background:
      /* Center hot-point */
      radial-gradient(
        closest-side,
        color-mix(in oklab, white 80%, var(--card-accent, var(--primary))) 0%,
        color-mix(in oklab, var(--card-accent, var(--primary)) 60%, transparent) 12%,
        transparent 35%
      );
    /* Star rays via mask: cross-shape brightens orthogonal axes */
    -webkit-mask:
      linear-gradient(0deg, transparent 42%, #000 50%, transparent 58%),
      linear-gradient(90deg, transparent 42%, #000 50%, transparent 58%),
      radial-gradient(closest-side, #000 0%, #000 30%, transparent 60%);
    -webkit-mask-composite: source-over;
    mask:
      linear-gradient(0deg, transparent 42%, #000 50%, transparent 58%),
      linear-gradient(90deg, transparent 42%, #000 50%, transparent 58%),
      radial-gradient(closest-side, #000 0%, #000 30%, transparent 60%);
    mask-composite: add;
    opacity: calc(var(--mouse-active, 0) * 0.55);
    mix-blend-mode: screen;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .feature-card > .card-edge {
      background: var(--border);
    }
    .feature-card > .card-edge::before,
    .feature-card > .card-edge::after {
      display: none;
    }
  }

  /* Per-gem resting tint — pulls from the dedicated gem-soft tokens
   * defined in theme.css (each is a low-chroma dark surface with the
   * gem's hue baked in, designed for exactly this). */
  .feature-card[data-gem='gold'] { --card-soft: var(--gold-soft); }
  .feature-card[data-gem='ruby'] { --card-soft: var(--ruby-soft); }
  .feature-card[data-gem='emerald'] { --card-soft: var(--emerald-soft); }
  .feature-card[data-gem='diamond'] { --card-soft: var(--diamond-soft); }
  .feature-card[data-gem='amethyst'] { --card-soft: var(--amethyst-soft); }
  .feature-card[data-gem='pink'] { --card-soft: var(--pink-soft); }
  .feature-card[data-gem='salmon'] { --card-soft: var(--salmon-soft); }
  .feature-card[data-gem='turquoize'] { --card-soft: var(--turquoize-soft); }

  /* No transform override on hover — that would clobber .u-light's
   * perspective tilt. The foil rim (.card-edge + ::before glint +
   * ::after star flare) carries the cursor-reactive feedback; we
   * don't need a gem-tinted halo lift on top of it. */

  /* Header row — icon + title sit inline, vertically centered. Replaces
   * the previous stacked icon-on-top-of-title layout so the title can
   * breathe at a larger display size. */
  .head {
    display: flex;
    align-items: center;
    gap: calc(var(--spacing) * 3);
    margin-bottom: calc(var(--spacing) * 1);
  }

  .icon-wrap {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: calc(var(--radius) - 4px);
    background-color: color-mix(in oklab, var(--card-accent, var(--primary)) 18%, transparent);
    color: var(--card-accent, var(--primary));
  }

  .title {
    font-family: 'Public Sans', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1.375rem;
    line-height: 1.2;
    letter-spacing: -0.018em;
    color: var(--foreground);
    margin: 0;
  }

  .stat-block {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    margin-top: calc(var(--spacing) * 1);
  }

  .stat-value {
    font-family: 'Commit Mono', 'JetBrains Mono', ui-monospace, monospace;
    font-feature-settings:
      'tnum' 1,
      'ss01' 1;
    font-size: 1.625rem;
    font-weight: 500;
    color: var(--foreground);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-family: 'Public Sans', system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.6875rem;
    color: var(--muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .description {
    /* flex: 1 inside the column-flex .feature-card claims remaining
     * height so cards in a grid row settle to a consistent height
     * regardless of how much body copy each carries. */
    flex: 1;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--muted-foreground);
    margin: 0;
  }
</style>
