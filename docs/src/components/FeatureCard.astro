---
/**
 * FeatureCard — restrained, token-driven card for the landing page feature
 * grid. Distilled from the original retro-themed variant explosion to a
 * single quiet treatment that lets the icon + title carry the differentiation
 * (Design Context principle: density without noise; quiet layout, expressive
 * details).
 *
 * The legacy `color` prop is accepted but ignored; existing MDX call sites
 * that still pass it continue to compile, and we remove the prop from call
 * sites incrementally without an MDX-wide sweep.
 */
import Icon from './Icon.astro'

interface Props {
  icon?: string
  title: string
  /** @deprecated Retained for backward-compat with existing MDX. Ignored. */
  color?: string
  stat?: string
  statLabel?: string
}

const { icon, title, stat, statLabel } = Astro.props
---

<article class="feature-card" data-sound="card">
  {icon && (
    <span class="icon-wrap" aria-hidden="true">
      <Icon name={icon} size="1.5rem" />
    </span>
  )}
  <h3 class="title" set:html={title} />
  {stat && (
    <div class="stat-block">
      <span class="stat-value">{stat}</span>
      {statLabel && <span class="stat-label">{statLabel}</span>}
    </div>
  )}
  <p class="description"><slot /></p>
</article>

<style>
  .feature-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 3);
    padding: calc(var(--spacing) * 5) calc(var(--spacing) * 5)
      calc(var(--spacing) * 6);
    background-color: color-mix(in oklab, var(--card) 96%, var(--primary));
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) - 2px);
    transition:
      border-color 180ms ease,
      transform 180ms ease,
      background-color 180ms ease;
  }

  .feature-card:hover {
    border-color: color-mix(in oklab, var(--primary) 35%, var(--border));
    transform: translateY(-2px);
  }

  .icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: calc(var(--radius) - 4px);
    background-color: color-mix(in oklab, var(--primary) 12%, transparent);
    color: var(--primary);
  }

  .title {
    font-family: 'Public Sans', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1.0625rem;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--foreground);
    margin: 0;
  }

  .stat-block {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    margin-top: calc(var(--spacing) * 1);
  }

  .stat-value {
    font-family: 'Commit Mono', 'JetBrains Mono', ui-monospace, monospace;
    font-feature-settings:
      'tnum' 1,
      'ss01' 1;
    font-size: 1.625rem;
    font-weight: 500;
    color: var(--foreground);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.6875rem;
    color: var(--muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .description {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--muted-foreground);
    margin: 0;
  }
</style>
