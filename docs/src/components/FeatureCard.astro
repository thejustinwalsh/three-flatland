---
/**
 * FeatureCard — gem-accented card for the landing page feature grid.
 *
 * Pass `color="<gem>"` to anchor the card to a specific accent from the
 * design system's gem palette: gold, ruby, emerald, diamond, amethyst,
 * pink, salmon, turquoize. The accent drives the icon hue, hover border,
 * and a soft tint behind the surface (per Design Context: color-as-taxonomy,
 * cards opt into the palette).
 *
 * Without `color`, the card falls back to `--primary` (amethyst) so plain
 * `<FeatureCard title="…">` calls render coherently against the rest of
 * the design system without forcing every author to pick a gem.
 */
import Icon from './Icon.astro'

type Gem =
  | 'gold'
  | 'ruby'
  | 'emerald'
  | 'diamond'
  | 'amethyst'
  | 'pink'
  | 'salmon'
  | 'turquoize'

/** Conventional color names accepted for transitional compat with existing
 * MDX call sites — mapped to the closest gem at render time. */
type LegacyColor = 'cyan' | 'blue' | 'green' | 'orange' | 'red' | 'yellow' | 'purple'

const legacyToGem: Record<LegacyColor, Gem> = {
  cyan: 'diamond',
  blue: 'diamond',
  green: 'emerald',
  orange: 'gold',
  red: 'ruby',
  yellow: 'gold',
  purple: 'amethyst',
}

interface Props {
  icon?: string
  title: string
  /** Gem accent — picks from the design-system palette. Defaults to `--primary`.
   *  Conventional names (cyan, blue, green, orange, red, yellow, purple) are
   *  accepted for compat and mapped to gems. */
  color?: Gem | LegacyColor
  stat?: string
  statLabel?: string
}

const { icon, title, color, stat, statLabel } = Astro.props

const resolvedGem: Gem | undefined = color
  ? (color in legacyToGem ? legacyToGem[color as LegacyColor] : (color as Gem))
  : undefined

const accentStyle = resolvedGem ? `--card-accent: var(--${resolvedGem});` : undefined
---

<article class="feature-card u-light u-rim u-reveal" data-sound="card" data-gem={resolvedGem} style={accentStyle}>
  {icon && (
    <span class="icon-wrap" aria-hidden="true">
      <Icon name={icon} size="1.5rem" />
    </span>
  )}
  <h3 class="title" set:html={title} />
  {stat && (
    <div class="stat-block">
      <span class="stat-value">{stat}</span>
      {statLabel && <span class="stat-label">{statLabel}</span>}
    </div>
  )}
  <p class="description"><slot /></p>
</article>

<style>
  .feature-card {
    /* The .u-rim primitive owns the border + background-clip layering, so
     * we don't set a `background-color` here directly — it'd paint over
     * the rim's padding-box layer. Instead, we override the rim's
     * padding-box layer with a gem-tinted card surface via --card. */
    --card: color-mix(in oklab, oklch(20% 0.008 250) 92%, var(--card-accent, var(--primary)));
    position: relative;
    display: flex;
    flex-direction: column;
    gap: calc(var(--spacing) * 3);
    padding: calc(var(--spacing) * 5) calc(var(--spacing) * 5)
      calc(var(--spacing) * 6);
    border-radius: calc(var(--radius) - 2px);
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  :root[data-theme='light'] .feature-card {
    --card: color-mix(in oklab, oklch(98% 0.008 80) 92%, var(--card-accent, var(--primary)));
  }

  .feature-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px -12px color-mix(in oklab, var(--card-accent, var(--primary)) 30%, transparent);
  }

  .icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: calc(var(--radius) - 4px);
    background-color: color-mix(in oklab, var(--card-accent, var(--primary)) 18%, transparent);
    color: var(--card-accent, var(--primary));
  }

  .title {
    font-family: 'Public Sans', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1.0625rem;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--foreground);
    margin: 0;
  }

  .stat-block {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    margin-top: calc(var(--spacing) * 1);
  }

  .stat-value {
    font-family: 'Commit Mono', 'JetBrains Mono', ui-monospace, monospace;
    font-feature-settings:
      'tnum' 1,
      'ss01' 1;
    font-size: 1.625rem;
    font-weight: 500;
    color: var(--foreground);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-family: 'Public Sans', system-ui, sans-serif;
    font-weight: 500;
    font-size: 0.6875rem;
    color: var(--muted-foreground);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .description {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--muted-foreground);
    margin: 0;
  }
</style>
