---
/**
 * ExampleSplitView — side-by-side preview + code with a draggable
 * resizer. Live iframe on one side, syntax-highlighted multi-file
 * code viewer on the other. Toolbar carries Three / React variant
 * toggle, fullscreen, and an Open-in-StackBlitz CTA.
 *
 * Variant toggle (Three.js / React) drives:
 *   - iframe `src` swap
 *   - visible `.code-pane` swap (CSS attribute selector on
 *     `data-variant`)
 *   - StackBlitz link's href (points at the GitHub `examples/<variant>/<slug>`
 *     subtree)
 *   - Persisted to sessionStorage as `flatland-example-type` so the
 *     state resets between visits — users get defaults on return and
 *     don't lose track of where the panel went on the previous visit.
 *
 * File tabs — for variants with more than one source file, a tab
 * strip lets the user switch between files. Boilerplate
 * (package.json, tsconfig.json, vite.config.ts) is filtered out;
 * the entry file (main.ts / App.tsx) is the default-active tab.
 *
 * Drag handle clamps to 25%–80%, persisted to sessionStorage as
 * `flatland-example-split`. Iframe gets `pointer-events: none`
 * during drag so the parent document keeps receiving pointermove
 * events when the cursor crosses the canvas.
 */
import { Code } from '@astrojs/starlight/components'

interface Props {
    slug: string
    threeFiles: Record<string, string>
    reactFiles: Record<string, string>
    /** Explicit list of files to surface in the Three.js code panel.
     *  Omit to show ONLY the entry file (`main.ts` / `main.tsx`).
     *  Pass an array (e.g. `['main.ts', 'src/util.ts']`) to expose
     *  multi-file browsing — useful for minis with many source
     *  files; overkill for the typical single-file example. */
    showThreeFiles?: string[]
    /** Same as `showThreeFiles` but for the React variant. Default
     *  is the entry file (`App.tsx` / `main.tsx`). */
    showReactFiles?: string[]
    /** Files that should appear in BOTH variant code panels — sprite
     *  atlases, ldtk maps, sprite sheets, anything the Three and
     *  React versions consume identically. Each filename here is
     *  added to both `showThreeFiles` and `showReactFiles` so it
     *  shows up as a tab on both panes (with whichever variant's
     *  copy of the file). Use the path as it appears in the file
     *  map — typically `public/sprites/foo.json` etc. */
    showCommonFiles?: string[]
}

const { slug, threeFiles, reactFiles, showThreeFiles, showReactFiles, showCommonFiles } = Astro.props

/** Boilerplate paths that aren't worth showing in the in-page code
 *  viewer — they're regenerated by `loadExample()` and would only
 *  add noise. The full set IS still passed to StackBlitz so the
 *  exported project runs out-of-the-box. */
const HIDDEN_FILES = new Set(['package.json', 'tsconfig.json', 'vite.config.ts'])

/** File-extension → expressive-code language hint. */
function langFor(filename: string): string {
    const ext = filename.split('.').pop() || ''
    if (ext === 'ts') return 'ts'
    if (ext === 'tsx') return 'tsx'
    if (ext === 'js') return 'js'
    if (ext === 'jsx') return 'jsx'
    if (ext === 'mjs') return 'js'
    if (ext === 'json') return 'json'
    if (ext === 'css') return 'css'
    if (ext === 'html') return 'html'
    if (ext === 'glsl' || ext === 'wgsl') return 'glsl'
    return 'text'
}

/** Order-of-importance for the file tab strip. Entry file first,
 *  src/* in lexical order, then the rest. */
function orderFiles(entries: [string, string][], primary: string): [string, string][] {
    const visible = entries.filter(([k]) => !HIDDEN_FILES.has(k))
    visible.sort(([a], [b]) => {
        if (a === primary) return -1
        if (b === primary) return 1
        const aSrc = a.startsWith('src/')
        const bSrc = b.startsWith('src/')
        if (aSrc && !bSrc) return -1
        if (bSrc && !aSrc) return 1
        return a.localeCompare(b)
    })
    return visible
}

const threePrimary = 'main.ts' in threeFiles ? 'main.ts' : 'main.tsx' in threeFiles ? 'main.tsx' : Object.keys(threeFiles)[0] ?? ''
const reactPrimary = 'App.tsx' in reactFiles ? 'App.tsx' : 'main.tsx' in reactFiles ? 'main.tsx' : Object.keys(reactFiles)[0] ?? ''

// Default to entry-file-only when the host MDX hasn't opted into
// multi-file browsing. Examples are usually single-file; minis and
// any explicitly-multi-file example pass `showThreeFiles` /
// `showReactFiles` to surface additional sources.
//
// `showCommonFiles` (atlas json, ldtk maps, sprite sheets) is
// merged into BOTH whitelists so the file appears as a tab on
// both variant panes.
const common = showCommonFiles ?? []
const threeWhitelist = [...(showThreeFiles ?? [threePrimary]), ...common]
const reactWhitelist = [...(showReactFiles ?? [reactPrimary]), ...common]

function pickFiles(files: Record<string, string>, whitelist: string[], primary: string): [string, string][] {
    const allow = new Set(whitelist)
    return orderFiles(Object.entries(files).filter(([k]) => allow.has(k)), primary)
}

const threeOrdered = pickFiles(threeFiles, threeWhitelist, threePrimary)
const reactOrdered = pickFiles(reactFiles, reactWhitelist, reactPrimary)

const baseURL = (import.meta.env.BASE_URL || '/').replace(/\/$/, '')
const examplesPort = (import.meta.env.VITE_EXAMPLES_PORT as string) || ''
const isDev = import.meta.env.DEV

/* Iframe URL — cross-origin in dev, same-origin in prod.
 *   - Dev: direct to the examples MPA server (different port).
 *     Safari throttles rAF in cross-origin iframes until the user
 *     clicks inside the frame; an attempted same-origin proxy hit
 *     unworkable Vite-internal-path collisions between the two Vite
 *     instances (/@vite/client, /@react-refresh, dep cache), so we
 *     accept the one-time click as the dev-mode trade-off.
 *   - Prod: static file copied into `docs/dist/examples/...` at
 *     build time — same-origin, no throttle. */
const threeSrc = isDev
    ? `http://localhost:${examplesPort}/three/${slug}/`
    : `${baseURL}/examples/three/${slug}/`
const reactSrc = isDev
    ? `http://localhost:${examplesPort}/react/${slug}/`
    : `${baseURL}/examples/react/${slug}/`

// GitHub source URLs — link straight to the example's directory on
// the repo so users can clone or copy via degit. Variant-aware so
// the link retargets when toggling Three/React.
const githubBase = 'https://github.com/thejustinwalsh/three-flatland/tree/main'
const threeGithubHref = `${githubBase}/examples/three/${slug}`
const reactGithubHref = `${githubBase}/examples/react/${slug}`

// StackBlitz import — uses the GitHub bridge URL
// (stackblitz.com/github/<repo>/tree/<branch>/<subdir>) so StackBlitz
// forks the example directly from GitHub. Slower than `sdk.openProject`
// with an inline payload, but doesn't require bundling the SDK and
// works reliably in dev where the SDK's dynamic import was choking on
// Vite optimizeDeps cache pollution. Variant-aware: the button picks
// the right /three/ or /react/ subdir based on the active variant.
const threeStackblitzHref = `https://stackblitz.com/github/thejustinwalsh/three-flatland/tree/main/examples/three/${slug}`
const reactStackblitzHref = `https://stackblitz.com/github/thejustinwalsh/three-flatland/tree/main/examples/react/${slug}`

const transitionName = `tile-examples-${slug}`
---

{/* No-flash state restore. The on-load bind script reads sessionStorage
   only AFTER DOMContentLoaded, which is after first paint — so the
   panel renders at its inline-styled default (50%) then snaps to the
   saved value, causing visible layout shift on reload. This inline
   script runs synchronously at parse-time, BEFORE the .example-split
   div below is laid out, and applies stored split / expand / code-
   collapsed state to the document element via CSS variables and
   attributes. The element inherits the var, picks up the attribute
   selectors, and paints in the correct state on the very first frame. */}
<script is:inline>
  (() => {
    try {
      const saved = parseFloat(sessionStorage.getItem('flatland-example-split') || '')
      if (Number.isFinite(saved) && saved >= 25 && saved <= 80) {
        document.documentElement.style.setProperty('--split', saved + '%')
      }
      if (sessionStorage.getItem('flatland-example-expanded') === '1') {
        document.documentElement.setAttribute('data-pre-expanded', 'true')
      }
      if (sessionStorage.getItem('flatland-example-code-collapsed') === '1') {
        document.documentElement.setAttribute('data-pre-code-collapsed', 'true')
      }
    } catch {}
  })()
</script>
<div
    class="example-split"
    data-slug={slug}
    data-variant="three"
>
    <div class="example-split-toolbar">
        <div class="variant-toggle" role="tablist" aria-label="Source variant">
            <button
                type="button"
                role="tab"
                aria-selected="true"
                data-variant-target="three"
            >
                <span class="i-simple-icons:threedotjs variant-icon" aria-hidden="true"></span>
                Three.js
            </button>
            <button
                type="button"
                role="tab"
                aria-selected="false"
                data-variant-target="react"
            >
                <span class="i-simple-icons:react variant-icon" aria-hidden="true"></span>
                React
            </button>
        </div>
        <div class="example-split-toolbar-actions">
            <a
                class="toolbar-btn github-btn"
                href={threeGithubHref}
                data-three-href={threeGithubHref}
                data-react-href={reactGithubHref}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="View source on GitHub"
                title="View source on GitHub"
            >
                <span class="i-lucide:github" aria-hidden="true"></span>
            </a>
            <a
                class="toolbar-btn stackblitz-btn"
                href={threeStackblitzHref}
                data-three-href={threeStackblitzHref}
                data-react-href={reactStackblitzHref}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Open in StackBlitz"
                title="Open in StackBlitz"
            >
                <span class="i-simple-icons:stackblitz" aria-hidden="true"></span>
            </a>
            <button type="button" class="toolbar-btn" data-fullscreen aria-label="Fullscreen preview" title="Fullscreen preview">
                <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
                    <path
                        d="M3 6V3h3M13 6V3h-3M3 10v3h3M13 10v3h-3"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        fill="none"
                    />
                </svg>
            </button>
            <button type="button" class="toolbar-btn code-toggle-btn" data-code-toggle aria-label="Hide code panel" title="Hide code panel">
                <span class="i-lucide:panel-right-close code-toggle-icon" aria-hidden="true"></span>
            </button>
        </div>
    </div>

    <div class="example-split-grid">
        <div class="example-split-pane example-split-preview">
            <iframe
                data-three-src={threeSrc}
                data-react-src={reactSrc}
                src={threeSrc}
                title={`${slug} preview`}
                allow="cross-origin-isolated"
                style={`view-transition-name: ${transitionName};`}
            ></iframe>
        </div>
        <div
            class="example-split-handle"
            role="separator"
            aria-orientation="vertical"
            aria-label="Resize preview and code panels"
            aria-valuenow="50"
            aria-valuemin="25"
            aria-valuemax="80"
            tabindex="0"
        ></div>
        <div class="example-split-pane example-split-code">
            <div class="code-pane" data-variant-pane="three">
                <div class="file-tabs" aria-label="Files">
                    <button
                        type="button"
                        class="expand-btn"
                        data-expand-toggle
                        aria-label="Expand code panel"
                        title="Expand code panel"
                    >
                        <span class="i-lucide:chevrons-left expand-icon" aria-hidden="true"></span>
                    </button>
                    {threeOrdered.map(([filename], i) => (
                        <button
                            type="button"
                            role="tab"
                            class="file-tab"
                            data-file-tab={filename}
                            aria-selected={i === 0 ? 'true' : 'false'}
                        >
                            {filename}
                        </button>
                    ))}
                </div>
                {threeOrdered.map(([filename, content], i) => (
                    <div
                        class="file-content"
                        data-file-content={filename}
                        hidden={i !== 0 ? true : undefined}
                    >
                        <Code code={content} lang={langFor(filename)} meta="showLineNumbers" />
                    </div>
                ))}
            </div>
            <div class="code-pane" data-variant-pane="react">
                <div class="file-tabs" aria-label="Files">
                    <button
                        type="button"
                        class="expand-btn"
                        data-expand-toggle
                        aria-label="Expand code panel"
                        title="Expand code panel"
                    >
                        <span class="i-lucide:chevrons-left expand-icon" aria-hidden="true"></span>
                    </button>
                    {reactOrdered.map(([filename], i) => (
                        <button
                            type="button"
                            role="tab"
                            class="file-tab"
                            data-file-tab={filename}
                            aria-selected={i === 0 ? 'true' : 'false'}
                        >
                            {filename}
                        </button>
                    ))}
                </div>
                {reactOrdered.map(([filename, content], i) => (
                    <div
                        class="file-content"
                        data-file-content={filename}
                        hidden={i !== 0 ? true : undefined}
                    >
                        <Code code={content} lang={langFor(filename)} meta="showLineNumbers" />
                    </div>
                ))}
            </div>
        </div>
    </div>
</div>

<style>
    .example-split {
        /* `--split` intentionally NOT declared locally — it inherits
         * from `:root` where the inline-script in this file sets it
         * from sessionStorage at parse-time (before first paint), or
         * stays unset and the `var(--split, 50%)` fallback below
         * provides the SSR default. Declaring it locally here would
         * override the inherited value and reintroduce the layout
         * shift on reload. */
        --handle: 8px;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .example-split-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
    }

    .example-split-toolbar-actions {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
    }

    .variant-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0;
        padding: 0.1875rem;
        border-radius: calc(var(--radius) - 2px);
        background: color-mix(in oklab, var(--card) 92%, var(--background));
        box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--border) 70%, transparent);
    }

    .variant-toggle button {
        appearance: none;
        background: transparent;
        border: 0;
        padding: 0.3125rem 0.625rem;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--muted-foreground);
        border-radius: calc(var(--radius) - 4px);
        cursor: pointer;
        transition: color 0.15s, background-color 0.15s;
    }

    .variant-toggle button:hover {
        color: var(--foreground);
    }

    .variant-toggle button[aria-selected='true'] {
        background-color: var(--background);
        color: color-mix(in oklab, var(--diamond) 65%, var(--foreground));
        box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--diamond) 30%, var(--border));
    }

    .variant-icon {
        width: 0.875rem;
        height: 0.875rem;
    }

    .toolbar-btn {
        appearance: none;
        background: transparent;
        border: 0;
        padding: 0.4rem 0.5rem;
        color: var(--muted-foreground);
        border-radius: calc(var(--radius) - 4px);
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: color 0.15s, background-color 0.15s;
    }

    .toolbar-btn:hover {
        color: var(--diamond);
        background-color: color-mix(in oklab, var(--diamond) 10%, transparent);
    }

    .stackblitz-btn span {
        width: 1rem;
        height: 1rem;
    }

    .example-split-grid {
        display: grid;
        /* `minmax(0, 1fr)` on the code track — a plain `1fr` track has
         * an implicit `auto` minimum and grows to its min-content size.
         * The code pane hosts expressive-code <pre> blocks with
         * unwrappable lines, so a plain `1fr` would push the entire
         * grid past viewport width and produce a document-level
         * horizontal scrollbar instead of a local one inside the
         * `.file-content` overflow:auto box. `minmax(0, …)` clamps the
         * track minimum to 0 so the pane is sized by the available
         * grid width and wide code lines scroll inside `.file-content`
         * the way users expect. */
        grid-template-columns: var(--split, 50%) var(--handle) minmax(0, 1fr);
        gap: 0;
        height: 70vh;
        min-height: 32rem;
        max-height: 56rem;
        border-radius: calc(var(--radius) + 0.25rem);
        overflow: hidden;
        background: var(--card);
        /* 1px gem-tinted border ring only — the diamond-tinted drop glow
         * underneath read as generic decorative halo, not lift. The border
         * defines the surface; restraint over chroma. */
        box-shadow: 0 0 0 1px color-mix(in oklab, var(--border) 75%, transparent);
        /* No transition by default — drag updates `--split` per
         * pointermove and any grid-template-columns transition would
         * make every drag frame visibly lag through the easing curve.
         * Transition is opted in by `is-toggling` (set by the chevron
         * click handler for the duration of the expand/collapse
         * animation only). */
    }

    /* Expanded mode — code panel takes the full grid width. The
     * iframe column collapses to 0 (still in DOM, just zero size,
     * no remount). Click chevron again to animate back to the
     * previous split position. */
    .example-split[data-expanded='true'] .example-split-grid {
        grid-template-columns: 0px 0px 1fr;
    }

    /* Code-pane collapsed mode — code panel completely hidden via
     * `display: none` on the code-side tracks AFTER the animation
     * finishes. Two attributes drive the state machine:
     *   - `data-code-collapsing="true"` (transient) — code pane is
     *     still rendered but the grid track widths animate to
     *     `1fr 0 0`. Triggers the existing `is-toggling` transition.
     *   - `data-code-collapsed="true"` (settled) — code pane +
     *     handle are `display: none`, full DOM weight gone from the
     *     paint/layout tree. Grid simplifies to `1fr`.
     * JS coordinates the handoff in `setCodeCollapsed()` so the
     * animation plays to completion, THEN the display flip lands. */
    .example-split[data-code-collapsing='true'] .example-split-grid {
        grid-template-columns: 1fr 0px 0px;
    }
    .example-split[data-code-collapsed='true'] .example-split-grid {
        grid-template-columns: 1fr;
    }
    .example-split[data-code-collapsed='true'] .example-split-handle,
    .example-split[data-code-collapsed='true'] .example-split-code {
        display: none;
    }

    /* Transition window — the JS adds `is-toggling` to the root for
     * ~350ms around an expand/collapse click, then removes it. Drag
     * gestures (which mutate `--split` directly) never see this
     * transition, so resize stays 60fps. Browsers (Chrome 117+,
     * Firefox 96+, Safari 16+) interpolate grid-template-columns
     * when track sizes are length-percentage pairs. */
    .example-split.is-toggling .example-split-grid {
        transition: grid-template-columns 320ms cubic-bezier(0.4, 0, 0.2, 1);
    }
    .example-split.is-toggling .example-split-handle {
        transition: opacity 200ms ease-out;
    }

    .example-split[data-expanded='true'] .example-split-handle {
        pointer-events: none;
        opacity: 0;
    }

    .example-split[data-expanded='true'] .example-split-preview {
        pointer-events: none;
    }

    .example-split-pane {
        position: relative;
        overflow: hidden;
        min-width: 0;
        /* Paint isolation — `.example-split-preview` hosts the example
         * iframe and `.example-split-code` hosts a potentially-long
         * expressive-code DOM tree. Without paint containment the two
         * panes (and the surrounding docs page) share a single paint
         * region, so any style invalidation in one re-rasterizes the
         * whole grid. `contain: paint` declares the pane a paint
         * boundary so invalidations stop at its edges — Safari can
         * keep the iframe compositor layer hot independent of code-
         * pane churn. */
        contain: paint;
    }

    /* Promote the iframe to its OWN compositor layer. `contain: paint`
     * on the surrounding pane gives Safari a paint boundary, but its
     * iframe-paint-coupling heuristics in WebKit still drag adjacent
     * tiles into the same composite cycle (we measured paint at 60%
     * CPU per tick with parent regions repainting alongside iframe
     * canvas updates). `will-change: transform` + `transform: translateZ(0)`
     * forces a dedicated GPU-backed layer so iframe frames blit
     * independently of parent compositing. `isolation: isolate`
     * caps stacking-context interactions. */
    .example-split-preview {
        isolation: isolate;
    }
    .example-split-preview iframe {
        will-change: transform;
        transform: translateZ(0);
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: 0;
        background: #1a1a2e;
        color-scheme: dark;
    }

    /* Drag fix — during a resize gesture, swallow pointer events on
     * the iframe so the cursor crossing the canvas doesn't sever the
     * parent document's pointermove stream. The handle's `data-dragging`
     * lasts only for the gesture; iframe is interactive again at
     * pointerup. */
    .example-split[data-dragging='true'] .example-split-preview iframe {
        pointer-events: none;
    }

    .example-split-handle {
        cursor: col-resize;
        background: color-mix(in oklab, var(--border) 70%, transparent);
        transition: background-color 0.15s;
        position: relative;
    }

    .example-split-handle::before {
        content: '';
        position: absolute;
        left: 50%;
        top: 50%;
        width: 2px;
        height: 2.5rem;
        transform: translate(-50%, -50%);
        background: color-mix(in oklab, var(--diamond) 50%, var(--muted-foreground));
        border-radius: 1px;
        pointer-events: none;
    }

    .example-split-handle:hover,
    .example-split-handle:focus-visible,
    .example-split[data-dragging='true'] .example-split-handle {
        background: color-mix(in oklab, var(--diamond) 25%, var(--border));
    }
    .example-split-handle:focus-visible {
        outline: 2px solid var(--diamond);
        outline-offset: -2px;
    }

    .example-split-code {
        background: var(--code-background);
        display: flex;
        flex-direction: column;
        /* Same compositor-layer treatment as the iframe pane — but
         * lighter: this pane is mostly static (~2000 nested syntax-
         * token spans, no per-frame updates), so we don't need the
         * full `will-change: transform` "high-mutation" hint. Plain
         * `translateZ(0)` + `isolation: isolate` is enough to force
         * Safari to rasterize the code-pane DOM ONCE and blit the
         * resulting texture on every composite, instead of touching
         * the 2000-node subtree each time the adjacent iframe canvas
         * triggers a parent-region paint. */
        isolation: isolate;
        transform: translateZ(0);
    }

    .code-pane {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        /* Stack a second paint barrier inside the right pane — the file-
         * content scroll container can hold a few hundred expressive-code
         * line elements; without contain, paint invalidations from inside
         * (scroll, hover, syntax highlight rehydration) can bubble up to
         * the surrounding grid. */
        contain: paint;
    }

    .example-split[data-variant='three'] .code-pane[data-variant-pane='react'],
    .example-split[data-variant='react'] .code-pane[data-variant-pane='three'] {
        display: none;
    }

    /* File tab strip — sits above the code content, scrolls horizontally
     * when there are many files. Active tab carries the diamond
     * gem accent matching the variant-toggle treatment. */
    .file-tabs {
        flex: 0 0 auto;
        display: flex;
        align-items: center;
        gap: 0;
        overflow-x: auto;
        scrollbar-width: thin;
        background: color-mix(in oklab, var(--card) 92%, var(--code-background));
        border-bottom: 1px solid color-mix(in oklab, var(--border) 60%, transparent);
        padding: 0.25rem 0.375rem;
    }

    .file-tab {
        appearance: none;
        background: transparent;
        border: 0;
        padding: 0.375rem 0.625rem;
        font-family: 'Commit Mono', 'JetBrains Mono', ui-monospace, SFMono-Regular, monospace;
        font-size: 0.75rem;
        color: var(--muted-foreground);
        border-radius: calc(var(--radius) - 4px);
        cursor: pointer;
        white-space: nowrap;
        transition: color 0.15s, background-color 0.15s;
    }

    /* Expand-collapse chevron — first item in the file-tabs strip,
     * controls the whole split (visible from either pane). Icon
     * rotates 180° in expanded state so it always points "back to
     * where you came from": chevrons-left in split mode (push to
     * left, expand right), chevrons-right in expanded mode (return
     * to split). Hairline divider on the right separates it from
     * the file tabs. */
    .expand-btn {
        appearance: none;
        background: transparent;
        border: 0;
        padding: 0.375rem 0.5rem;
        margin-right: 0.25rem;
        color: color-mix(in oklab, var(--diamond) 55%, var(--muted-foreground));
        border-radius: calc(var(--radius) - 4px);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: color 0.15s, background-color 0.15s;
        position: relative;
    }

    .expand-btn:hover {
        color: var(--diamond);
        background-color: color-mix(in oklab, var(--diamond) 10%, transparent);
    }

    .expand-btn::after {
        content: '';
        position: absolute;
        right: -0.125rem;
        top: 25%;
        bottom: 25%;
        width: 1px;
        background-color: color-mix(in oklab, var(--border) 70%, transparent);
    }

    .expand-icon {
        width: 0.875rem;
        height: 0.875rem;
        transition: transform 240ms cubic-bezier(0.4, 0, 0.2, 1);
    }

    .example-split[data-expanded='true'] .expand-icon {
        transform: rotate(180deg);
    }

    .file-tab:hover {
        color: var(--foreground);
        background-color: color-mix(in oklab, var(--background) 35%, transparent);
    }

    .file-tab[aria-selected='true'] {
        color: color-mix(in oklab, var(--diamond) 65%, var(--foreground));
        background-color: var(--background);
        box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--diamond) 30%, var(--border));
    }

    .file-content {
        flex: 1 1 auto;
        overflow: auto;
        background: var(--code-background);
        /* `min-*: 0` overrides the default `min-content` floor of flex
         * children. Without these, a wide expressive-code line pushes
         * the flex item to its content min-width and the overflow:auto
         * scrollbar never appears — the overflow escapes the flex
         * column instead. With them, the file-content sizes to the
         * flex track and wide code lines scroll inside this box. */
        min-width: 0;
        min-height: 0;
    }

    .file-content[hidden] {
        display: none;
    }

    /* expressive-code's frame already has its own border-radius,
     * box-shadow, and chrome from our theme overrides. Inside the
     * code pane, drop those so the Code block sits flush against
     * the file tabs. */
    .file-content :global(.expressive-code) {
        margin: 0;
    }
    .file-content :global(.expressive-code .frame) {
        box-shadow: none;
        border-radius: 0;
        /* Let wide code lines extend horizontally so `.file-content`
         * becomes the horizontal scroll container — its scrollbar then
         * sits at the bottom of the VISIBLE viewport (always reachable)
         * instead of at the bottom of the full ~9000px code content
         * (where the user would have to scroll vertically to the end
         * first to drag it). */
        overflow: visible;
    }
    .file-content :global(.expressive-code pre) {
        border-radius: 0;
        /* See `.frame` rule above — same reasoning. Both this and the
         * figure must be overflow:visible so wide lines bubble up to
         * `.file-content`'s scroll calculation. */
        overflow: visible;
    }
    /* The file tab strip already shows the filename; the
     * expressive-code figcaption duplicates it. Hide the figcaption
     * inside the split view's code panes only — markdown fenced
     * code blocks elsewhere keep their figcaption styling. */
    .file-content :global(.expressive-code figcaption.header) {
        display: none;
    }

    /* `content-visibility: auto` on `.ec-line` was tried for off-screen
     * paint skipping. Safari Timeline showed it BACKFIRED: paint events
     * went from 2 → 34 and main-thread CPU jumped from low single
     * digits to 33% avg. Safari's near-viewport observer cost outweighs
     * the saved paint on a 350-line file. Leaving it off — revisit if
     * we ever have files in the multi-thousand-line range. */

    @media (max-width: 768px) {
        .example-split-grid {
            grid-template-columns: 1fr;
            grid-template-rows: 50vh var(--handle) 1fr;
            height: auto;
            min-height: 0;
            max-height: none;
        }
        .example-split-handle {
            cursor: row-resize;
        }
        .example-split-handle::before {
            width: 2.5rem;
            height: 2px;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .variant-toggle button,
        .toolbar-btn,
        .file-tab,
        .example-split-handle {
            transition: none;
        }
    }
</style>

<script>
    function bindSplitViews() {
        const splits = document.querySelectorAll<HTMLElement>('.example-split:not([data-bound])')
        splits.forEach((root) => {
            root.dataset.bound = '1'

            const toggleButtons = root.querySelectorAll<HTMLButtonElement>(
                '.variant-toggle button[data-variant-target]'
            )
            const iframe = root.querySelector<HTMLIFrameElement>('.example-split-preview iframe')
            const githubLink = root.querySelector<HTMLAnchorElement>('a.github-btn')
            const stackblitzLink = root.querySelector<HTMLAnchorElement>('a.stackblitz-btn')
            const STORAGE_VARIANT = 'flatland-example-type'

            // Active variant — the StackBlitz click handler reads this
            // to pick the right payload script. Captured here so the
            // closure stays current as setVariant() runs.
            let activeVariant: 'three' | 'react' = 'three'

            const restoreVariant = (): 'three' | 'react' => {
                try {
                    const v = sessionStorage.getItem(STORAGE_VARIANT)
                    return v === 'react' || v === 'three' ? v : 'three'
                } catch {
                    return 'three'
                }
            }

            const setVariant = (variant: 'three' | 'react') => {
                activeVariant = variant
                root.dataset.variant = variant
                toggleButtons.forEach((b) => {
                    b.setAttribute(
                        'aria-selected',
                        b.dataset.variantTarget === variant ? 'true' : 'false'
                    )
                })
                if (iframe) {
                    const next = iframe.dataset[`${variant}Src`] || iframe.src
                    if (iframe.src !== next) iframe.src = next
                }
                if (githubLink) {
                    const href = githubLink.dataset[`${variant}Href`]
                    if (href) githubLink.href = href
                }
                if (stackblitzLink) {
                    const href = stackblitzLink.dataset[`${variant}Href`]
                    if (href) stackblitzLink.href = href
                }
                try { sessionStorage.setItem(STORAGE_VARIANT, variant) } catch {}
            }

            setVariant(restoreVariant())

            toggleButtons.forEach((btn) => {
                btn.addEventListener('click', () => {
                    const v = btn.dataset.variantTarget
                    if (v === 'three' || v === 'react') setVariant(v)
                })
            })

            // ─── File tabs ────────────────────────────────────────
            // Each .code-pane has its own file-tab strip + a list of
            // .file-content blocks. Tabs scoped per-variant so the
            // active file persists across variant toggles.
            const codePanes = root.querySelectorAll<HTMLElement>('.code-pane')
            codePanes.forEach((pane) => {
                const tabs = pane.querySelectorAll<HTMLButtonElement>('.file-tab[data-file-tab]')
                const contents = pane.querySelectorAll<HTMLElement>('.file-content[data-file-content]')
                tabs.forEach((tab) => {
                    tab.addEventListener('click', () => {
                        const target = tab.dataset.fileTab
                        tabs.forEach((t) => {
                            t.setAttribute(
                                'aria-selected',
                                t.dataset.fileTab === target ? 'true' : 'false'
                            )
                        })
                        contents.forEach((c) => {
                            if (c.dataset.fileContent === target) c.removeAttribute('hidden')
                            else c.setAttribute('hidden', '')
                        })
                    })
                })
            })

            // ─── Drag handle ──────────────────────────────────────
            const handle = root.querySelector<HTMLElement>('.example-split-handle')
            const grid = root.querySelector<HTMLElement>('.example-split-grid')
            const STORAGE_SPLIT = 'flatland-example-split'

            try {
                const saved = parseFloat(sessionStorage.getItem(STORAGE_SPLIT) || '')
                if (Number.isFinite(saved) && saved >= 25 && saved <= 80) {
                    root.style.setProperty('--split', `${saved}%`)
                }
            } catch {}

            if (handle && grid) {
                let dragging = false
                const isHorizontal = () => window.matchMedia('(min-width: 769px)').matches

                const onMove = (e: PointerEvent) => {
                    if (!dragging) return
                    const rect = grid.getBoundingClientRect()
                    const isHoriz = isHorizontal()
                    const total = isHoriz ? rect.width : rect.height
                    const offset = isHoriz ? e.clientX - rect.left : e.clientY - rect.top
                    let pct = Math.max(25, Math.min(80, (offset / total) * 100))
                    /* Subtle 50% snap with resistance. Inside the snap
                     * zone the cursor's offset from 50% is dampened so
                     * the handle pulls toward center — easy to land
                     * "exactly 50%" without precision dragging, and
                     * inside the dampening band the user feels a soft
                     * tug. Beyond the zone the snap releases and the
                     * cursor controls the handle 1:1 again. */
                    const SNAP_ZONE_PCT = 4       // ±4% around 50% feels the pull
                    const SNAP_THRESHOLD_PCT = 0.6 // dead-center stickiness
                    const delta = pct - 50
                    if (Math.abs(delta) < SNAP_THRESHOLD_PCT) {
                        pct = 50
                    } else if (Math.abs(delta) < SNAP_ZONE_PCT) {
                        // Cubic damping — pull strengthens near center,
                        // releases as the cursor moves away.
                        const t = Math.abs(delta) / SNAP_ZONE_PCT
                        const damped = SNAP_ZONE_PCT * t * t
                        pct = 50 + Math.sign(delta) * damped
                    }
                    root.style.setProperty('--split', `${pct}%`)
                    try { sessionStorage.setItem(STORAGE_SPLIT, pct.toFixed(1)) } catch {}
                }

                const onUp = () => {
                    if (!dragging) return
                    dragging = false
                    root.removeAttribute('data-dragging')
                    document.body.style.removeProperty('user-select')
                    document.body.style.removeProperty('cursor')
                    window.removeEventListener('pointermove', onMove)
                    window.removeEventListener('pointerup', onUp)
                }

                handle.addEventListener('pointerdown', (e) => {
                    e.preventDefault()
                    dragging = true
                    root.setAttribute('data-dragging', 'true')
                    document.body.style.userSelect = 'none'
                    document.body.style.cursor = isHorizontal() ? 'col-resize' : 'row-resize'
                    window.addEventListener('pointermove', onMove)
                    window.addEventListener('pointerup', onUp)
                })

                /* Double-click handle → instant snap to 50% with the
                 * is-toggling transition so the slide reads as a deliberate
                 * action, not a jump. `dblclick` fires for mouse only; touch
                 * devices don't dispatch it (their tap behavior is separate),
                 * so this is naturally a mouse-only convenience without
                 * disrupting touch users. */
                handle.addEventListener('dblclick', () => {
                    root.classList.add('is-toggling')
                    root.style.setProperty('--split', '50%')
                    try { sessionStorage.setItem(STORAGE_SPLIT, '50.0') } catch {}
                    setTimeout(() => root.classList.remove('is-toggling'), 360)
                })

                handle.addEventListener('keydown', (e) => {
                    const cur = parseFloat(getComputedStyle(root).getPropertyValue('--split')) || 50
                    let next = cur
                    if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') next = cur - 5
                    else if (e.key === 'ArrowRight' || e.key === 'ArrowDown') next = cur + 5
                    else if (e.key === 'Home') next = 30
                    else if (e.key === 'End') next = 75
                    else return
                    e.preventDefault()
                    next = Math.max(25, Math.min(80, next))
                    root.style.setProperty('--split', `${next}%`)
                    try { sessionStorage.setItem(STORAGE_SPLIT, next.toFixed(1)) } catch {}
                })
            }

            // ─── Expand-collapse code panel ───────────────────────
            // Both panes carry an `expand-btn` (so the affordance is
            // visible whichever variant is active); they toggle the
            // SAME root[data-expanded] attribute. The grid-template-
            // columns transition handles the smooth shrink/grow of
            // the iframe column and handle width. State is persisted
            // so the user's choice sticks across navigations.
            const expandBtns = root.querySelectorAll<HTMLButtonElement>('.expand-btn[data-expand-toggle]')
            const STORAGE_EXPANDED = 'flatland-example-expanded'

            try {
                if (sessionStorage.getItem(STORAGE_EXPANDED) === '1') {
                    root.setAttribute('data-expanded', 'true')
                }
            } catch {}

            // `animate` controls whether the .is-toggling class is
            // applied during the state change. We pass `false` on
            // initial-load restore so the page doesn't animate on
            // mount, and `true` for the user clicks so the transition
            // fires only then.
            const setExpanded = (expanded: boolean, animate: boolean) => {
                if (animate) {
                    root.classList.add('is-toggling')
                    setTimeout(() => root.classList.remove('is-toggling'), 360)
                }
                if (expanded) root.setAttribute('data-expanded', 'true')
                else root.removeAttribute('data-expanded')
                expandBtns.forEach((b) => {
                    b.setAttribute('aria-label', expanded ? 'Restore split view' : 'Expand code panel')
                    b.setAttribute('title', expanded ? 'Restore split view' : 'Expand code panel')
                })
                try { sessionStorage.setItem(STORAGE_EXPANDED, expanded ? '1' : '0') } catch {}
            }

            // Sync labels with restored state — no animation on mount.
            setExpanded(root.getAttribute('data-expanded') === 'true', false)

            expandBtns.forEach((btn) => {
                btn.addEventListener('click', () => {
                    setExpanded(root.getAttribute('data-expanded') !== 'true', true)
                })
            })

            // ─── Code panel collapse / dock-right ────────────────────
            // Hides the code pane entirely (`display: none` after the
            // shrink animation completes). Two-phase state machine:
            //   collapse:   set `data-code-collapsing` → wait 320ms for
            //               grid-template-columns transition → set
            //               `data-code-collapsed` (display:none takes
            //               the code DOM out of layout/paint entirely)
            //   uncollapse: clear `data-code-collapsed` → next rAF,
            //               start with `data-code-collapsing` (track
            //               still 0) → next rAF, clear collapsing so
            //               the track animates back to its full width.
            const codeToggleBtn = root.querySelector<HTMLButtonElement>('[data-code-toggle]')
            const codeToggleIcon = codeToggleBtn?.querySelector('.code-toggle-icon')
            const STORAGE_CODE_COLLAPSED = 'flatland-example-code-collapsed'
            const ANIM_MS = 320

            let pendingCollapseTimer: number | null = null

            const updateCodeToggleUi = (collapsed: boolean) => {
                if (!codeToggleBtn) return
                codeToggleBtn.setAttribute('aria-label', collapsed ? 'Show code panel' : 'Hide code panel')
                codeToggleBtn.setAttribute('title', collapsed ? 'Show code panel' : 'Hide code panel')
                if (codeToggleIcon) {
                    codeToggleIcon.classList.toggle('i-lucide:panel-right-close', !collapsed)
                    codeToggleIcon.classList.toggle('i-lucide:panel-right-open', collapsed)
                }
            }

            const setCodeCollapsed = (collapsed: boolean, animate: boolean) => {
                if (pendingCollapseTimer !== null) {
                    clearTimeout(pendingCollapseTimer)
                    pendingCollapseTimer = null
                }
                const isCurrentlyCollapsed = root.getAttribute('data-code-collapsed') === 'true'
                if (collapsed === isCurrentlyCollapsed && !root.hasAttribute('data-code-collapsing')) {
                    return
                }
                if (collapsed) {
                    if (animate) {
                        root.classList.add('is-toggling')
                        root.setAttribute('data-code-collapsing', 'true')
                        pendingCollapseTimer = window.setTimeout(() => {
                            root.classList.remove('is-toggling')
                            root.removeAttribute('data-code-collapsing')
                            root.setAttribute('data-code-collapsed', 'true')
                            pendingCollapseTimer = null
                        }, ANIM_MS)
                    } else {
                        root.setAttribute('data-code-collapsed', 'true')
                    }
                } else {
                    root.removeAttribute('data-code-collapsed')
                    if (animate) {
                        root.setAttribute('data-code-collapsing', 'true')
                        requestAnimationFrame(() => {
                            root.classList.add('is-toggling')
                            requestAnimationFrame(() => {
                                root.removeAttribute('data-code-collapsing')
                            })
                        })
                        pendingCollapseTimer = window.setTimeout(() => {
                            root.classList.remove('is-toggling')
                            pendingCollapseTimer = null
                        }, ANIM_MS + 16)
                    }
                }
                updateCodeToggleUi(collapsed)
                try { sessionStorage.setItem(STORAGE_CODE_COLLAPSED, collapsed ? '1' : '0') } catch {}
            }

            // Restore persisted state — no animation on mount.
            try {
                if (sessionStorage.getItem(STORAGE_CODE_COLLAPSED) === '1') {
                    setCodeCollapsed(true, false)
                } else {
                    updateCodeToggleUi(false)
                }
            } catch { updateCodeToggleUi(false) }

            codeToggleBtn?.addEventListener('click', () => {
                const next = root.getAttribute('data-code-collapsed') !== 'true'
                setCodeCollapsed(next, true)
            })

            // ─── Fullscreen ────────────────────────────────────────
            const fsBtn = root.querySelector<HTMLButtonElement>('[data-fullscreen]')
            fsBtn?.addEventListener('click', () => {
                const target = iframe as any
                if (!target) return
                const req =
                    target.requestFullscreen ||
                    target.webkitRequestFullscreen ||
                    target.mozRequestFullScreen ||
                    target.msRequestFullscreen
                req?.call(target)
            })

            // StackBlitz button — anchor with variant-aware href; no
            // click handler needed. URL-based fork import is slower
            // than the SDK's inline payload but works without bundling
            // the SDK and survives Vite optimizeDeps cache pollution.
        })
    }

    if (typeof document !== 'undefined') {
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', bindSplitViews, { once: true })
        } else {
            bindSplitViews()
        }
        document.addEventListener('astro:page-load', bindSplitViews)
    }
</script>
