---
/**
 * ExampleSplitView — side-by-side preview + code with a draggable
 * resizer. Live iframe on one side, syntax-highlighted multi-file
 * code viewer on the other. Toolbar carries Three / React variant
 * toggle, fullscreen, and an Open-in-StackBlitz CTA.
 *
 * Variant toggle (Three.js / React) drives:
 *   - iframe `src` swap
 *   - visible `.code-pane` swap (CSS attribute selector on
 *     `data-variant`)
 *   - StackBlitz link's href (points at the GitHub `examples/<variant>/<slug>`
 *     subtree)
 *   - Persisted to localStorage as `flatland-example-type`
 *
 * File tabs — for variants with more than one source file, a tab
 * strip lets the user switch between files. Boilerplate
 * (package.json, tsconfig.json, vite.config.ts) is filtered out;
 * the entry file (main.ts / App.tsx) is the default-active tab.
 *
 * Drag handle clamps to 25%–80%, persisted to localStorage as
 * `flatland-example-split`. Iframe gets `pointer-events: none`
 * during drag so the parent document keeps receiving pointermove
 * events when the cursor crosses the canvas.
 */
import { Code } from '@astrojs/starlight/components'

interface Props {
    slug: string
    threeFiles: Record<string, string>
    reactFiles: Record<string, string>
    /** Explicit list of files to surface in the Three.js code panel.
     *  Omit to show ONLY the entry file (`main.ts` / `main.tsx`).
     *  Pass an array (e.g. `['main.ts', 'src/util.ts']`) to expose
     *  multi-file browsing — useful for minis with many source
     *  files; overkill for the typical single-file example. */
    showThreeFiles?: string[]
    /** Same as `showThreeFiles` but for the React variant. Default
     *  is the entry file (`App.tsx` / `main.tsx`). */
    showReactFiles?: string[]
}

const { slug, threeFiles, reactFiles, showThreeFiles, showReactFiles } = Astro.props

/** Boilerplate paths that aren't worth showing in the in-page code
 *  viewer — they're regenerated by `loadExample()` and would only
 *  add noise. The full set IS still passed to StackBlitz so the
 *  exported project runs out-of-the-box. */
const HIDDEN_FILES = new Set(['package.json', 'tsconfig.json', 'vite.config.ts'])

/** File-extension → expressive-code language hint. */
function langFor(filename: string): string {
    const ext = filename.split('.').pop() || ''
    if (ext === 'ts') return 'ts'
    if (ext === 'tsx') return 'tsx'
    if (ext === 'js') return 'js'
    if (ext === 'jsx') return 'jsx'
    if (ext === 'mjs') return 'js'
    if (ext === 'json') return 'json'
    if (ext === 'css') return 'css'
    if (ext === 'html') return 'html'
    if (ext === 'glsl' || ext === 'wgsl') return 'glsl'
    return 'text'
}

/** Order-of-importance for the file tab strip. Entry file first,
 *  src/* in lexical order, then the rest. */
function orderFiles(entries: [string, string][], primary: string): [string, string][] {
    const visible = entries.filter(([k]) => !HIDDEN_FILES.has(k))
    visible.sort(([a], [b]) => {
        if (a === primary) return -1
        if (b === primary) return 1
        const aSrc = a.startsWith('src/')
        const bSrc = b.startsWith('src/')
        if (aSrc && !bSrc) return -1
        if (bSrc && !aSrc) return 1
        return a.localeCompare(b)
    })
    return visible
}

const threePrimary = 'main.ts' in threeFiles ? 'main.ts' : 'main.tsx' in threeFiles ? 'main.tsx' : Object.keys(threeFiles)[0] ?? ''
const reactPrimary = 'App.tsx' in reactFiles ? 'App.tsx' : 'main.tsx' in reactFiles ? 'main.tsx' : Object.keys(reactFiles)[0] ?? ''

// Default to entry-file-only when the host MDX hasn't opted into
// multi-file browsing. Examples are usually single-file; minis and
// any explicitly-multi-file example pass `showThreeFiles` /
// `showReactFiles` to surface additional sources.
const threeWhitelist = showThreeFiles ?? [threePrimary]
const reactWhitelist = showReactFiles ?? [reactPrimary]

function pickFiles(files: Record<string, string>, whitelist: string[], primary: string): [string, string][] {
    const allow = new Set(whitelist)
    return orderFiles(Object.entries(files).filter(([k]) => allow.has(k)), primary)
}

const threeOrdered = pickFiles(threeFiles, threeWhitelist, threePrimary)
const reactOrdered = pickFiles(reactFiles, reactWhitelist, reactPrimary)

const baseURL = (import.meta.env.BASE_URL || '/').replace(/\/$/, '')
const examplesPort = (import.meta.env.VITE_EXAMPLES_PORT as string) || ''
const isDev = import.meta.env.DEV

const threeSrc = isDev
    ? `http://localhost:${examplesPort}/three/${slug}/`
    : `${baseURL}/examples/three/${slug}/`
const reactSrc = isDev
    ? `http://localhost:${examplesPort}/react/${slug}/`
    : `${baseURL}/examples/react/${slug}/`

// GitHub source URLs — link straight to the example's directory on
// the repo so users can clone or copy via degit. Variant-aware so
// the link retargets when toggling Three/React.
const githubBase = 'https://github.com/thejustinwalsh/three-flatland/tree/main'
const threeGithubHref = `${githubBase}/examples/three/${slug}`
const reactGithubHref = `${githubBase}/examples/react/${slug}`

// StackBlitz payloads — JSON-serialized file maps are written into
// `<script type='application/json'>` blocks; the toolbar's StackBlitz
// button reads them at click time and calls `sdk.openProject(payload,
// { newWindow: true })`. This opens the SAME embed payload we serve
// inline (file maps + entry file) in a fresh StackBlitz tab.
const stackblitzPayloads = {
    three: {
        title: `${slug} — Three.js`,
        description: 'three-flatland example',
        template: 'node' as const,
        files: threeFiles,
        openFile: threePrimary,
    },
    react: {
        title: `${slug} — React`,
        description: 'three-flatland example (R3F)',
        template: 'node' as const,
        files: reactFiles,
        openFile: reactPrimary,
    },
}

const transitionName = `tile-examples-${slug}`
---

<div class="example-split" data-slug={slug} data-variant="three" style={`--split: 55%;`}>
    <div class="example-split-toolbar">
        <div class="variant-toggle" role="tablist" aria-label="Source variant">
            <button
                type="button"
                role="tab"
                aria-selected="true"
                data-variant-target="three"
            >
                <span class="i-simple-icons:threedotjs variant-icon" aria-hidden="true"></span>
                Three.js
            </button>
            <button
                type="button"
                role="tab"
                aria-selected="false"
                data-variant-target="react"
            >
                <span class="i-simple-icons:react variant-icon" aria-hidden="true"></span>
                React
            </button>
        </div>
        <div class="example-split-toolbar-actions">
            <a
                class="toolbar-btn github-btn"
                href={threeGithubHref}
                data-three-href={threeGithubHref}
                data-react-href={reactGithubHref}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="View source on GitHub"
                title="View source on GitHub"
            >
                <span class="i-lucide:github" aria-hidden="true"></span>
            </a>
            <button
                type="button"
                class="toolbar-btn stackblitz-btn"
                data-stackblitz
                aria-label="Open in StackBlitz"
                title="Open in StackBlitz"
            >
                <span class="i-simple-icons:stackblitz" aria-hidden="true"></span>
            </button>
            <button type="button" class="toolbar-btn" data-fullscreen aria-label="Fullscreen preview" title="Fullscreen preview">
                <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true">
                    <path
                        d="M3 6V3h3M13 6V3h-3M3 10v3h3M13 10v3h-3"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        fill="none"
                    />
                </svg>
            </button>
        </div>
    </div>

    {/* StackBlitz payloads — `<template>` is invisible by spec
       (browsers never render template content), avoiding any chance
       of the JSON payload leaking into the layout. The button click
       handler reads `template.content.textContent` to get the JSON
       string. Same files map + openFile that an in-page
       <StackBlitzEmbed> would have used, just opened in a fresh
       StackBlitz tab via sdk.openProject. */}
    <template
        data-stackblitz-payload="three"
        set:html={JSON.stringify(stackblitzPayloads.three)}
    />
    <template
        data-stackblitz-payload="react"
        set:html={JSON.stringify(stackblitzPayloads.react)}
    />

    <div class="example-split-grid">
        <div class="example-split-pane example-split-preview">
            <iframe
                data-three-src={threeSrc}
                data-react-src={reactSrc}
                src={threeSrc}
                title={`${slug} preview`}
                allow="cross-origin-isolated"
                style={`view-transition-name: ${transitionName};`}
            ></iframe>
        </div>
        <div
            class="example-split-handle"
            role="separator"
            aria-orientation="vertical"
            aria-label="Resize preview and code panels"
            tabindex="0"
        ></div>
        <div class="example-split-pane example-split-code">
            <div class="code-pane" data-variant-pane="three">
                <div class="file-tabs" role="tablist" aria-label="Files">
                    {threeOrdered.map(([filename], i) => (
                        <button
                            type="button"
                            role="tab"
                            class="file-tab"
                            data-file-tab={filename}
                            aria-selected={i === 0 ? 'true' : 'false'}
                        >
                            {filename}
                        </button>
                    ))}
                </div>
                {threeOrdered.map(([filename, content], i) => (
                    <div
                        class="file-content"
                        data-file-content={filename}
                        hidden={i !== 0 ? true : undefined}
                    >
                        <Code code={content} lang={langFor(filename)} meta="showLineNumbers" />
                    </div>
                ))}
            </div>
            <div class="code-pane" data-variant-pane="react">
                {reactOrdered.length > 1 && (
                    <div class="file-tabs" role="tablist" aria-label="Files">
                        {reactOrdered.map(([filename], i) => (
                            <button
                                type="button"
                                role="tab"
                                class="file-tab"
                                data-file-tab={filename}
                                aria-selected={i === 0 ? 'true' : 'false'}
                            >
                                {filename}
                            </button>
                        ))}
                    </div>
                )}
                {reactOrdered.map(([filename, content], i) => (
                    <div
                        class="file-content"
                        data-file-content={filename}
                        hidden={i !== 0 ? true : undefined}
                    >
                        <Code code={content} lang={langFor(filename)} meta="showLineNumbers" />
                    </div>
                ))}
            </div>
        </div>
    </div>
</div>

<style>
    .example-split {
        --split: 55%;
        --handle: 8px;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .example-split-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
    }

    .example-split-toolbar-actions {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
    }

    .variant-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0;
        padding: 0.1875rem;
        border-radius: calc(var(--radius) - 2px);
        background: color-mix(in oklab, var(--card) 92%, var(--background));
        box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--border) 70%, transparent);
    }

    .variant-toggle button {
        appearance: none;
        background: transparent;
        border: 0;
        padding: 0.3125rem 0.625rem;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--muted-foreground);
        border-radius: calc(var(--radius) - 4px);
        cursor: pointer;
        transition: color 0.15s, background-color 0.15s;
    }

    .variant-toggle button:hover {
        color: var(--foreground);
    }

    .variant-toggle button[aria-selected='true'] {
        background-color: var(--background);
        color: color-mix(in oklab, var(--diamond) 65%, var(--foreground));
        box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--diamond) 30%, var(--border));
    }

    .variant-icon {
        width: 0.875rem;
        height: 0.875rem;
    }

    .toolbar-btn {
        appearance: none;
        background: transparent;
        border: 0;
        padding: 0.4rem 0.5rem;
        color: var(--muted-foreground);
        border-radius: calc(var(--radius) - 4px);
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: color 0.15s, background-color 0.15s;
    }

    .toolbar-btn:hover {
        color: var(--diamond);
        background-color: color-mix(in oklab, var(--diamond) 10%, transparent);
    }

    .stackblitz-btn span {
        width: 1rem;
        height: 1rem;
    }

    .example-split-grid {
        display: grid;
        grid-template-columns: var(--split) var(--handle) 1fr;
        gap: 0;
        height: 70vh;
        min-height: 32rem;
        max-height: 56rem;
        border-radius: calc(var(--radius) + 0.25rem);
        overflow: hidden;
        background: var(--card);
        box-shadow:
            0 0 0 1px color-mix(in oklab, var(--border) 75%, transparent),
            0 24px 60px -20px color-mix(in oklab, var(--diamond) 25%, transparent);
    }

    .example-split-pane {
        position: relative;
        overflow: hidden;
        min-width: 0;
    }

    .example-split-preview iframe {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: 0;
        background: #1a1a2e;
        color-scheme: dark;
    }

    /* Drag fix — during a resize gesture, swallow pointer events on
     * the iframe so the cursor crossing the canvas doesn't sever the
     * parent document's pointermove stream. The handle's `data-dragging`
     * lasts only for the gesture; iframe is interactive again at
     * pointerup. */
    .example-split[data-dragging='true'] .example-split-preview iframe {
        pointer-events: none;
    }

    .example-split-handle {
        cursor: col-resize;
        background: color-mix(in oklab, var(--border) 70%, transparent);
        transition: background-color 0.15s;
        position: relative;
    }

    .example-split-handle::before {
        content: '';
        position: absolute;
        left: 50%;
        top: 50%;
        width: 2px;
        height: 2.5rem;
        transform: translate(-50%, -50%);
        background: color-mix(in oklab, var(--diamond) 50%, var(--muted-foreground));
        border-radius: 1px;
        pointer-events: none;
    }

    .example-split-handle:hover,
    .example-split-handle:focus-visible,
    .example-split[data-dragging='true'] .example-split-handle {
        background: color-mix(in oklab, var(--diamond) 25%, var(--border));
    }
    .example-split-handle:focus-visible {
        outline: 2px solid var(--diamond);
        outline-offset: -2px;
    }

    .example-split-code {
        background: var(--code-background);
        display: flex;
        flex-direction: column;
    }

    .code-pane {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .example-split[data-variant='three'] .code-pane[data-variant-pane='react'],
    .example-split[data-variant='react'] .code-pane[data-variant-pane='three'] {
        display: none;
    }

    /* File tab strip — sits above the code content, scrolls horizontally
     * when there are many files. Active tab carries the diamond
     * gem accent matching the variant-toggle treatment. */
    .file-tabs {
        flex: 0 0 auto;
        display: flex;
        align-items: center;
        gap: 0;
        overflow-x: auto;
        scrollbar-width: thin;
        background: color-mix(in oklab, var(--card) 92%, var(--code-background));
        border-bottom: 1px solid color-mix(in oklab, var(--border) 60%, transparent);
        padding: 0.25rem 0.375rem;
    }

    .file-tab {
        appearance: none;
        background: transparent;
        border: 0;
        padding: 0.375rem 0.625rem;
        font-family: 'Commit Mono', 'JetBrains Mono', ui-monospace, SFMono-Regular, monospace;
        font-size: 0.75rem;
        color: var(--muted-foreground);
        border-radius: calc(var(--radius) - 4px);
        cursor: pointer;
        white-space: nowrap;
        transition: color 0.15s, background-color 0.15s;
    }

    .file-tab:hover {
        color: var(--foreground);
        background-color: color-mix(in oklab, var(--background) 35%, transparent);
    }

    .file-tab[aria-selected='true'] {
        color: color-mix(in oklab, var(--diamond) 65%, var(--foreground));
        background-color: var(--background);
        box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--diamond) 30%, var(--border));
    }

    .file-content {
        flex: 1 1 auto;
        overflow: auto;
        background: var(--code-background);
    }

    .file-content[hidden] {
        display: none;
    }

    /* expressive-code's frame already has its own border-radius,
     * box-shadow, and chrome from our theme overrides. Inside the
     * code pane, drop those so the Code block sits flush against
     * the file tabs. */
    .file-content :global(.expressive-code) {
        margin: 0;
    }
    .file-content :global(.expressive-code .frame) {
        box-shadow: none;
        border-radius: 0;
    }
    .file-content :global(.expressive-code pre) {
        border-radius: 0;
    }
    /* The file tab strip already shows the filename; the
     * expressive-code figcaption duplicates it. Hide the figcaption
     * inside the split view's code panes only — markdown fenced
     * code blocks elsewhere keep their figcaption styling. */
    .file-content :global(.expressive-code figcaption.header) {
        display: none;
    }

    @media (max-width: 768px) {
        .example-split-grid {
            grid-template-columns: 1fr;
            grid-template-rows: 50vh var(--handle) 1fr;
            height: auto;
            min-height: 0;
            max-height: none;
        }
        .example-split-handle {
            cursor: row-resize;
        }
        .example-split-handle::before {
            width: 2.5rem;
            height: 2px;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .variant-toggle button,
        .toolbar-btn,
        .file-tab,
        .example-split-handle {
            transition: none;
        }
    }
</style>

<script>
    function bindSplitViews() {
        const splits = document.querySelectorAll<HTMLElement>('.example-split:not([data-bound])')
        splits.forEach((root) => {
            root.dataset.bound = '1'

            const toggleButtons = root.querySelectorAll<HTMLButtonElement>(
                '.variant-toggle button[data-variant-target]'
            )
            const iframe = root.querySelector<HTMLIFrameElement>('.example-split-preview iframe')
            const githubLink = root.querySelector<HTMLAnchorElement>('a.github-btn')
            const stackblitzBtn = root.querySelector<HTMLButtonElement>('button[data-stackblitz]')
            const STORAGE_VARIANT = 'flatland-example-type'

            // Active variant — the StackBlitz click handler reads this
            // to pick the right payload script. Captured here so the
            // closure stays current as setVariant() runs.
            let activeVariant: 'three' | 'react' = 'three'

            const restoreVariant = (): 'three' | 'react' => {
                try {
                    const v = localStorage.getItem(STORAGE_VARIANT)
                    return v === 'react' || v === 'three' ? v : 'three'
                } catch {
                    return 'three'
                }
            }

            const setVariant = (variant: 'three' | 'react') => {
                activeVariant = variant
                root.dataset.variant = variant
                toggleButtons.forEach((b) => {
                    b.setAttribute(
                        'aria-selected',
                        b.dataset.variantTarget === variant ? 'true' : 'false'
                    )
                })
                if (iframe) {
                    const next = iframe.dataset[`${variant}Src`] || iframe.src
                    if (iframe.src !== next) iframe.src = next
                }
                if (githubLink) {
                    const href = githubLink.dataset[`${variant}Href`]
                    if (href) githubLink.href = href
                }
                try { localStorage.setItem(STORAGE_VARIANT, variant) } catch {}
            }

            setVariant(restoreVariant())

            toggleButtons.forEach((btn) => {
                btn.addEventListener('click', () => {
                    const v = btn.dataset.variantTarget
                    if (v === 'three' || v === 'react') setVariant(v)
                })
            })

            // ─── File tabs ────────────────────────────────────────
            // Each .code-pane has its own file-tab strip + a list of
            // .file-content blocks. Tabs scoped per-variant so the
            // active file persists across variant toggles.
            const codePanes = root.querySelectorAll<HTMLElement>('.code-pane')
            codePanes.forEach((pane) => {
                const tabs = pane.querySelectorAll<HTMLButtonElement>('.file-tab[data-file-tab]')
                const contents = pane.querySelectorAll<HTMLElement>('.file-content[data-file-content]')
                tabs.forEach((tab) => {
                    tab.addEventListener('click', () => {
                        const target = tab.dataset.fileTab
                        tabs.forEach((t) => {
                            t.setAttribute(
                                'aria-selected',
                                t.dataset.fileTab === target ? 'true' : 'false'
                            )
                        })
                        contents.forEach((c) => {
                            if (c.dataset.fileContent === target) c.removeAttribute('hidden')
                            else c.setAttribute('hidden', '')
                        })
                    })
                })
            })

            // ─── Drag handle ──────────────────────────────────────
            const handle = root.querySelector<HTMLElement>('.example-split-handle')
            const grid = root.querySelector<HTMLElement>('.example-split-grid')
            const STORAGE_SPLIT = 'flatland-example-split'

            try {
                const saved = parseFloat(localStorage.getItem(STORAGE_SPLIT) || '')
                if (Number.isFinite(saved) && saved >= 25 && saved <= 80) {
                    root.style.setProperty('--split', `${saved}%`)
                }
            } catch {}

            if (handle && grid) {
                let dragging = false
                const isHorizontal = () => window.matchMedia('(min-width: 769px)').matches

                const onMove = (e: PointerEvent) => {
                    if (!dragging) return
                    const rect = grid.getBoundingClientRect()
                    const isHoriz = isHorizontal()
                    const total = isHoriz ? rect.width : rect.height
                    const offset = isHoriz ? e.clientX - rect.left : e.clientY - rect.top
                    const pct = Math.max(25, Math.min(80, (offset / total) * 100))
                    root.style.setProperty('--split', `${pct}%`)
                    try { localStorage.setItem(STORAGE_SPLIT, pct.toFixed(1)) } catch {}
                }

                const onUp = () => {
                    if (!dragging) return
                    dragging = false
                    root.removeAttribute('data-dragging')
                    document.body.style.removeProperty('user-select')
                    document.body.style.removeProperty('cursor')
                    window.removeEventListener('pointermove', onMove)
                    window.removeEventListener('pointerup', onUp)
                }

                handle.addEventListener('pointerdown', (e) => {
                    e.preventDefault()
                    dragging = true
                    root.setAttribute('data-dragging', 'true')
                    document.body.style.userSelect = 'none'
                    document.body.style.cursor = isHorizontal() ? 'col-resize' : 'row-resize'
                    window.addEventListener('pointermove', onMove)
                    window.addEventListener('pointerup', onUp)
                })

                handle.addEventListener('keydown', (e) => {
                    const cur = parseFloat(getComputedStyle(root).getPropertyValue('--split')) || 55
                    let next = cur
                    if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') next = cur - 5
                    else if (e.key === 'ArrowRight' || e.key === 'ArrowDown') next = cur + 5
                    else if (e.key === 'Home') next = 30
                    else if (e.key === 'End') next = 75
                    else return
                    e.preventDefault()
                    next = Math.max(25, Math.min(80, next))
                    root.style.setProperty('--split', `${next}%`)
                    try { localStorage.setItem(STORAGE_SPLIT, next.toFixed(1)) } catch {}
                })
            }

            // ─── Fullscreen ────────────────────────────────────────
            const fsBtn = root.querySelector<HTMLButtonElement>('[data-fullscreen]')
            fsBtn?.addEventListener('click', () => {
                const target = iframe as any
                if (!target) return
                const req =
                    target.requestFullscreen ||
                    target.webkitRequestFullscreen ||
                    target.mozRequestFullScreen ||
                    target.msRequestFullscreen
                req?.call(target)
            })

            // ─── StackBlitz: open the embed payload in a new tab ──
            // Reads the JSON payload for the active variant from
            // `<script type='application/json' data-stackblitz-payload>`,
            // dynamically imports the SDK (only when needed), and
            // calls `sdk.openProject(payload, { newWindow: true })`.
            // The opened project mirrors the same files/openFile that
            // the inline preview ran from — full IDE access in
            // StackBlitz, with the source-on-disk via the page's
            // loadExample() output.
            stackblitzBtn?.addEventListener('click', async () => {
                try {
                    const tpl = root.querySelector<HTMLTemplateElement>(
                        `template[data-stackblitz-payload="${activeVariant}"]`
                    )
                    const json = tpl?.innerHTML
                    if (!json) return
                    const payload = JSON.parse(json)
                    const { default: sdk } = await import('@stackblitz/sdk')
                    sdk.openProject(payload, { newWindow: true, openFile: payload.openFile })
                } catch (err) {
                    // Fall back to the GitHub bridge URL on any SDK
                    // failure (network blocked, popup blocked, etc.).
                    const fallback = `https://stackblitz.com/github/thejustinwalsh/three-flatland/tree/main/examples/${activeVariant}/${root.dataset.slug}`
                    window.open(fallback, '_blank', 'noopener')
                }
            })
        })
    }

    if (typeof document !== 'undefined') {
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', bindSplitViews, { once: true })
        } else {
            bindSplitViews()
        }
        document.addEventListener('astro:page-load', bindSplitViews)
    }
</script>
