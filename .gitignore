!.vscode/tasks.json
!.vscode/extensions.json
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Test
coverage/
playwright-report/
test-results/
.playwright/
.vscode-test/

# Turbo

# Astro
.astro/

# UnoCSS icon safelist (generated by starlight-plugin-icons)
.starlight-icons/

# Environment
.env
.env.local
.env.*.local

# Temporary
tmp/
temp/
.size-limit-filtered.*

# Agents
settings.local.json

# Vendor Library for examples to pull from
vendor/
!packages/image/vendor/
!packages/image/vendor/**

# Profile traces
traces/

# Local-only emitted artifacts: madge graph viewer HTML, size-limit --why
# bundle reports (per-branch). Single hidden dir keeps the repo root clean.
.reports/

# Generated by `pnpm graph:sync` — madge needs a tsconfig with all
# workspace package paths resolved.
tsconfig.madge.json

# Restruct
.restruct/
!.restruct/verify.yaml
!.restruct/permissions.yaml
.superpowers/

# Impeccable — local design-review hook cache, per-machine and per-session
.impeccable/

# VS Code extension packaging — sidecar binaries (bundle-sidecars.mjs),
# the packaged VSIX itself, and the LICENSE copy package-vsix.mjs
# regenerates from the repo root's real one on every run.
tools/vscode/bin/
tools/vscode/audio-play/
tools/vscode/*.vsix
tools/vscode/LICENSE
.nx/cache
.nx/workspace-data
.nx/migrate-runs
